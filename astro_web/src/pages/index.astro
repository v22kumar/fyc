---
import Layout from '../layouts/Layout.astro';
---

<Layout title="முகப்பு / Home">
  <div class="hero-section">
    <div class="hero-content">
      <h1 id="hero-title">ஒன்றாக நாம் ஒரு நல்ல நாளை உருவாக்குவோம்</h1>
      <p id="hero-subtitle">Together We Build Better Tomorrow</p>
      <div class="hero-actions">
        <a href="/issues" class="btn btn-primary" id="cta-report">பிரச்சனையை பதிவு செய்யவும் / Report Issue</a>
        <a href="/donors" class="btn btn-secondary" id="cta-blood">இரத்தம் தேவை / Request Blood</a>
      </div>
    </div>
    <div class="hero-image-card">
      <div class="seedling-img">🌱</div>
    </div>
  </div>

  <div class="quick-access-section">
    <h2 id="section-quick-access">விரைவு அணுகல் / Quick Access</h2>
    <div class="grid-3" style="margin-top: 1.5rem;">
      <a href="/donors" class="card quick-card">
        <span class="quick-icon">🩸</span>
        <div class="quick-text">
          <h3 class="quick-title-ta">இரத்த தான நெட்வொர்க்</h3>
          <h3 class="quick-title-en">Blood Donation Network</h3>
          <p class="quick-desc">குருதி கொடையாளர்களைக் கண்டறிய அல்லது கொடையாளராக இணைய.</p>
        </div>
      </a>

      <a href="/issues" class="card quick-card">
        <span class="quick-icon">⚠️</span>
        <div class="quick-text">
          <h3 class="quick-title-ta">பொது பிரச்சனைகள் புகாரளிப்பு</h3>
          <h3 class="quick-title-en">Public Issue Reporting</h3>
          <p class="quick-desc">சாலைகள், தெருவிளக்குகள் மற்றும் கழிவுநீர் சிக்கல்களை தீர்க்க புகாரளிக்கவும்.</p>
        </div>
      </a>

      <a href="/directory" class="card quick-card">
        <span class="quick-icon">📞</span>
        <div class="quick-text">
          <h3 class="quick-title-ta">அரசு & அவசர தொடர்புகள்</h3>
          <h3 class="quick-title-en">Government & Public Directory</h3>
          <p class="quick-desc">அரசு மருத்துவமனைகள், காவல் நிலையங்கள் மற்றும் அவசர உதவி எண்கள்.</p>
        </div>
      </a>
    </div>
  </div>

  <div class="impact-section">
    <div class="card" style="background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light)); color: #ffffff; padding: 2.5rem; text-align: center;">
      <h2 id="impact-title" style="font-family: 'Outfit', sans-serif;">எங்கள் சமூக தாக்கம் / Our Impact</h2>
      <p style="opacity: 0.8; margin-top: 0.5rem; margin-bottom: 2rem;">25+ Years of Service: 1998 - 2025</p>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem;">
        <div>
          <div class="impact-num">1500+</div>
          <p class="impact-lbl-ta">மரம் நடப்பட்டது</p>
          <p class="impact-lbl-en">Trees Planted</p>
        </div>
        <div>
          <div class="impact-num">1200+</div>
          <p class="impact-lbl-ta">இரத்த கொடையாளர்கள்</p>
          <p class="impact-lbl-en">Blood Donors</p>
        </div>
        <div>
          <div class="impact-num">80+</div>
          <p class="impact-lbl-ta">நடத்தப்பட்ட நிகழ்வுகள்</p>
          <p class="impact-lbl-en">Events Organized</p>
        </div>
        <div>
          <div class="impact-num">5000+</div>
          <p class="impact-lbl-ta">பயனடைந்த மக்கள்</p>
          <p class="impact-lbl-en">Lives Impacted</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    .hero-section {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
      margin-bottom: 3.5rem;
      background-color: #ffffff;
      padding: 3rem;
      border-radius: var(--radius-lg);
      border: 1px solid #e5e7eb;
    }

    .hero-content {
      flex: 1.2;
    }

    .hero-content h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 2.5rem;
      color: var(--color-primary);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }

    .hero-content p {
      font-size: 1.25rem;
      color: var(--color-text-muted);
      margin-bottom: 2rem;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
    }

    .hero-image-card {
      flex: 0.8;
      background-color: #ecfdf5;
      height: 250px;
      border-radius: var(--radius-lg);
      display: flex;
      justify-content: center;
      align-items: center;
      box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }

    .seedling-img {
      font-size: 6rem;
      animation: float 4s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    .quick-access-section {
      margin-bottom: 3.5rem;
    }

    .quick-card {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
      text-decoration: none;
      color: inherit;
    }

    .quick-icon {
      font-size: 2.25rem;
      background-color: #f3f4f6;
      padding: 0.5rem;
      border-radius: var(--radius-md);
    }

    .quick-text h3 {
      font-size: 1.1rem;
      color: var(--color-primary);
    }

    .quick-text p {
      font-size: 0.85rem;
      color: var(--color-text-muted);
      margin-top: 0.5rem;
    }

    .impact-section {
      margin-bottom: 2rem;
    }

    .impact-num {
      font-size: 3rem;
      font-weight: 800;
      font-family: 'Outfit', sans-serif;
      margin-bottom: 0.25rem;
    }

    .impact-lbl-ta {
      font-size: 0.95rem;
      font-weight: 500;
    }

    .impact-lbl-en {
      font-size: 0.8rem;
      opacity: 0.75;
    }

    @media (max-width: 768px) {
      .hero-section {
        flex-direction: column;
        padding: 1.5rem;
        text-align: center;
      }
      .hero-actions {
        justify-content: center;
      }
      .hero-image-card {
        width: 100%;
        height: 180px;
      }
    }
  </style>

  <script is:inline>
    // Translate text dynamically on language change
    window.addEventListener('lang-change', (e) => {
      const lang = e.detail;
      const translations = {
        ta: {
          'hero-title': 'ஒன்றாக நாம் ஒரு நல்ல நாளை உருவாக்குவோம்',
          'hero-subtitle': 'Together We Build Better Tomorrow',
          'cta-report': 'பிரச்சனையை பதிவு செய்யவும் / Report Issue',
          'cta-blood': 'இரத்தம் தேவை / Request Blood',
          'section-quick-access': 'விரைவு அணுகல் / Quick Access',
          'impact-title': 'எங்கள் சமூக தாக்கம் / Our Impact'
        },
        en: {
          'hero-title': 'Together, We Build a Better Tomorrow',
          'hero-subtitle': 'Unite. Play. Thrive. More than friends, a brotherhood.',
          'cta-report': 'Report Public Issue',
          'cta-blood': 'Blood Request',
          'section-quick-access': 'Quick Access Dashboard',
          'impact-title': 'Our Community Impact Metrics'
        }
      };

      const trans = translations[lang];
      for (const [id, val] of Object.entries(trans)) {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
      }
    });
  </script>
</Layout>
