---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Fetch events
const res = await fetch('http://127.0.0.1:8000/api/v1/events', {
  headers: {
    // Assuming public access is scoped by some default tenant id or it doesn't need it.
    // Wait, list_events requires tenant_id. Let's pass the default one.
    'X-Organization-ID': '8f8b80b7-4b71-4770-b183-5c5f49e49a1d'
  }
}).catch(() => null);

let events = [];
if (res && res.ok) {
  events = await res.json();
}
---

<Layout title="FYC Events | Upcoming Programs">
  <Header />
  
  <main class="events-page">
    <div class="hero">
      <h1>Upcoming Events</h1>
      <p>Join FYC's latest initiatives, programs, and celebrations.</p>
    </div>

    <section class="events-grid">
      {events.length === 0 ? (
        <p class="no-events">No upcoming events at the moment. Please check back later.</p>
      ) : (
        events.map(event => (
          <div class="event-card">
            <div class="event-date">
              <span class="day">{new Date(event.event_start).getDate()}</span>
              <span class="month">{new Date(event.event_start).toLocaleString('default', { month: 'short' })}</span>
            </div>
            <div class="event-info">
              <h2>{event.title_en}</h2>
              <p class="desc">{event.description_en.substring(0, 100)}...</p>
              <a href={`/events/${event.id}`} class="btn">View & Register</a>
            </div>
          </div>
        ))
      )}
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .events-page {
    min-height: 70vh;
    padding-bottom: 4rem;
  }
  .hero {
    background: linear-gradient(135deg, #064e3b, #0f766e);
    color: white;
    text-align: center;
    padding: 4rem 1rem;
    margin-bottom: 3rem;
  }
  .hero h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .events-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
    padding: 0 1rem;
  }
  .event-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    display: flex;
    overflow: hidden;
    transition: transform 0.2s;
  }
  .event-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0,0,0,0.1);
  }
  .event-date {
    background: #f0fdf4;
    color: #064e3b;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 90px;
    border-right: 1px solid #e5e7eb;
  }
  .event-date .day { font-size: 2rem; font-weight: bold; line-height: 1; }
  .event-date .month { font-size: 1rem; text-transform: uppercase; font-weight: 600; margin-top: 0.25rem; }
  .event-info { padding: 1.5rem; flex-grow: 1; }
  .event-info h2 { font-size: 1.25rem; margin-bottom: 0.5rem; color: #111827; }
  .event-info .desc { color: #6b7280; font-size: 0.95rem; margin-bottom: 1.25rem; line-height: 1.5; }
  .btn { display: inline-block; background: #064e3b; color: white; padding: 0.5rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
  .btn:hover { background: #0f5132; }
  .no-events { text-align: center; color: #6b7280; grid-column: 1 / -1; padding: 3rem; }
</style>
