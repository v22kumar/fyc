---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const { id } = Astro.params;

// Fetch event details
const res = await fetch(`http://127.0.0.1:8000/api/v1/events/${id}`, {
  headers: {
    'X-Organization-ID': '8f8b80b7-4b71-4770-b183-5c5f49e49a1d'
  }
}).catch(() => null);

if (!res || !res.ok) {
  return Astro.redirect('/events');
}

const event = await res.json();
---

<Layout title={`${event.title_en} | Registration`}>
  <Header />
  
  <main class="registration-page">
    <div class="header-banner">
      <div class="container">
        <a href="/events" class="back-link">← Back to Events</a>
        <h1>{event.title_en}</h1>
        <p class="ta-title">{event.title_ta}</p>
        <div class="meta">
            <span>📅 {new Date(event.event_start).toLocaleDateString()}</span>
            <span>⏰ {new Date(event.event_start).toLocaleTimeString()} - {new Date(event.event_end).toLocaleTimeString()}</span>
        </div>
      </div>
    </div>

    <div class="container content-split">
      <div class="details">
        <h3>About Event</h3>
        <p>{event.description_en}</p>
        <p class="ta-desc">{event.description_ta}</p>
        
        {event.registration_deadline && (
            <div class="alert warning">
                Registration Deadline: <strong>{new Date(event.registration_deadline).toLocaleDateString()}</strong>
            </div>
        )}
      </div>

      <div class="registration-form-container">
        <h3>Register Now</h3>
        <form id="regForm" class="reg-form">
          <input type="hidden" id="eventId" value={event.id} />
          
          <div class="form-group">
            <label>Full Name *</label>
            <input type="text" id="name" required />
          </div>
          
          <div class="form-row">
            <div class="form-group">
                <label>Age *</label>
                <input type="number" id="age" required min="5" max="100" />
            </div>
            <div class="form-group">
                <label>Gender *</label>
                <select id="gender" required>
                    <option value="">Select</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
                <label>Mobile Number *</label>
                <input type="tel" id="mobile" required pattern="[0-9]{10}" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="email" />
            </div>
          </div>

          <div class="form-group">
            <label>School / College</label>
            <input type="text" id="school" />
          </div>
          
          <div class="form-group">
            <label>Class / Grade Category *</label>
            <select id="grade" required>
              <option value="">Select Category</option>
              <option value="1 முதல் 3 ஆம் வகுப்பு">1 முதல் 3 ஆம் வகுப்பு</option>
              <option value="4 முதல் 5 ஆம் வகுப்பு">4 முதல் 5 ஆம் வகுப்பு</option>
              <option value="6 முதல் 8 ஆம் வகுப்பு">6 முதல் 8 ஆம் வகுப்பு</option>
              <option value="9 முதல் 10 ஆம் வகுப்பு">9 முதல் 10 ஆம் வகுப்பு</option>
              <option value="11 மற்றும் 12 ஆம் வகுப்பு">11 மற்றும் 12 ஆம் வகுப்பு</option>
              <option value="கல்லூரி மாணவர்கள்">கல்லூரி மாணவர்கள்</option>
              <option value="திறந்த பிரிவு">திறந்த பிரிவு</option>
            </select>
          </div>

          <div class="form-group" id="competitions-container" style="display: none;">
            <label>Select Competitions & Topics *</label>
            <div id="dynamic-competitions" class="checkbox-group">
              <!-- Dynamically populated -->
            </div>
          </div>

          <div class="form-group">
            <label>Address</label>
            <textarea id="address" rows="2"></textarea>
          </div>

          <button type="submit" class="submit-btn">Submit Registration</button>
          <div id="msg" class="msg"></div>
        </form>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
    const compData = {
      "1 முதல் 3 ஆம் வகுப்பு": {
        "பேச்சுப் போட்டி": ["என் அம்மா என் முதல் ஆசிரியர்", "நான் பெரியவனாக / பெரியவளாக ஆன பிறகு", "என் செல்லப் பிராணி", "மரங்கள் ஏன் நண்பர்கள்?", "மகிழ்ச்சியான பள்ளி"],
        "ஒப்பித்தல் போட்டி": ["தாய் பற்றிய கவிதை", "இயற்கை கவிதை", "குழந்தைகள் கவிதை", "நல்ல பழக்கங்கள்"],
        "ஓவியப் போட்டி": ["என் குடும்பம்", "என் பள்ளி", "வண்ணத்துப்பூச்சி உலகம்"]
      },
      "4 முதல் 5 ஆம் வகுப்பு": {
        "பேச்சுப் போட்டி": ["மொபைல் நல்ல நண்பனா?", "புத்தகம் VS மொபைல்", "நான் காப்பாற்ற விரும்பும் ஒரு உயிரினம்", "என் ஊர்", "எதிர்காலத்தில் நான் உருவாக்க விரும்பும் கண்டுபிடிப்பு"],
        "ஒப்பித்தல் போட்டி": ["தேசபற்று கவிதை", "தமிழ் பற்றிய கவிதை", "உழைப்பு பற்றிய கவிதை"],
        "கட்டுரைப் போட்டி": ["என் கனவு பள்ளி", "சுற்றுச்சூழலை நான் எப்படி காப்பாற்றுவேன்?"]
      },
      "6 முதல் 8 ஆம் வகுப்பு": {
        "பேச்சுப் போட்டி": ["AI என் நண்பனா அல்லது போட்டியாளரா?", "சமூக ஊடகங்கள் நம்மை மாற்றுகிறதா?", "பிளாஸ்டிக் இல்லா உலகம் சாத்தியமா?", "விளையாட்டு மற்றும் வாழ்க்கை", "தோல்வி வெற்றியின் தாயா?"],
        "ஒப்பித்தல் போட்டி": ["மனிதநேயம்", "இயற்கை பாதுகாப்பு", "இளைஞர் எழுச்சி"],
        "கட்டுரைப் போட்டி": ["2050-ல் என் இந்தியா", "இணைய உலகில் பாதுகாப்பு", "விண்வெளி ஆராய்ச்சியின் எதிர்காலம்"]
      },
      "9 முதல் 10 ஆம் வகுப்பு": {
        "பேச்சுப் போட்டி": ["செயற்கை நுண்ணறிவு மனிதனை மிஞ்சுமா?", "மதிப்பெண்களா? திறமைகளா?", "சமூக ஊடகங்கள்: வரமா சாபமா?", "காலநிலை மாற்றம் – இளைஞர்களின் பங்கு", "எதிர்கால வேலைகள் எப்படி இருக்கும்?"],
        "ஒப்பித்தல் போட்டி": ["பாரதியார் கவிதைகள்", "பெண்கள் முன்னேற்றம்", "சுதந்திரம் மற்றும் பொறுப்பு"],
        "கட்டுரைப் போட்டி": ["AI மற்றும் மனிதநேயம்", "டிஜிட்டல் இந்தியா", "நல்ல தலைமைத்துவம்"]
      },
      "11 மற்றும் 12 ஆம் வகுப்பு": {
        "பேச்சுப் போட்டி": ["AI காலத்தில் கல்வி எப்படி மாற வேண்டும்?", "தொழில்நுட்பம் மனித உறவுகளை பாதிக்கிறதா?", "இந்தியா 2047", "இளைஞர்களும் தொழில்முனைவும்", "மனநலம் பற்றி பேச வேண்டிய நேரமா?"],
        "ஒப்பித்தல் போட்டி": ["பாரதிதாசன் கவிதைகள்", "சமூக மாற்றக் கவிதைகள்", "பெண் விடுதலைக் கவிதைகள்"],
        "கட்டுரைப் போட்டி": ["Start-up India", "செயற்கை நுண்ணறிவு மற்றும் வேலைவாய்ப்பு", "இந்தியாவின் உலகளாவிய பங்கு"]
      },
      "கல்லூரி மாணவர்கள்": {
        "பேச்சுப் போட்டி": ["ChatGPT மற்றும் AI: கல்வியின் எதிர்காலம்", "Startup vs Job", "இந்தியா உலகின் AI தலைநகரமாக முடியுமா?", "சமூக ஊடகங்களில் உண்மை மற்றும் பொய்", "இன்றைய தலைமுறையின் மிகப்பெரிய சவால் என்ன?"],
        "விவாதப் போட்டி": ["AI மனித வேலைகளை பறிக்குமா?", "ஆன்லைன் கல்வியா? நேரடி கல்வியா?", "அரசு வேலை vs தனியார் வேலை"],
        "கட்டுரைப் போட்டி": ["2047 வளர்ந்த இந்தியா", "Climate Tech", "AI Ethics"]
      },
      "திறந்த பிரிவு": {
        "திறந்த பிரிவு": ["3 நிமிடங்களில் ஒரு பிரச்சனைக்கு தீர்வு கூறு", "தமிழில் TED Talk", "ஒரு புதிய சமூக மாற்ற யோசனை", "என் ஊருக்கான ஒரு Startup Idea", "AI-ஐ பயன்படுத்தி கிராம வளர்ச்சி"]
      }
    };

    const gradeSelect = document.getElementById('grade');
    const compContainer = document.getElementById('competitions-container');
    const dynComps = document.getElementById('dynamic-competitions');

    gradeSelect?.addEventListener('change', (e) => {
        const val = (e.target as HTMLSelectElement).value;
        if (!val || !compData[val]) {
            if (compContainer) compContainer.style.display = 'none';
            if (dynComps) dynComps.innerHTML = '';
            return;
        }

        let html = '';
        const types = compData[val];
        for (const [type, topics] of Object.entries(types)) {
            html += `<div style="margin-bottom:1rem;"><strong>${type}</strong><br/>`;
            topics.forEach((topic: string) => {
                html += `
                <label class="cb-label" style="margin-left: 10px; margin-top: 5px;">
                    <input type="checkbox" name="competitions" value="${type}: ${topic}" />
                    ${topic}
                </label>`;
            });
            html += `</div>`;
        }
        if (dynComps) dynComps.innerHTML = html;
        if (compContainer) compContainer.style.display = 'block';
    });

    const form = document.getElementById('regForm');
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const eventId = (document.getElementById('eventId') as HTMLInputElement).value;
        const msgEl = document.getElementById('msg');
        
        // Collect competitions
        const cbNodes = document.querySelectorAll('input[name="competitions"]:checked');
        const competitions = Array.from(cbNodes).map((cb: any) => cb.value);

        if (competitions.length === 0) {
            alert("Please select at least one competition topic.");
            return;
        }

        const payload = {
            name: (document.getElementById('name') as HTMLInputElement).value,
            age: parseInt((document.getElementById('age') as HTMLInputElement).value),
            gender: (document.getElementById('gender') as HTMLSelectElement).value,
            mobile_number: (document.getElementById('mobile') as HTMLInputElement).value,
            email: (document.getElementById('email') as HTMLInputElement).value || null,
            school_college: (document.getElementById('school') as HTMLInputElement).value || null,
            class_grade: (document.getElementById('grade') as HTMLSelectElement).value,
            address: (document.getElementById('address') as HTMLInputElement).value || null,
            competition_category: competitions
        };

        try {
            const res = await fetch(`http://127.0.0.1:8000/api/v1/events/${eventId}/register`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Organization-ID': '8f8b80b7-4b71-4770-b183-5c5f49e49a1d'
                },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (res.ok) {
                if (msgEl) {
                    msgEl.className = 'msg success';
                    msgEl.textContent = 'Registration successful!';
                }
                (form as HTMLFormElement).reset();
                if (compContainer) compContainer.style.display = 'none';
            } else {
                if (msgEl) {
                    msgEl.className = 'msg error';
                    msgEl.textContent = data.detail || 'Registration failed';
                }
            }
        } catch (err) {
            if (msgEl) {
                msgEl.className = 'msg error';
                msgEl.textContent = 'Network error. Please try again.';
            }
        }
    });
</script>

<style>
  .registration-page { background: #f9fafb; min-height: 100vh; padding-bottom: 4rem; }
  .header-banner { background: #064e3b; color: white; padding: 3rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .back-link { color: #a7f3d0; text-decoration: none; margin-bottom: 1rem; display: inline-block; font-size: 0.9rem; }
  .header-banner h1 { font-size: 2.2rem; margin: 0.5rem 0; }
  .ta-title { color: #d1fae5; font-size: 1.1rem; margin-bottom: 1.5rem; }
  .meta { display: flex; gap: 1.5rem; font-size: 0.95rem; color: #a7f3d0; }
  
  .content-split { display: grid; grid-template-columns: 1fr 450px; gap: 3rem; margin-top: 3rem; }
  @media (max-width: 800px) { .content-split { grid-template-columns: 1fr; } }
  
  .details h3 { font-size: 1.5rem; margin-bottom: 1rem; color: #111827; }
  .details p { color: #4b5563; line-height: 1.7; margin-bottom: 1rem; }
  .ta-desc { font-size: 0.95rem; }
  .alert { padding: 1rem; border-radius: 8px; margin-top: 2rem; font-size: 0.95rem; }
  .alert.warning { background: #fffbeb; color: #b45309; border: 1px solid #fde68a; }
  
  .registration-form-container { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
  .registration-form-container h3 { margin-top: 0; margin-bottom: 1.5rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 1rem; }
  .reg-form { display: flex; flexDirection: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  label { font-weight: 500; font-size: 0.9rem; color: #374151; }
  input[type="text"], input[type="number"], input[type="tel"], input[type="email"], select, textarea {
      padding: 0.6rem; border: 1px solid #d1d5db; border-radius: 6px; font-family: inherit; width: 100%; box-sizing: border-box;
  }
  .checkbox-group { display: flex; flex-direction: column; gap: 0.5rem; background: #f3f4f6; padding: 1rem; border-radius: 6px; }
  .cb-label { display: flex; align-items: center; gap: 0.5rem; font-weight: normal; cursor: pointer; font-size: 0.9rem; color: #4b5563; }
  
  .submit-btn { background: #064e3b; color: white; border: none; padding: 0.8rem; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 1rem; width: 100%; margin-top: 1rem; }
  .submit-btn:hover { background: #0f5132; }
  
  .msg { margin-top: 1rem; padding: 0.8rem; border-radius: 6px; font-size: 0.9rem; text-align: center; display: none; }
  .msg.success { display: block; background: #d1fae5; color: #065f46; }
  .msg.error { display: block; background: #fee2e2; color: #991b1b; }
</style>
