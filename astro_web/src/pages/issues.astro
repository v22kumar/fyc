---
import Layout from '../layouts/Layout.astro';
---

<Layout title="பொது பிரச்சனைகள் / Public Issues">
  <div class="issue-container">
    <div class="card header-card">
      <span class="icon-header">⚠️</span>
      <div>
        <h1 id="page-title">பொது பிரச்சனைகள் புகாரளிப்பு</h1>
        <p id="page-subtitle">பிரச்சனைகளை பதிவு செய்யவும், நாம் ஒன்றாக தீர்ப்போம். / Report community infrastructure or safety issues.</p>
      </div>
    </div>

    <div class="grid-3" style="grid-template-columns: 1.5fr 1fr; align-items: start; gap: 2rem;">
      <!-- Report Form -->
      <div class="card form-card">
        <h2 id="form-header" style="color: var(--color-primary); margin-bottom: 1.5rem;">புகார் படிவம் / Issue Form</h2>
        
        <form id="issue-form" class="issue-form">
          <div class="form-group">
            <label id="lbl-category" class="form-label">பிரச்சனை வகை / Category</label>
            <select name="category" id="category" class="form-select" required>
              <option value="ROAD">சாலை பிரச்சனைகள் / Road Issues</option>
              <option value="WATER">குடிநீர் விநியோகம் / Water Supply Issues</option>
              <option value="STREET_LIGHT">தெரு விளக்கு பழுது / Street Light Failure</option>
              <option value="GARBAGE">கழிவு மேலாண்மை / Garbage Issues</option>
              <option value="SAFETY">பொது பாதுகாப்பு / Public Safety Concerns</option>
            </select>
          </div>

          <div class="form-group">
            <label id="lbl-desc-ta" class="form-label">விளக்கம் (தமிழ்) / Description (Tamil)</label>
            <textarea name="description_ta" id="description_ta" class="form-textarea" placeholder="பிரச்சனையைப் பற்றி விரிவாக விவரிக்கவும்..." required></textarea>
          </div>

          <div class="form-group">
            <label id="lbl-desc-en" class="form-label">Description (English)</label>
            <textarea name="description_en" id="description_en" class="form-textarea" placeholder="Describe the issue in detail..." required></textarea>
          </div>

          <div class="form-group">
            <label id="lbl-geo" class="form-label">இருப்பிடம் / Geolocation</label>
            <div style="display: flex; gap: 0.5rem; align-items: center;">
              <button type="button" class="btn btn-secondary" id="btn-locate">📍 இருப்பிடத்தை பெருக / Get Location</button>
              <span id="geo-status" style="font-size: 0.85rem; color: var(--color-text-muted);">இருப்பிடம் பெறப்படவில்லை</span>
            </div>
            <input type="hidden" name="latitude" id="latitude" required />
            <input type="hidden" name="longitude" id="longitude" required />
          </div>

          <div class="form-group">
            <label id="lbl-photo" class="form-label">புகைப்படம் பதிவேற்றவும் / Upload Photo</label>
            <input type="file" name="file" id="file" class="form-file" accept="image/*" required />
          </div>

          <button type="submit" class="btn btn-primary" id="btn-submit" style="width: 100%; padding: 0.85rem;">புகாரை பதிவு செய்க / Submit Issue</button>
        </form>
      </div>

      <!-- Recent Issues List & Workflow -->
      <div>
        <div class="card" style="margin-bottom: 1.5rem;">
          <h3 id="lbl-workflow" style="color: var(--color-primary); margin-bottom: 0.75rem;">தீர்வு முறைமை / Workflow</h3>
          <ol style="margin-left: 1.25rem; font-size: 0.85rem; color: var(--color-text-muted); display: flex; flex-direction: column; gap: 0.5rem;">
            <li><strong>புதிய புகார் (New):</strong> குடிமகன் பிரச்சனையைப் பதிவு செய்கிறார்.</li>
            <li><strong>ஒப்படைப்பு (Assigned):</strong> நிர்வாகி தன்னார்வலரை நியமிக்கிறார்.</li>
            <li><strong>ஆராய்வு (Under Review):</strong> தன்னார்வலர் கள ஆய்வு மேற்கொள்கிறார்.</li>
            <li><strong>தீர்வு (Resolved):</strong> தன்னார்வலர் சரிசெய்து புகைப்படத்துடன் தீர்வு காண்கிறார்.</li>
            <li><strong>மூடல் (Closed):</strong> புகார் சரிபார்க்கப்பட்டு மூடப்படுகிறது.</li>
          </ol>
        </div>

        <div class="card">
          <h3 id="lbl-recent-issues" style="color: var(--color-primary); margin-bottom: 1rem;">சமீபத்திய புகார்கள் / Recent Issues</h3>
          <div id="recent-issues-list" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <!-- Will load dynamically -->
            <p style="font-size: 0.85rem; text-align: center; color: var(--color-text-muted);">ஏற்றுகிறது / Loading...</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .issue-container {
      max-width: 1000px;
      margin: 0 auto;
    }

    .header-card {
      display: flex;
      gap: 1.5rem;
      align-items: center;
      background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
      color: #ffffff;
      margin-bottom: 2rem;
      padding: 2rem;
    }

    .header-card h1 {
      font-size: 2.25rem;
      font-family: 'Outfit', sans-serif;
    }

    .icon-header {
      font-size: 3.5rem;
    }

    .form-card {
      padding: 2rem;
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-label {
      display: block;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-text-dark);
      margin-bottom: 0.35rem;
    }

    .form-select, .form-textarea, .form-file {
      width: 100%;
      padding: 0.65rem;
      border: 1px solid #d1d5db;
      border-radius: var(--radius-md);
      font-size: 0.95rem;
      outline: none;
    }

    .form-select:focus, .form-textarea:focus {
      border-color: var(--color-primary);
    }

    .form-textarea {
      height: 100px;
      resize: vertical;
    }

    /* Recent Issue Cards */
    .recent-issue-card {
      background-color: var(--color-bg-light);
      padding: 0.75rem;
      border-radius: var(--radius-md);
      font-size: 0.85rem;
      border: 1px solid #e5e7eb;
    }

    .issue-meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.25rem;
      font-weight: 600;
    }

    .status-badge {
      font-size: 0.75rem;
      padding: 0.1rem 0.4rem;
      border-radius: 4px;
      font-weight: 700;
    }

    .status-new { background-color: #dbeafe; color: #1e40af; }
    .status-assigned { background-color: #f3e8ff; color: #6b21a8; }
    .status-under_review { background-color: #ffedd5; color: #9a3412; }
    .status-resolved { background-color: #dcfce7; color: #166534; }
    .status-closed { background-color: #f3f4f6; color: #374151; }

    @media (max-width: 768px) {
      .grid-3 {
        grid-template-columns: 1fr !important;
      }
    }
  </style>

  <script is:inline>
    const API_BASE = "http://127.0.0.1:8000/api/v1";
    const DEFAULT_ORG_ID = "8f8b80b7-4b71-4770-b183-5c5f49e49a1d";

    const btnLocate = document.getElementById("btn-locate");
    const geoStatus = document.getElementById("geo-status");
    const latInput = document.getElementById("latitude");
    const lngInput = document.getElementById("longitude");
    const issueForm = document.getElementById("issue-form");
    const recentList = document.getElementById("recent-issues-list");

    // Geolocation Handling
    btnLocate.addEventListener("click", () => {
      const lang = localStorage.getItem("lang") || "ta";
      geoStatus.textContent = lang === "ta" ? "இருப்பிடம் பெறப்படுகிறது..." : "Locating...";

      if (!navigator.geolocation) {
        geoStatus.textContent = lang === "ta" ? "இருப்பிட வசதி இல்லை" : "Not supported by browser";
        return;
      }

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const lat = position.coords.latitude;
          const lng = position.coords.longitude;
          latInput.value = lat;
          lngInput.value = lng;
          geoStatus.textContent = `Lat: ${lat.toFixed(4)}, Lng: ${lng.toFixed(4)}`;
          geoStatus.style.color = "var(--color-primary)";
        },
        () => {
          // Fallback to mock Nagercoil coordinates if user denies permission
          latInput.value = 8.1833;
          lngInput.value = 77.4119;
          geoStatus.textContent = "Nagercoil (Default)";
          geoStatus.style.color = "var(--color-secondary)";
        }
      );
    });

    // Form Submission
    issueForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const lang = localStorage.getItem("lang") || "ta";

      if (!latInput.value || !lngInput.value) {
        alert(lang === "ta" ? "தயவுசெய்து இருப்பிடத்தைப் பெறவும்." : "Please click 'Get Location' first.");
        return;
      }

      const formData = new FormData(issueForm);
      // Backend expects organization_id in request body or headers.
      // The issue router handles anonymous/auth creation scoping.
      
      try {
        const response = await fetch(`${API_BASE}/issues`, {
          method: "POST",
          headers: {
            "X-Organization-ID": DEFAULT_ORG_ID
          },
          body: formData
        });

        if (!response.ok) throw new Error("Submission failed");
        
        alert(lang === "ta" ? "புகார் வெற்றிகரமாகப் பதிவு செய்யப்பட்டது!" : "Issue submitted successfully!");
        issueForm.reset();
        geoStatus.textContent = lang === "ta" ? "இருப்பிடம் பெறப்படவில்லை" : "Location not captured";
        latInput.value = "";
        lngInput.value = "";
        loadRecentIssues();
      } catch (err) {
        alert(lang === "ta" ? "புகாரைப் பதிவு செய்வதில் தோல்வி." : "Failed to submit issue.");
      }
    });

    // Load recent issues from API
    async function loadRecentIssues() {
      try {
        const res = await fetch(`${API_BASE}/issues`, {
          headers: {
            "X-Organization-ID": DEFAULT_ORG_ID
          }
        });
        if (!res.ok) throw new Error();
        const data = await res.json();
        renderRecentIssues(data.slice(0, 5)); // Show last 5
      } catch (err) {
        recentList.innerHTML = `<p style="font-size:0.8rem; color:var(--color-secondary); text-align:center;">Failed to load issues.</p>`;
      }
    }

    function renderRecentIssues(issues) {
      const lang = localStorage.getItem("lang") || "ta";
      if (issues.length === 0) {
        recentList.innerHTML = `<p style="font-size:0.85rem; text-align:center; color:var(--color-text-muted);">புகார்கள் ஏதும் இல்லை. / No issues logged.</p>`;
        return;
      }

      recentList.innerHTML = "";
      issues.forEach(issue => {
        const desc = lang === "ta" ? issue.description_ta : issue.description_en;
        const card = document.createElement("div");
        card.className = "recent-issue-card";
        card.innerHTML = `
          <div class="issue-meta">
            <span>${issue.category}</span>
            <span class="status-badge status-${issue.status.toLowerCase()}">${issue.status}</span>
          </div>
          <p style="color:var(--color-text-dark);">${desc}</p>
          <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.25rem;">
            ${new Date(issue.created_at).toLocaleDateString()}
          </p>
        `;
        recentList.appendChild(card);
      });
    }

    // Load on start
    loadRecentIssues();

    // Bilingual Listener
    window.addEventListener('lang-change', (e) => {
      const lang = e.detail;
      const translations = {
        ta: {
          'page-title': 'பொது பிரச்சனைகள் புகாரளிப்பு',
          'page-subtitle': 'பிரச்சனைகளை பதிவு செய்யவும், நாம் ஒன்றாக தீர்ப்போம். / Report community infrastructure or safety issues.',
          'form-header': 'புகார் படிவம்',
          'lbl-category': 'பிரச்சனை வகை',
          'lbl-desc-ta': 'விளக்கம் (தமிழ்)',
          'lbl-desc-en': 'Description (English)',
          'lbl-geo': 'இருப்பிடம்',
          'lbl-photo': 'புகைப்படம் பதிவேற்றவும்',
          'btn-submit': 'புகாரை பதிவு செய்க',
          'btn-locate': '📍 இருப்பிடத்தை பெருக',
          'lbl-workflow': 'தீர்வு முறைமை',
          'lbl-recent-issues': 'சமீபத்திய புகார்கள்'
        },
        en: {
          'page-title': 'Public Issue Reporting',
          'page-subtitle': 'Report road, water, or safety issues to local volunteers.',
          'form-header': 'Register Issue Form',
          'lbl-category': 'Select Category Type',
          'lbl-desc-ta': 'Description (Tamil)',
          'lbl-desc-en': 'Description (English)',
          'lbl-geo': 'Geolocation Capture',
          'lbl-photo': 'Attach Photo File',
          'btn-submit': 'Submit Issue',
          'btn-locate': '📍 Capture Geolocation',
          'lbl-workflow': 'Triage Workflow',
          'lbl-recent-issues': 'Recent Issues Feed'
        }
      };

      const trans = translations[lang];
      for (const [id, val] of Object.entries(trans)) {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
      }
      
      // Update locate btn text inside DOM
      btnLocate.textContent = lang === 'ta' ? '📍 இருப்பிடத்தை பெருக' : '📍 Capture Geolocation';

      // Redraw list to switch description
      loadRecentIssues();
    });
  </script>
</Layout>
