---
import Layout from '../layouts/Layout.astro';
---

<Layout title="இரத்த தானம் / Blood Donors">
  <div class="donor-container">
    <div class="card header-card">
      <span class="red-heart">❤️</span>
      <div>
        <h1 id="page-title">இரத்த தானம்</h1>
        <p id="page-subtitle">உங்கள் சிறிய உதவி ஒரு உயிரைக் காப்பாற்றலாம் / A small help can save a life.</p>
      </div>
    </div>

    <!-- Blood Group Selectors -->
    <div class="selector-container">
      <h3 id="select-label">குருதி குழுவை தேர்வு செய்யவும் / Select Blood Group</h3>
      <div class="blood-grid" id="blood-groups-container">
        {['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-'].map((group) => (
          <button class="blood-btn" data-group={group}>{group}</button>
        ))}
      </div>
    </div>

    <!-- Results Area -->
    <div class="results-container">
      <div class="results-header">
        <h2 id="results-title">கொடையாளர் பட்டியல் / Donor Directory</h2>
        <span class="results-count" id="results-count-text">0 கொடையாளர்கள் கண்டறியப்பட்டனர்</span>
      </div>
      
      <div id="donors-list" class="grid-3" style="margin-top: 1.5rem;">
        <div class="no-selection-state" id="empty-state">
          <p id="empty-text">தேடலைத் தொடங்க இரத்தக் குழுவைத் தேர்ந்தெடுக்கவும்.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact Modal -->
  <div class="modal" id="contact-modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">தொடர்பு விவரங்கள்</h3>
        <button class="close-btn" id="modal-close">&times;</button>
      </div>
      <div class="modal-body" id="modal-body-content">
        <!-- Will be filled dynamically -->
      </div>
    </div>
  </div>

  <style>
    .donor-container {
      max-width: 900px;
      margin: 0 auto;
    }

    .header-card {
      display: flex;
      gap: 1.5rem;
      align-items: center;
      background: linear-gradient(135deg, #991b1b, #b91c1c);
      color: #ffffff;
      margin-bottom: 2rem;
      padding: 2rem;
    }

    .header-card h1 {
      font-size: 2.25rem;
      font-family: 'Outfit', sans-serif;
    }

    .red-heart {
      font-size: 3.5rem;
      animation: beat 1s infinite alternate;
    }

    @keyframes beat {
      to { transform: scale(1.1); }
    }

    .selector-container {
      background-color: #ffffff;
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      border: 1px solid #e5e7eb;
      margin-bottom: 2rem;
    }

    .blood-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .blood-btn {
      background-color: var(--color-bg-light);
      border: 1px solid #d1d5db;
      border-radius: var(--radius-md);
      padding: 1rem;
      font-size: 1.25rem;
      font-weight: 700;
      cursor: pointer;
      color: var(--color-text-dark);
      transition: all 0.2s;
    }

    .blood-btn:hover, .blood-btn.active {
      background-color: var(--color-secondary);
      color: #ffffff;
      border-color: var(--color-secondary);
      box-shadow: 0 4px 6px rgba(153, 27, 27, 0.2);
    }

    .results-container {
      margin-bottom: 3rem;
    }

    .results-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 2px solid #e5e7eb;
      padding-bottom: 0.75rem;
    }

    .results-count {
      font-size: 0.9rem;
      color: var(--color-text-muted);
      font-weight: 600;
    }

    .no-selection-state {
      grid-column: 1 / -1;
      text-align: center;
      padding: 3rem;
      background-color: #ffffff;
      border-radius: var(--radius-lg);
      border: 1px dashed #d1d5db;
      color: var(--color-text-muted);
    }

    /* Donor Cards */
    .donor-card {
      background-color: #ffffff;
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      border: 1px solid #e5e7eb;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 1rem;
      box-shadow: var(--shadow-sm);
    }

    .donor-info {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .donor-name {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--color-text-dark);
    }

    .donor-group-badge {
      background-color: #fef2f2;
      color: var(--color-secondary);
      border: 1px solid #fecaca;
      padding: 0.25rem 0.5rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.9rem;
    }

    .donor-meta {
      font-size: 0.85rem;
      color: var(--color-text-muted);
    }

    .donor-action-btn {
      width: 100%;
      background-color: var(--color-primary);
      color: #ffffff;
      text-align: center;
      padding: 0.65rem;
      border-radius: var(--radius-md);
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: background-color 0.2s;
    }

    .donor-action-btn:hover {
      background-color: var(--color-primary-light);
    }

    /* Modal Layouts */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0,0,0,0.5);
      z-index: 1000;
      justify-content: center;
      align-items: center;
    }

    .modal.open {
      display: flex;
    }

    .modal-content {
      background-color: #ffffff;
      border-radius: var(--radius-lg);
      max-width: 450px;
      width: 90%;
      padding: 2rem;
      box-shadow: var(--shadow-md);
      animation: slideDown 0.3s ease;
    }

    @keyframes slideDown {
      from { transform: translateY(-20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #e5e7eb;
      padding-bottom: 0.75rem;
      margin-bottom: 1.25rem;
    }

    .close-btn {
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--color-text-muted);
    }

    .modal-body {
      font-size: 0.95rem;
    }

    .login-form-container {
      margin-top: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .input-field {
      width: 100%;
      padding: 0.65rem;
      border: 1px solid #d1d5db;
      border-radius: var(--radius-md);
    }
  </style>

  <script is:inline>
    // Constants
    const API_BASE = "http://127.0.0.1:8000/api/v1";
    const DEFAULT_ORG_ID = "8f8b80b7-4b71-4770-b183-5c5f49e49a1d"; // Seeded Organization

    // State Variables
    let selectedGroup = "";
    let donorsData = [];

    // DOM Elements
    const groupsContainer = document.getElementById("blood-groups-container");
    const donorsList = document.getElementById("donors-list");
    const countText = document.getElementById("results-count-text");
    const emptyState = document.getElementById("empty-state");
    const contactModal = document.getElementById("contact-modal");
    const modalClose = document.getElementById("modal-close");
    const modalBody = document.getElementById("modal-body-content");

    // Event Listeners
    groupsContainer.addEventListener("click", (e) => {
      if (e.target.classList.contains("blood-btn")) {
        // Toggle Active
        document.querySelectorAll(".blood-btn").forEach(b => b.classList.remove("active"));
        e.target.classList.add("active");

        selectedGroup = e.target.getAttribute("data-group");
        searchDonors(selectedGroup);
      }
    });

    modalClose.addEventListener("click", () => {
      contactModal.classList.remove("open");
    });

    // API calls
    async function searchDonors(group) {
      try {
        donorsList.innerHTML = `<div class="no-selection-state">தேடுகிறது / Searching...</div>`;
        
        // Pass organization header or query parameter if available
        const response = await fetch(`${API_BASE}/blood-donors?blood_group=${encodeURIComponent(group)}`, {
          headers: {
            "X-Organization-ID": DEFAULT_ORG_ID
          }
        });
        
        if (!response.ok) throw new Error("Search failed");
        
        donorsData = await response.json();
        renderDonors(donorsData);
      } catch (err) {
        donorsList.innerHTML = `<div class="no-selection-state" style="color: var(--color-secondary);">தேடல் தோல்வியுற்றது. பிணையத்தை சரிபார்க்கவும் / Search failed. Please check backend network connection.</div>`;
      }
    }

    function renderDonors(donors) {
      const lang = localStorage.getItem("lang") || "ta";
      countText.textContent = lang === "ta" 
        ? `${donors.length} கொடையாளர்கள் கண்டறியப்பட்டனர்` 
        : `${donors.length} Donors Found`;

      if (donors.length === 0) {
        donorsList.innerHTML = `
          <div class="no-selection-state">
            ${lang === 'ta' ? 'இந்த இரத்த பிரிவில் கொடையாளர்கள் இல்லை.' : 'No donors found in this blood group.'}
          </div>
        `;
        return;
      }

      donorsList.innerHTML = "";
      donors.forEach(donor => {
        const name = lang === "ta" ? (donor.full_name_ta || donor.full_name_en) : (donor.full_name_en || donor.full_name_ta);
        const card = document.createElement("div");
        card.className = "donor-card";
        card.innerHTML = `
          <div class="donor-info">
            <span class="donor-name">${name}</span>
            <span class="donor-group-badge">${donor.blood_group}</span>
          </div>
          <div class="donor-meta">
            <span>📍 Nagercoil</span> • <span>${donor.is_available ? '✔️ Available' : '❌ Unavailable'}</span>
          </div>
          <button class="donor-action-btn" data-id="${donor.id}">
            ${lang === 'ta' ? 'தொடர்பு கொள்ள' : 'Request Contact'}
          </button>
        `;
        donorsList.appendChild(card);
      });

      // Hook up request action
      document.querySelectorAll(".donor-action-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          const donorId = btn.getAttribute("data-id");
          handleRequestContact(donorId);
        });
      });
    }

    async function handleRequestContact(donorId) {
      const token = localStorage.getItem("access_token");
      const lang = localStorage.getItem("lang") || "ta";

      if (!token) {
        // User not logged in, show Login Modal
        showLoginModal(donorId);
        return;
      }

      try {
        const response = await fetch(`${API_BASE}/blood-donors/${donorId}/request-contact`, {
          method: "POST",
          headers: {
            "Authorization": `Bearer ${token}`,
            "X-Organization-ID": DEFAULT_ORG_ID
          }
        });

        if (response.status === 401 || response.status === 403) {
          // Token expired or invalid
          localStorage.removeItem("access_token");
          showLoginModal(donorId);
          return;
        }

        if (!response.ok) throw new Error("Contact request failed");

        const data = await response.json();
        showContactDetails(data);
      } catch (err) {
        alert(lang === "ta" ? "தொடர்பு விவரங்களைப் பெறுவதில் தோல்வி." : "Failed to retrieve contact details.");
      }
    }

    function showContactDetails(data) {
      const lang = localStorage.getItem("lang") || "ta";
      modalBody.innerHTML = `
        <div style="text-align: center; display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
          <p style="color: var(--color-primary); font-weight: 600;">✔️ ${lang === 'ta' ? 'தொடர்பு விவரம் பெறப்பட்டது (ஆடிட் செய்யப்பட்டுள்ளது)' : 'Contact details retrieved (Access logged)'}</p>
          <div style="font-size: 1.5rem; font-weight: 700; background-color: var(--color-bg-light); padding: 1rem; border-radius: var(--radius-md);">
            📱 ${data.phone_number}
          </div>
          <a href="${data.whatsapp_link}" target="_blank" class="btn btn-primary" style="background-color: #25d366; display: flex; gap: 0.5rem; align-items: center; justify-content: center;">
            💬 WhatsApp Chat
          </a>
        </div>
      `;
      contactModal.classList.add("open");
    }

    function showLoginModal(donorId) {
      const lang = localStorage.getItem("lang") || "ta";
      modalBody.innerHTML = `
        <p style="color: var(--color-text-muted); margin-bottom: 1rem;">
          ${lang === 'ta' 
            ? 'தொடர்பு கொள்ள உள்நுழையவும் (அதிவேக மொபைல் OTP சோதனை). கொடையாளர் தனியுரிமைக்காக ஒவ்வொரு அணுகலும் ஆடிட் செய்யப்படுகிறது.' 
            : 'Please log in to request contact details. Access is logged for privacy.'}
        </p>
        <div class="login-form-container">
          <input type="text" id="login-phone" placeholder="+919876543210" class="input-field" value="+919876543210" />
          <button id="login-btn-submit" class="btn btn-primary">${lang === 'ta' ? 'OTP அனுப்புக' : 'Request OTP'}</button>
          
          <div id="otp-entry-section" style="display: none; flex-direction: column; gap: 0.75rem; margin-top: 0.5rem;">
            <input type="text" id="login-otp" placeholder="123456" class="input-field" />
            <button id="login-btn-verify" class="btn btn-secondary">${lang === 'ta' ? 'உள்நுழைக / சரிபார்க்கவும்' : 'Verify & Login'}</button>
          </div>
        </div>
      `;
      contactModal.classList.add("open");

      // Handle Mock OTP authentication
      const btnSubmit = document.getElementById("login-btn-submit");
      const btnVerify = document.getElementById("login-btn-verify");
      const otpSection = document.getElementById("otp-entry-section");
      const phoneInput = document.getElementById("login-phone");
      const otpInput = document.getElementById("login-otp");

      let verificationId = "";

      btnSubmit.addEventListener("click", async () => {
        try {
          const res = await fetch(`${API_BASE}/auth/otp/send`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              organization_id: DEFAULT_ORG_ID,
              phone_number: phoneInput.value
            })
          });
          const data = await res.json();
          if (res.ok) {
            verificationId = data.verification_id;
            otpSection.style.display = "flex";
            btnSubmit.style.display = "none";
          } else {
            alert(data.detail || "Failed to send OTP");
          }
        } catch (err) {
          alert("Error sending OTP");
        }
      });

      btnVerify.addEventListener("click", async () => {
        try {
          const res = await fetch(`${API_BASE}/auth/otp/verify`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              verification_id: verificationId,
              otp_code: otpInput.value
            })
          });
          const data = await res.json();
          if (res.ok) {
            localStorage.setItem("access_token", data.access_token);
            contactModal.classList.remove("open");
            // Retry contact retrieval now
            handleRequestContact(donorId);
          } else {
            alert(data.detail || "Invalid OTP code");
          }
        } catch (err) {
          alert("Error verifying OTP");
        }
      });
    }

    // Translate statically
    window.addEventListener('lang-change', (e) => {
      const lang = e.detail;
      const translations = {
        ta: {
          'page-title': 'இரத்த தானம்',
          'page-subtitle': 'உங்கள் சிறிய உதவி ஒரு உயிரைக் காப்பாற்றலாம் / A small help can save a life.',
          'select-label': 'குருதி குழுவை தேர்வு செய்யவும் / Select Blood Group',
          'results-title': 'கொடையாளர் பட்டியல் / Donor Directory',
          'empty-text': 'தேடலைத் தொடங்க இரத்தக் குழுவைத் தேர்ந்தெடுக்கவும்.'
        },
        en: {
          'page-title': 'Blood Donation Registry',
          'page-subtitle': 'Find verified donors near your geographic area.',
          'select-label': 'Select Blood Group Type',
          'results-title': 'Verified Donors List',
          'empty-text': 'Please select a blood group above to query the directory.'
        }
      };

      const trans = translations[lang];
      for (const [id, val] of Object.entries(trans)) {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
      }
      
      // Re-trigger search or redraw if group selected
      if (selectedGroup) searchDonors(selectedGroup);
    });
  </script>
</Layout>
