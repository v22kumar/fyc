---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const res = await fetch('http://127.0.0.1:8000/api/v1/sports/tournaments', {
  headers: { 'X-Organization-ID': '8f8b80b7-4b71-4770-b183-5c5f49e49a1d' }
}).catch(() => null);

let tournaments = [];
if (res && res.ok) tournaments = await res.json();
---

<Layout title="FYC Sports | Tournaments">
  <Header />
  
  <main class="events-page">
    <div class="hero">
      <h1>Sports & Tournaments</h1>
      <p>Register your teams and compete in FYC leagues!</p>
    </div>

    <section class="events-grid">
      {tournaments.length === 0 ? (
        <p class="no-events">No active tournaments right now. Check back later.</p>
      ) : (
        tournaments.map(t => (
          <div class="event-card" style="display:block; padding:1.5rem;">
            <div style="display:flex; justify-content:space-between; margin-bottom:1rem;">
                <span class="badge">{t.sport.toUpperCase()}</span>
                <span class="status">{t.status}</span>
            </div>
            <h2 style="margin-bottom:0.5rem; font-size:1.3rem;">{t.name_en}</h2>
            <p style="color:#6b7280; font-size:0.9rem; margin-bottom:1.5rem;">{t.name_ta} - {t.year} @ {t.venue}</p>
            <a href={`/sports/${t.id}`} class="btn">View & Register Team</a>
          </div>
        ))
      )}
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .events-page { min-height: 70vh; padding-bottom: 4rem; background:#f9fafb;}
  .hero { background: linear-gradient(135deg, #0f5132, #14532d); color: white; text-align: center; padding: 4rem 1rem; margin-bottom: 3rem; }
  .hero h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .events-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; padding: 0 1rem; }
  .event-card { background: white; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: transform 0.2s; }
  .event-card:hover { transform: translateY(-5px); box-shadow: 0 10px 15px rgba(0,0,0,0.1); }
  .badge { background: #e0f2fe; color: #0369a1; padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.8rem; font-weight: bold; }
  .status { font-size: 0.8rem; font-weight: bold; color: #166534; }
  .btn { display: inline-block; background: #064e3b; color: white; padding: 0.6rem 1rem; border-radius: 6px; text-decoration: none; font-size: 0.95rem; font-weight: 500; text-align:center; width:100%; box-sizing:border-box;}
  .btn:hover { background: #0f5132; }
  .no-events { text-align: center; color: #6b7280; grid-column: 1 / -1; padding: 3rem; }
</style>
