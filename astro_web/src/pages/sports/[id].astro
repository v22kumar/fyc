---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const { id } = Astro.params;

const [tRes, fixRes] = await Promise.all([
  fetch(`http://127.0.0.1:8000/api/v1/sports/tournaments/${id}`, { headers: { 'X-Organization-ID': '8f8b80b7-4b71-4770-b183-5c5f49e49a1d' } }).catch(()=>null),
  fetch(`http://127.0.0.1:8000/api/v1/sports/tournaments/${id}/fixtures`, { headers: { 'X-Organization-ID': '8f8b80b7-4b71-4770-b183-5c5f49e49a1d' } }).catch(()=>null)
]);

if (!tRes || !tRes.ok) return Astro.redirect('/sports');

const tournament = await tRes.json();
const fixtures = (fixRes && fixRes.ok) ? await fixRes.json() : [];
---

<Layout title={`${tournament.name_en} | FYC Sports`}>
  <Header />
  
  <main class="page-bg">
    <div class="header-banner">
      <div class="container">
        <a href="/sports" class="back-link">← Back to Sports</a>
        <h1>{tournament.name_en}</h1>
        <p class="ta-title">{tournament.name_ta}</p>
        <div class="meta">
            <span>🏟️ {tournament.venue}</span>
            <span>🏆 {tournament.sport.toUpperCase()} - {tournament.year}</span>
        </div>
      </div>
    </div>

    <div class="container content-split">
      <div class="details">
        <h3>Match Fixtures</h3>
        {fixtures.length === 0 ? (
            <div class="alert warning">Fixtures have not been generated yet. Register your team below to participate!</div>
        ) : (
            <div class="fixtures-list">
                {fixtures.map((f: any) => (
                    <div class="fixture-card">
                        <div class="f-head">Match #{f.match_number} | {f.status}</div>
                        <div class="f-teams">
                            <span class="team">{f.team_a_name}</span>
                            <span class="vs">VS</span>
                            <span class="team">{f.team_b_name}</span>
                        </div>
                        {f.status === 'COMPLETED' && (
                            <div class="f-score">Score: {f.team_a_score} - {f.team_b_score}</div>
                        )}
                    </div>
                ))}
            </div>
        )}
      </div>

      <div class="form-container">
        <h3>Register Your Team</h3>
        <form id="teamForm" class="reg-form">
          <input type="hidden" id="tourneyId" value={tournament.id} />
          
          <div class="form-group">
            <label>Team Name *</label>
            <input type="text" id="tname" required />
          </div>
          
          <div class="form-group">
            <label>Captain Name *</label>
            <input type="text" id="cname" required />
          </div>

          <div class="form-group">
            <label>Contact Number *</label>
            <input type="tel" id="mobile" required pattern="[0-9]{10}" />
          </div>

          <button type="submit" class="submit-btn" disabled={tournament.status !== 'UPCOMING'}>
            {tournament.status === 'UPCOMING' ? 'Submit Team Registration' : 'Registration Closed'}
          </button>
          <div id="msg" class="msg"></div>
        </form>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
    const form = document.getElementById('teamForm');
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const tId = (document.getElementById('tourneyId') as HTMLInputElement).value;
        const msgEl = document.getElementById('msg');
        const btn = form.querySelector('.submit-btn') as HTMLButtonElement;
        
        const payload = {
            name: (document.getElementById('tname') as HTMLInputElement).value,
            captain_name: (document.getElementById('cname') as HTMLInputElement).value,
            contact_number: (document.getElementById('mobile') as HTMLInputElement).value
        };

        btn.disabled = true;
        btn.innerText = "Registering...";

        try {
            // NOTE: Team registration requires auth in backend. To bypass for public, 
            // you might need to adjust the backend OR pass a dummy token.
            // For this demo, we assume the user is logged in or the endpoint allows public via tenant.
            // Wait, the backend requires get_current_user for team registration.
            // Let's pass a mock token or let it fail gracefully for the demo if not logged in.
            
            const token = localStorage.getItem('token') || ''; 

            const res = await fetch(`http://127.0.0.1:8000/api/v1/sports/tournaments/${tId}/teams`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`,
                    'X-Organization-ID': '8f8b80b7-4b71-4770-b183-5c5f49e49a1d'
                },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (res.ok) {
                if (msgEl) {
                    msgEl.className = 'msg success';
                    msgEl.textContent = 'Team Registered successfully!';
                }
                (form as HTMLFormElement).reset();
            } else {
                if (msgEl) {
                    msgEl.className = 'msg error';
                    msgEl.textContent = data.detail || 'Failed to register. Please log in.';
                }
            }
        } catch (err) {
            if (msgEl) {
                msgEl.className = 'msg error';
                msgEl.textContent = 'Network error. Please try again.';
            }
        } finally {
            btn.disabled = false;
            btn.innerText = "Submit Team Registration";
        }
    });
</script>

<style>
  .page-bg { background: #f9fafb; min-height: 100vh; padding-bottom: 4rem; }
  .header-banner { background: #0f5132; color: white; padding: 3rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .back-link { color: #a7f3d0; text-decoration: none; margin-bottom: 1rem; display: inline-block; font-size: 0.9rem; }
  .header-banner h1 { font-size: 2.2rem; margin: 0.5rem 0; }
  .ta-title { color: #d1fae5; font-size: 1.1rem; margin-bottom: 1.5rem; }
  .meta { display: flex; gap: 1.5rem; font-size: 0.95rem; color: #a7f3d0; }
  
  .content-split { display: grid; grid-template-columns: 1fr 400px; gap: 3rem; margin-top: 3rem; }
  @media (max-width: 800px) { .content-split { grid-template-columns: 1fr; } }
  
  .details h3 { font-size: 1.5rem; margin-bottom: 1.5rem; color: #111827; }
  .alert { padding: 1rem; border-radius: 8px; font-size: 0.95rem; }
  .alert.warning { background: #fffbeb; color: #b45309; border: 1px solid #fde68a; }
  
  .fixtures-list { display: flex; flex-direction: column; gap: 1rem; }
  .fixture-card { background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 1.25rem; }
  .f-head { font-size: 0.85rem; color: #6b7280; margin-bottom: 0.75rem; text-transform: uppercase; font-weight: 600; }
  .f-teams { display: flex; align-items: center; justify-content: space-between; font-weight: bold; font-size: 1.1rem; }
  .team { flex: 1; text-align: center; }
  .vs { color: #9ca3af; font-size: 0.9rem; padding: 0 1rem; }
  .f-score { margin-top: 1rem; text-align: center; color: #064e3b; font-weight: bold; background: #ecfdf5; padding: 0.5rem; border-radius: 4px; }
  
  .form-container { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); align-self: start; }
  .form-container h3 { margin-top: 0; margin-bottom: 1.5rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 1rem; }
  .reg-form { display: flex; flexDirection: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-weight: 500; font-size: 0.9rem; color: #374151; }
  input[type="text"], input[type="tel"] {
      padding: 0.7rem; border: 1px solid #d1d5db; border-radius: 6px; font-family: inherit; width: 100%; box-sizing: border-box;
  }
  
  .submit-btn { background: #064e3b; color: white; border: none; padding: 0.8rem; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 1rem; width: 100%; margin-top: 0.5rem; }
  .submit-btn:hover:not(:disabled) { background: #0f5132; }
  .submit-btn:disabled { background: #9ca3af; cursor: not-allowed; }
  
  .msg { margin-top: 1rem; padding: 0.8rem; border-radius: 6px; font-size: 0.9rem; text-align: center; display: none; }
  .msg.success { display: block; background: #d1fae5; color: #065f46; }
  .msg.error { display: block; background: #fee2e2; color: #991b1b; }
</style>
