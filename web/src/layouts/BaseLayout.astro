---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'FYC Connect - Community Service Platform by Friends Youth Club, Nagercoil' } = Astro.props;
const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? '';
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'https://fyc-backend.fly.dev';
const DEFAULT_ORG_ID = import.meta.env.PUBLIC_DEFAULT_ORG_ID ?? '8f8b80b7-4b71-4770-b183-5c5f49e49a1d';
---

<!doctype html>
<html lang="ta" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#064e3b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..900;1,14..32,300..900&family=Noto+Sans+Tamil:wght@400;500;600;700;800;900&family=Noto+Sans+Malayalam:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title} | FYC Connect</title>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased" style="font-family:'Inter',sans-serif">

    <!-- CRITICAL INLINE: runs before paint — sets auth class + lang on <html> -->
    <script is:inline>
      (function () {
        try {
          var isAuth = !!localStorage.getItem('fyc_token');
          document.documentElement.classList.add(isAuth ? 'is-auth' : 'is-guest');
          var lang = localStorage.getItem('fyc_lang') || 'ta';
          document.documentElement.setAttribute('data-lang', lang);
        } catch (_) {
          document.documentElement.classList.add('is-guest');
        }
      })();
    </script>

    <Header />
    <main><slot /></main>
    <Footer />

    <!-- Google One Tap SDK -->
    {GOOGLE_CLIENT_ID && <script src="https://accounts.google.com/gsi/client" async></script>}

    <!-- Google One Tap: auto-prompts for guests not on login page -->
    <script define:vars={{ GOOGLE_CLIENT_ID, API_BASE, DEFAULT_ORG_ID }}>
      if (GOOGLE_CLIENT_ID && !localStorage.getItem('fyc_token') && !window.location.pathname.startsWith('/login')) {
        window.addEventListener('load', function () {
          if (typeof google === 'undefined') return;
          google.accounts.id.initialize({
            client_id: GOOGLE_CLIENT_ID,
            auto_select: true,
            cancel_on_tap_outside: true,
            context: 'signin',
            callback: async function (resp) {
              try {
                var res = await fetch(API_BASE + '/api/v1/auth/google', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ organization_id: DEFAULT_ORG_ID, id_token: resp.credential }),
                });
                var data = await res.json();
                if (res.ok) {
                  localStorage.setItem('fyc_token', data.access_token);
                  localStorage.setItem('fyc_user', JSON.stringify(data.user || {}));
                  window.location.reload();
                }
              } catch (_) {}
            },
          });
          google.accounts.id.prompt();
        });
      }
    </script>

    <!-- i18n engine: 4 languages (ta/en/ml/hi) -->
    <script>
      const LANG_META = {
        ta: { label: 'தமிழ்',   flag: 'TA' },
        en: { label: 'English',  flag: 'EN' },
        ml: { label: 'മലയാളം', flag: 'ML' },
        hi: { label: 'हिन्दी',   flag: 'HI' },
      } as const;
      type Lang = keyof typeof LANG_META;
      const LANG_ORDER: Lang[] = ['ta', 'en', 'ml', 'hi'];

      function getLang(): Lang { return (localStorage.getItem('fyc_lang') as Lang) || 'ta'; }

      function applyLang(lang: Lang) {
        document.documentElement.setAttribute('data-lang', lang);
        document.querySelectorAll<HTMLElement>('[data-ta]').forEach((el) => {
          const val = (el.dataset as any)[lang] || el.dataset.en || el.dataset.ta || '';
          if (val) el.textContent = val;
        });
        document.querySelectorAll<HTMLInputElement>('[data-placeholder-ta]').forEach((el) => {
          const key = 'placeholder' + lang.charAt(0).toUpperCase() + lang.slice(1);
          el.placeholder = (el.dataset as any)[key] || el.dataset.placeholderEn || el.dataset.placeholderTa || '';
        });
        const meta = LANG_META[lang];
        document.querySelectorAll('.lang-flag').forEach(el => { el.textContent = meta.flag; });
        document.querySelectorAll('.lang-label').forEach(el => { el.textContent = meta.label; });
        // Highlight the active language option
        document.querySelectorAll<HTMLElement>('.lang-opt').forEach((el) => {
          const active = el.dataset.langCode === lang;
          el.classList.toggle('bg-[#0F5132]/10', active);
          el.classList.toggle('font-black', active);
        });
      }

      function closeAllLangDropdowns() {
        document.querySelectorAll('.lang-dropdown-menu').forEach(d => d.classList.add('hidden'));
      }

      (window as any).setLang = function (lang: Lang) {
        localStorage.setItem('fyc_lang', lang);
        applyLang(lang);
        closeAllLangDropdowns();
      };

      (window as any).toggleLangPicker = function (id: string) {
        const target = document.getElementById(id || 'lang-dropdown-desktop');
        const wasHidden = target?.classList.contains('hidden');
        closeAllLangDropdowns();
        // Also close any open user dropdowns
        document.querySelectorAll('.user-dropdown-menu').forEach(d => d.classList.add('hidden'));
        if (wasHidden) target?.classList.remove('hidden');
      };

      // Close dropdowns on outside click
      document.addEventListener('click', (e) => {
        const t = e.target as Element;
        if (!t.closest('.lang-picker-wrap')) closeAllLangDropdowns();
      });

      applyLang(getLang());
    </script>

    <!-- Header weather + gold price -->
    <script>
      (function () {
        const API = 'https://fyc-backend.fly.dev';
        const wEl = document.getElementById('hdr-weather');
        const gEl = document.getElementById('hdr-gold');
        const fmt = (n: number | null) => {
          if (n == null) return '—';
          const s = Math.round(n).toString();
          if (s.length <= 3) return '₹' + s;
          const last3 = s.slice(-3);
          const rest = s.slice(0, -3);
          let out = '';
          for (let i = 0; i < rest.length; i++) {
            if (i && (rest.length - i) % 2 === 0) out += ',';
            out += rest[i];
          }
          return '₹' + out + ',' + last3;
        };
        fetch(API + '/api/v1/utilities/gold-price').then(r => r.json()).then(g => {
          if (gEl && g.price_per_gram_22k != null) gEl.textContent = '🪙 22K ' + fmt(g.price_per_gram_22k) + '/g';
        }).catch(() => {});
        const fw = (lat: number, lon: number) => {
          fetch(API + '/api/v1/utilities/weather?lat=' + lat + '&lon=' + lon).then(r => r.json()).then(w => {
            if (w.temp == null) return;
            if (wEl) wEl.textContent = '🌤 ' + Math.round(w.temp) + '°C · ' + (w.city || 'Nagercoil');
          }).catch(() => {});
        };
        navigator.geolocation
          ? navigator.geolocation.getCurrentPosition(p => fw(p.coords.latitude, p.coords.longitude), () => fw(8.1833, 77.4119), { timeout: 8000, maximumAge: 300000 })
          : fw(8.1833, 77.4119);
      })();
    </script>

    <!-- Header auth state -->
    <script>
      (function () {
        const token = localStorage.getItem('fyc_token');
        const userStr = localStorage.getItem('fyc_user');
        if (token && userStr) {
          try {
            const user = JSON.parse(userStr);
            const initial = (user.full_name_en || user.email || 'U')[0].toUpperCase();
            const displayName = user.full_name_en || user.email || 'FYC User';
            ['hdr-login-btn', 'hdr-login-btn-mobile'].forEach(id => document.getElementById(id)?.classList.add('hidden'));
            ['hdr-user-menu', 'hdr-user-menu-mobile'].forEach(id => document.getElementById(id)?.classList.remove('hidden'));
            ['hdr-user-avatar', 'hdr-user-avatar-mobile'].forEach(id => { const el = document.getElementById(id); if (el) el.textContent = initial; });
            ['hdr-user-name', 'hdr-user-name-mobile'].forEach(id => { const el = document.getElementById(id); if (el) el.textContent = displayName; });
          } catch (_) {}
        }
        function closeAllUserDropdowns() {
          document.querySelectorAll('.user-dropdown-menu').forEach(d => d.classList.add('hidden'));
        }
        (window as any).toggleUserMenu = function (id: string) {
          const target = document.getElementById(id || 'hdr-user-dropdown');
          const wasHidden = target?.classList.contains('hidden');
          closeAllUserDropdowns();
          if (wasHidden) target?.classList.remove('hidden');
        };
        (window as any).signOut = () => {
          localStorage.removeItem('fyc_token');
          localStorage.removeItem('fyc_user');
          window.location.href = '/';
        };
        // Close user dropdowns on outside click (avatar buttons live inside their wrappers)
        document.addEventListener('click', (e) => {
          const t = e.target as Element;
          if (!t.closest('#hdr-user-menu') && !t.closest('#hdr-user-menu-mobile')) {
            closeAllUserDropdowns();
          }
        });
      })();
    </script>

    <!-- Protected link interceptor for guests -->
    <script>
      (function () {
        const PROTECTED = ['/blood-donors', '/events', '/sports', '/submit-issue', '/directory', '/verify', '/green', '/opportunities', '/complete-profile', '/admin', '/users'];
        if (localStorage.getItem('fyc_token')) return;
        document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) => {
          const href = a.getAttribute('href') || '';
          if (PROTECTED.some(p => href === p || href.startsWith(p + '/'))) {
            a.addEventListener('click', (e) => {
              e.preventDefault();
              window.location.href = '/login?next=' + encodeURIComponent(href);
            });
          }
        });
      })();
    </script>
  </body>
</html>
