---
// web/src/components/AiNewsSummary.astro
export interface Props {
  summary?: string;
  trendingTopics?: string[];
}

const { 
  summary = "Check out the detailed news categories below for the latest updates.",
  trendingTopics = []
} = Astro.props;
---

<div class="mb-8 rounded-2xl overflow-hidden shadow-md border border-gray-100 bg-white p-6">
  <div class="flex flex-col items-start gap-4">
    
    <div class="flex items-center gap-3">
      <div class="bg-blue-50 p-2 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9.06 11.9 8.07-8.06a2.85 2.85 0 1 1 4.03 4.03l-8.06 8.08"></path>
          <path d="M7.07 14.94c-1.66 0-3 1.35-3 3.02 0 1.33-2.5 1.52-2 2.02 1.08 1.1 2.49 2.02 4 2.02 2.2 0 4-1.8 4-4.04a3.01 3.01 0 0 0-3-3.02z"></path>
          <path d="m13.6 13.7 2.1 2.1"></path>
          <path d="m22 2-1.5 1.5"></path>
          <path d="m9 17-1.5 1.5"></path>
        </svg>
      </div>
      <h2 class="text-lg font-extrabold text-gray-900 tracking-wide">AI News Summary</h2>
    </div>
    
    <p class="text-gray-800 text-sm leading-relaxed font-medium">
      {summary}
    </p>

    {trendingTopics.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-2">
        {trendingTopics.map(topic => (
          <span class="px-3 py-1 bg-gray-100 text-gray-700 text-xs font-semibold rounded-full border border-gray-200">
            {topic}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
