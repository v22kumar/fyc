---
const navLinks = [
  { href: '/',             ta: 'முகப்பு',           en: 'Home',          ml: 'ഹോം',       hi: 'होम',       protected: false },
  { href: '/about',        ta: 'எங்களை பற்றி',      en: 'About',         ml: 'ഞങ്ങളെ കുറിച്ച്', hi: 'हमारे बारे में', protected: false },
  { href: '/blood-donors', ta: 'இரத்த தானம்',       en: 'Blood Donors',  ml: 'രക്തദാനം',  hi: 'रक्तदान',   protected: true },
  { href: '/events',       ta: 'நிகழ்வுகள்',         en: 'Events',        ml: 'ഇവന്റുകൾ', hi: 'कार्यक्रम', protected: true },
  { href: '/sports',       ta: 'விளையாட்டு',          en: 'Sports',        ml: 'കായികം',   hi: 'खेल',       protected: true },
  { href: '/submit-issue', ta: 'பிரச்னை தெரிவிக்க', en: 'Report Issue',  ml: 'പരാതി',     hi: 'शिकायत',    protected: true },
  { href: '/directory',    ta: 'சமூக கடை',           en: 'Directory',     ml: 'ഡയറക്ടറി', hi: 'निर्देशिका', protected: true },
  { href: '/verify',       ta: 'அட்டை சரிபார்',     en: 'Verify Card',   ml: 'കാർഡ് പരിശോധന', hi: 'कार्ड सत्यापन', protected: true },
];
---

<header class="bg-[#0F5132] border-b border-[#198754]/20 sticky top-0 z-50 shadow-md">
  <div class="w-full max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-[70px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 text-white font-bold tracking-tight flex-shrink-0">
        <img src="/fyc_logo.png" alt="FYC" class="h-12 w-12 rounded-xl object-cover flex-shrink-0 border border-white/10 shadow-sm" />
        <div class="flex flex-col justify-center">
          <span class="text-lg leading-none font-extrabold">FYC Connect</span>
          <span class="text-[9px] text-[#D4AF37] font-semibold uppercase tracking-[0.12em] mt-1">Unite &bull; Play &bull; Thrive</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0.5">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-2.5 py-1.5 rounded-lg text-green-100 hover:text-white hover:bg-white/10 text-xs font-semibold transition-all"
            data-ta={link.ta} data-en={link.en} data-ml={link.ml} data-hi={link.hi}
          >
            {link.ta}
          </a>
        ))}

        <!-- Language picker -->
        <div class="relative ml-1" id="lang-picker">
          <button
            onclick="toggleLangPicker()"
            class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-[#D4AF37] text-[#D4AF37] text-xs font-bold hover:bg-white/10 transition-all"
          >
            <span class="lang-flag">TA</span>
            <span class="text-[9px] opacity-50">▼</span>
          </button>
          <div id="lang-dropdown" class="hidden absolute right-0 top-10 bg-white border border-gray-100 rounded-xl shadow-xl z-50 py-1 min-w-[130px] overflow-hidden">
            <button onclick="setLang('ta')" class="w-full text-left px-4 py-2.5 text-xs font-semibold hover:bg-gray-50 transition-colors flex items-center gap-2">
              <span class="w-6 text-center text-[10px] font-bold text-gray-400">TA</span> தமிழ்
            </button>
            <button onclick="setLang('en')" class="w-full text-left px-4 py-2.5 text-xs font-semibold hover:bg-gray-50 transition-colors flex items-center gap-2">
              <span class="w-6 text-center text-[10px] font-bold text-gray-400">EN</span> English
            </button>
            <button onclick="setLang('ml')" class="w-full text-left px-4 py-2.5 text-xs font-semibold hover:bg-gray-50 transition-colors flex items-center gap-2">
              <span class="w-6 text-center text-[10px] font-bold text-gray-400">ML</span> മലയാളം
            </button>
            <button onclick="setLang('hi')" class="w-full text-left px-4 py-2.5 text-xs font-semibold hover:bg-gray-50 transition-colors flex items-center gap-2">
              <span class="w-6 text-center text-[10px] font-bold text-gray-400">HI</span> हिन्दी
            </button>
          </div>
        </div>

        <!-- Auth buttons -->
        <a id="hdr-login-btn" href="/login"
          class="ml-1 px-3 py-1.5 rounded-lg bg-white/15 text-white text-xs font-semibold hover:bg-white/25 transition-all border border-white/20"
          data-ta="உள்நுழை" data-en="Login" data-ml="ലോഗിൻ" data-hi="लॉगिन">உள்நுழை</a>
        <div id="hdr-user-menu" class="hidden ml-1 relative">
          <button onclick="toggleUserMenu()"
            class="w-8 h-8 rounded-full bg-[#D4AF37] text-[#0F5132] text-xs font-extrabold flex items-center justify-center hover:opacity-90 transition-opacity shadow-sm"
            id="hdr-user-avatar">U</button>
          <div id="hdr-user-dropdown"
            class="hidden absolute right-0 top-10 bg-white shadow-xl rounded-2xl border border-gray-100 py-2 w-44 z-50">
            <div class="px-4 py-2 text-xs text-gray-500 border-b border-gray-100 font-medium" id="hdr-user-name"></div>
            <a href="/complete-profile" class="block px-4 py-2.5 text-xs text-gray-700 hover:bg-gray-50 transition-colors"
               data-ta="சுயவிவரம்" data-en="My Profile" data-ml="പ്രൊഫൈൽ" data-hi="प्रोफ़ाइल">My Profile</a>
            <button onclick="signOut()"
              class="w-full text-left px-4 py-2.5 text-xs text-red-600 hover:bg-red-50 transition-colors font-semibold"
              data-ta="வெளியேறு" data-en="Sign out" data-ml="സൈൻ ഔട്ട്" data-hi="साइन आउट">Sign out</button>
          </div>
        </div>
      </nav>

      <!-- Mobile right controls -->
      <div class="flex lg:hidden items-center gap-2">
        <!-- Mobile language picker -->
        <div class="relative" id="lang-picker-mobile">
          <button
            onclick="toggleLangPicker()"
            class="flex items-center gap-1 px-2 py-1 rounded-lg border border-[#D4AF37] text-[#D4AF37] text-[10px] font-bold hover:bg-white/10 transition-all"
          >
            <span class="lang-flag">TA</span>
          </button>
        </div>
        <a id="hdr-login-btn-mobile" href="/login"
          class="px-2.5 py-1 rounded-lg bg-white/15 text-white text-xs font-semibold hover:bg-white/25 transition-all"
          data-ta="உள்நுழை" data-en="Login" data-ml="ലോഗിൻ" data-hi="लॉगिन">உள்நுழை</a>
        <div id="hdr-user-menu-mobile" class="hidden">
          <button onclick="toggleUserMenu()"
            class="w-8 h-8 rounded-full bg-[#D4AF37] text-[#0F5132] text-xs font-extrabold flex items-center justify-center"
            id="hdr-user-avatar-mobile">U</button>
        </div>
        <button
          id="mobile-menu-btn"
          class="text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Toggle menu"
          onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-white/20 mt-1 pt-3">
      <div class="grid grid-cols-2 gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-green-100 hover:text-white hover:bg-white/10 text-sm font-medium transition-colors"
            data-ta={link.ta} data-en={link.en} data-ml={link.ml} data-hi={link.hi}
            onclick="document.getElementById('mobile-menu').classList.add('hidden')"
          >
            <span>{link.protected ? '🔒 ' : ''}{link.ta}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Info strip: weather + gold -->
  <div class="border-t border-white/10 bg-[#0b3d24]/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-1 flex items-center gap-3 text-[11px] text-green-100/75 overflow-hidden">
      <span id="hdr-weather" class="shrink-0">🌤 —</span>
      <span class="text-white/20 shrink-0">|</span>
      <span id="hdr-gold" class="shrink-0">🪙 —</span>
    </div>
  </div>
</header>
