---
const navLinks = [
  { href: '/',              ta: 'முகப்பு',          en: 'Home' },
  { href: '/about',         ta: 'எங்களை பற்றி',     en: 'About' },
  { href: '/blood-donors',  ta: 'இரத்த தானம்',      en: 'Blood Donation' },
  { href: '/submit-issue',  ta: 'பிரச்னை தெரிவிக்க', en: 'Report Issue' },
  { href: '/events',        ta: 'நிகழ்வுகள்',        en: 'Events' },
];
---

<header class="bg-primary sticky top-0 z-50 shadow-lg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-white font-bold text-xl tracking-tight">
        <span class="text-2xl">🌱</span>
        <span>FYC Connect</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-3 py-2 rounded-lg text-green-100 hover:text-white hover:bg-white/10 text-sm font-medium transition-colors"
            data-ta={link.ta}
            data-en={link.en}
          >
            {link.ta}
          </a>
        ))}
        <button
          id="lang-toggle"
          onclick="toggleLang()"
          class="ml-2 px-3 py-1.5 rounded-lg border border-white/30 text-white text-sm font-medium hover:bg-white/10 transition-colors"
        >
          English
        </button>
      </nav>

      <!-- Mobile menu button -->
      <div class="flex md:hidden items-center gap-2">
        <button
          id="lang-toggle"
          onclick="toggleLang()"
          class="px-2.5 py-1 rounded-lg border border-white/30 text-white text-xs font-medium hover:bg-white/10 transition-colors"
        >
          English
        </button>
        <button
          id="mobile-menu-btn"
          class="text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Toggle menu"
          onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-white/20 mt-1 pt-3 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-3 py-2 rounded-lg text-green-100 hover:text-white hover:bg-white/10 text-sm font-medium transition-colors"
          data-ta={link.ta}
          data-en={link.en}
          onclick="document.getElementById('mobile-menu').classList.add('hidden')"
        >
          {link.ta}
        </a>
      ))}
    </div>
  </div>
</header>
