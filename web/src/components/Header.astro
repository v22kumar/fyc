---
const navLinks = [
  { href: '/',              ta: 'முகப்பு',          en: 'Home' },
  { href: '/about',         ta: 'எங்களை பற்றி',     en: 'About' },
  { href: '/blood-donors',  ta: 'இரத்த தானம்',      en: 'Blood Donation' },
  { href: '/submit-issue',  ta: 'பிரச்னை தெரிவிக்க', en: 'Report Issue' },
  { href: '/events',        ta: 'நிகழ்வுகள்',        en: 'Events' },
  { href: '/verify',        ta: 'அட்டை சரிபார்',     en: 'Verify Card' },
  { href: '/directory',     ta: 'சமூக கடை',           en: 'Directory' },
  { href: '/sports',        ta: 'விளையாட்டு',          en: 'Sports' },
];
---

<header class="bg-[#0F5132] border-b border-[#198754]/20 sticky top-0 z-50 shadow-md">
  <div class="w-full max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-[70px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 text-white font-bold tracking-tight">
        <img src="/fyc_logo.png" alt="FYC" class="h-12 w-12 rounded-xl object-cover object-center flex-shrink-0 border border-white/10 shadow-sm" />
        <div class="flex flex-col justify-center">
          <span class="text-lg leading-none font-extrabold tracking-tight">FYC Connect</span>
          <span class="text-[9px] text-[#D4AF37] font-semibold uppercase tracking-[0.12em] mt-1">Unite &bull; Play &bull; Thrive</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-2.5 py-1.5 rounded-lg text-green-100 hover:text-white hover:bg-white/10 text-xs font-semibold transition-all"
            data-ta={link.ta}
            data-en={link.en}
          >
            {link.ta}
          </a>
        ))}
        <button
          id="lang-toggle"
          onclick="toggleLang()"
          class="ml-2 px-2.5 py-1.5 rounded-lg border border-[#D4AF37] text-[#D4AF37] text-xs font-semibold hover:bg-white/10 hover:text-white transition-all"
        >
          English
        </button>
        <!-- Auth: hidden until JS resolves state -->
        <a id="hdr-login-btn" href="/login"
          class="ml-1 px-2.5 py-1.5 rounded-lg bg-white/10 text-white text-xs font-semibold hover:bg-white/20 transition-all"
          data-ta="உள்நுழை" data-en="Login">உள்நுழை</a>
        <div id="hdr-user-menu" class="hidden ml-1 relative">
          <button onclick="toggleUserMenu()"
            class="w-8 h-8 rounded-full bg-[#D4AF37] text-[#0F5132] text-xs font-extrabold flex items-center justify-center hover:opacity-90 transition-opacity"
            id="hdr-user-avatar">U</button>
          <div id="hdr-user-dropdown"
            class="hidden absolute right-0 top-10 bg-white shadow-lg rounded-xl border border-gray-100 py-1 w-40 z-50">
            <div class="px-4 py-2 text-xs text-gray-500 border-b border-gray-50" id="hdr-user-name"></div>
            <button onclick="signOut()"
              class="w-full text-left px-4 py-2 text-xs text-red-600 hover:bg-red-50 transition-colors"
              data-ta="வெளியேறு" data-en="Sign out">Sign out</button>
          </div>
        </div>
      </nav>

      <!-- Mobile menu button -->
      <div class="flex md:hidden items-center gap-2">
        <button
          id="lang-toggle"
          onclick="toggleLang()"
          class="px-2.5 py-1 rounded-lg border border-[#D4AF37] text-[#D4AF37] text-xs font-semibold hover:bg-white/10 transition-colors"
        >
          English
        </button>
        <!-- Mobile auth button -->
        <a id="hdr-login-btn-mobile" href="/login"
          class="px-2.5 py-1 rounded-lg bg-white/10 text-white text-xs font-semibold hover:bg-white/20 transition-colors"
          data-ta="உள்நுழை" data-en="Login">உள்நுழை</a>
        <div id="hdr-user-menu-mobile" class="hidden">
          <button onclick="toggleUserMenu()"
            class="w-8 h-8 rounded-full bg-[#D4AF37] text-[#0F5132] text-xs font-extrabold flex items-center justify-center"
            id="hdr-user-avatar-mobile">U</button>
        </div>
        <button
          id="mobile-menu-btn"
          class="text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Toggle menu"
          onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-white/20 mt-1 pt-3 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-3 py-2 rounded-lg text-green-100 hover:text-white hover:bg-white/10 text-sm font-medium transition-colors"
          data-ta={link.ta}
          data-en={link.en}
          onclick="document.getElementById('mobile-menu').classList.add('hidden')"
        >
          {link.ta}
        </a>
      ))}
    </div>
  </div>

  <!-- Info strip: live weather + gold price -->
  <div class="border-t border-white/10 bg-[#0b3d24]/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-1 flex items-center gap-3 text-[11px] text-green-100/75 overflow-hidden">
      <span id="hdr-weather" class="flex items-center gap-1 shrink-0">🌤 —</span>
      <span class="text-white/20 shrink-0">|</span>
      <span id="hdr-gold" class="flex items-center gap-1 shrink-0">🪙 —</span>
    </div>
  </div>
</header>
