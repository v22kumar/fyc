---
import BaseLayout from '../layouts/BaseLayout.astro';

const bloodGroups = ['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-'];

import { API_BASE, DEFAULT_ORG_ID } from '../lib/config';
---

<BaseLayout
  title="இரத்த தானம் தேடுக - Blood Donor Search"
  description="நாகர்கோவில் பகுதியில் உள்ள இரத்த தான பதிவாளர்களை தேடுங்கள். Search blood donors in Nagercoil area."
>
  <script is:inline>
    if (!localStorage.getItem('fyc_token')) {
      window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search));
    }
  </script>

  <!-- Page Header -->
  <section class="relative overflow-hidden text-white" style="min-height:200px;background:#030C06;">
    <div class="aurora-bg absolute inset-0 overflow-hidden pointer-events-none">
      <div class="aurora-blob-1" style="position:absolute;left:-60px;top:-60px;width:300px;height:300px;border-radius:50%;background:rgba(239,68,68,0.50);"></div>
      <div class="aurora-blob-2" style="position:absolute;right:-40px;top:20px;width:260px;height:260px;border-radius:50%;background:rgba(15,81,50,0.40);"></div>
      <div class="aurora-blob-3" style="position:absolute;left:40%;bottom:-30px;width:180px;height:180px;border-radius:50%;background:rgba(212,175,55,0.08);"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center py-16 px-4">
      <div class="text-5xl mb-4">🩸</div>
      <h1 class="text-3xl sm:text-4xl font-bold mb-3"
        data-ta="இரத்த தானம் தேடுக" data-en="Search Blood Donors"
        data-ml="രക്തദാതാക്കളെ കണ്ടെത്തുക" data-hi="रक्तदाता खोजें">
        இரத்த தானம் தேடுக
      </h1>
      <p class="text-red-100"
        data-ta="நாகர்கோவில் பகுதியில் உள்ள பதிவாளர்களை தேடுங்கள்"
        data-en="Find verified donors in the Nagercoil area"
        data-ml="നാഗർകോവിൽ മേഖലയിൽ സ്ഥിരീകരിച്ച ദാതാക്കളെ കണ്ടെത്തുക"
        data-hi="नागरकोइल क्षेत्र में सत्यापित दाता खोजें">
        நாகர்கோவில் பகுதியில் உள்ள பதிவாளர்களை தேடுங்கள்
      </p>
    </div>
  </section>

  <!-- Search Section -->
  <section class="py-6 px-4 bg-white border-b border-gray-100 sticky top-16 z-40 shadow-sm">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row gap-6 items-start md:items-center justify-between">
      <!-- Blood Group Filter -->
      <div class="w-full md:w-auto">
        <p class="text-sm font-medium text-gray-700 mb-3" data-ta="இரத்த வகை தேர்ந்தெடுக்கவும்" data-en="Filter by Blood Group">
          இரத்த வகை தேர்ந்தெடுக்கவும்
        </p>
        <div class="flex flex-wrap gap-2">
          <button
            class="blood-filter-btn px-4 py-2 rounded-full border-2 border-accent text-accent font-semibold text-sm transition-all hover:bg-accent hover:text-white active"
            data-group=""
            data-ta="அனைத்தும்"
            data-en="All Types"
          >
            அனைத்தும்
          </button>
          {bloodGroups.map((g) => (
            <button
              class="blood-filter-btn px-4 py-2 rounded-full border-2 border-gray-200 text-gray-700 font-semibold text-sm transition-all hover:border-accent hover:text-accent"
              data-group={g}
            >
              {g}
            </button>
          ))}
        </div>
      </div>

      <!-- Location Filter -->
      <div class="w-full md:w-auto flex flex-col sm:flex-row gap-4 items-start sm:items-center">
        <div class="w-full sm:w-56">
          <label for="location-select" class="block text-sm font-medium text-gray-700 mb-1" data-ta="பகுதி / வட்டாரம்" data-en="Location / Taluk">
            பகுதி / வட்டாரம்
          </label>
          <select
            id="location-select"
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-accent"
          >
            <option value="" data-ta="அனைத்து பகுதிகள்" data-en="All Locations">அனைத்து பகுதிகள்</option>
            <!-- Dynamic options populated by JS -->
          </select>
        </div>
        <div class="flex items-center mt-6">
          <input
            type="checkbox"
            id="nearby-checkbox"
            class="h-4 w-4 text-accent border-gray-300 rounded focus:ring-accent cursor-not-allowed"
            disabled
          />
          <label for="nearby-checkbox" class="ml-2 text-sm text-gray-400 font-medium cursor-not-allowed select-none" id="nearby-label" data-ta="அருகிலுள்ள பகுதிகள் உட்பட" data-en="Include nearby areas">
            அருகிலுள்ள பகுதிகள் உட்பட
          </label>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-10 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Privacy Notice -->
      <div class="bg-amber-50 border border-amber-200 rounded-card p-4 mb-6 flex gap-3 items-start">
        <span class="text-xl flex-shrink-0">🔒</span>
        <div>
          <p class="text-sm font-semibold text-amber-800" data-ta="தனியுரிமை கவசம்" data-en="Privacy Shield">
            தனியுரிமை கவசம்
          </p>
          <p class="text-sm text-amber-700 mt-0.5" data-ta="தானிகளின் தொலைபேசி எண் பொது பட்டியலில் காட்டப்படவில்லை. 'தொடர்பு கோரவும்' பொத்தானை அழுத்தி தொடர்பு விவரங்களைப் பெறுங்கள்." data-en="Donor phone numbers are not shown publicly. Click 'Request Contact' to reveal contact details.">
            தானிகளின் தொலைபேசி எண் பொது பட்டியலில் காட்டப்படவில்லை. 'தொடர்பு கோரவும்' பொத்தானை அழுத்தி தொடர்பு விவரங்களைப் பெறுங்கள்.
          </p>
        </div>
      </div>

      <!-- Loading state -->
      <div id="donors-loading" class="text-center py-16">
        <div class="inline-block w-10 h-10 border-4 border-accent border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-gray-500" data-ta="ஏற்றுகிறது..." data-en="Loading donors...">ஏற்றுகிறது...</p>
      </div>

      <!-- Error state -->
      <div id="donors-error" class="hidden text-center py-16">
        <div class="text-5xl mb-4">⚠️</div>
        <p class="text-gray-600 font-medium" data-ta="தரவு ஏற்றுவதில் பிழை. மீண்டும் முயற்சிக்கவும்." data-en="Failed to load donors. Please try again.">
          தரவு ஏற்றுவதில் பிழை. மீண்டும் முயற்சிக்கவும்.
        </p>
        <button
          onclick="loadDonors()"
          class="mt-4 px-6 py-2 bg-accent text-white rounded-card text-sm font-medium hover:bg-accent-700 transition-colors"
          data-ta="மீண்டும் முயற்சிக்கவும்"
          data-en="Try Again"
        >
          மீண்டும் முயற்சிக்கவும்
        </button>
      </div>

      <!-- Empty state -->
      <div id="donors-empty" class="hidden text-center py-16">
        <div class="text-5xl mb-4">🔍</div>
        <p class="text-gray-600 font-medium" data-ta="இந்த இரத்த வகையில் தானம் பதிவாளர்கள் இல்லை" data-en="No donors found for this blood group">
          இந்த இரத்த வகையில் தானம் பதிவாளர்கள் இல்லை
        </p>
      </div>

      <!-- Donor count badge -->
      <div id="donors-count" class="hidden mb-4 text-sm text-gray-500 font-medium"></div>

      <!-- Donors grid -->
      <div id="donors-grid" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Populated by JS -->
      </div>

      <!-- Load more -->
      <div id="load-more-wrap" class="hidden text-center mt-8">
        <button
          id="load-more-btn"
          onclick="loadMore()"
          class="px-8 py-3 bg-white border-2 border-accent text-accent font-semibold rounded-xl hover:bg-accent hover:text-white transition-all text-sm"
        >
          <span data-ta="மேலும் காட்டு" data-en="Load more donors">Load more donors</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Contact Request Modal -->
  <div id="contact-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50">
    <div class="bg-white rounded-card shadow-2xl max-w-sm w-full p-6">
      <div class="text-center" id="contact-modal-loading">
        <div class="inline-block w-10 h-10 border-4 border-accent border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-gray-500" data-ta="தொடர்பு விவரங்கள் பெறப்படுகிறது..." data-en="Fetching contact details...">தொடர்பு விவரங்கள் பெறப்படுகிறது...</p>
      </div>
      <div class="text-center hidden" id="contact-modal-result">
        <div class="text-5xl mb-3">🤝</div>
        <h3 class="text-lg font-bold text-gray-900 mb-2" data-ta="தொடர்பு விவரங்கள்" data-en="Contact Details">
          தொடர்பு விவரங்கள்
        </h3>
        <p class="text-2xl font-bold text-primary mb-5" id="contact-phone"></p>
        <div class="flex flex-col gap-3">
          <a
            id="contact-whatsapp-link"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-3 bg-green-600 text-white rounded-card font-semibold text-sm hover:bg-green-700 transition-colors flex items-center justify-center gap-2"
          >
            <span>💬</span>
            <span data-ta="WhatsApp இல் தொடர்பு கொள்ளுங்கள்" data-en="Contact on WhatsApp">Contact on WhatsApp</span>
          </a>
          <button
            id="close-contact-modal"
            class="w-full py-3 border border-gray-200 text-gray-700 rounded-card font-semibold text-sm hover:bg-gray-50 transition-colors"
            data-ta="மூடு" data-en="Close"
          >
            மூடு
          </button>
        </div>
      </div>
      <div class="text-center hidden" id="contact-modal-error">
        <div class="text-5xl mb-3">⚠️</div>
        <p class="text-sm text-gray-600 mb-5" data-ta="தொடர்பு விவரங்களைப் பெற முடியவில்லை. மீண்டும் முயற்சிக்கவும்." data-en="Could not fetch contact details. Please try again.">
          தொடர்பு விவரங்களைப் பெற முடியவில்லை. மீண்டும் முயற்சிக்கவும்.
        </p>
        <button
          id="close-contact-modal-error"
          class="w-full py-3 border border-gray-200 text-gray-700 rounded-card font-semibold text-sm hover:bg-gray-50 transition-colors"
          data-ta="மூடு" data-en="Close"
        >
          மூடு
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ API_BASE, DEFAULT_ORG_ID }}>
  const PAGE_SIZE = 100;
  let currentFilter = '';
  let selectedGeographyId = '';
  let includeNearby = false;
  let currentOffset = 0;
  let totalDonors = 0;

  const bloodGroupColors = {
    'A+': 'bg-red-100 text-red-800', 'A-': 'bg-red-50 text-red-700',
    'B+': 'bg-orange-100 text-orange-800', 'B-': 'bg-orange-50 text-orange-700',
    'AB+': 'bg-purple-100 text-purple-800', 'AB-': 'bg-purple-50 text-purple-700',
    'O+': 'bg-blue-100 text-blue-800', 'O-': 'bg-blue-50 text-blue-700',
  };

  function getLang() {
    return localStorage.getItem('fyc_lang') || 'ta';
  }

  function t(ta, en) {
    return getLang() === 'ta' ? ta : en;
  }

  function createDonorCard(donor) {
    const lang = getLang();
    const name = lang === 'ta' ? (donor.full_name_ta || donor.full_name_en || 'பெயர் இல்லை') : (donor.full_name_en || donor.full_name_ta || 'Unknown');
    const bgClass = bloodGroupColors[donor.blood_group] || 'bg-gray-100 text-gray-800';
    const availableLabel = donor.is_available ? t('கிடைக்கிறது', 'Available') : t('தற்போது இல்லை', 'Unavailable');
    const availableClass = donor.is_available ? 'text-green-600' : 'text-gray-400';
    
    const locationName = lang === 'ta' ? (donor.geography_name_ta || donor.geography_name_en || '') : (donor.geography_name_en || donor.geography_name_ta || '');
    const locationBadge = locationName ? `
      <div class="flex items-center gap-1 text-xs text-gray-500 mb-3 font-medium">
        <span>📍</span>
        <span>${locationName}</span>
      </div>
    ` : '';

    return `
      <div class="bg-white rounded-card shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between mb-2">
          <div class="w-12 h-12 rounded-full bg-accent-100 flex items-center justify-center text-xl font-bold text-accent-800 flex-shrink-0">
            ${donor.blood_group.replace('+', '<sup>+</sup>').replace('-', '<sup>−</sup>')}
          </div>
          <span class="text-xs font-medium ${availableClass} flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full ${donor.is_available ? 'bg-green-500' : 'bg-gray-400'} inline-block"></span>
            ${availableLabel}
          </span>
        </div>
        <h3 class="font-semibold text-gray-900 mb-0.5 text-base">${name}</h3>
        ${locationBadge}
        <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-bold ${bgClass} mb-4">
          ${donor.blood_group}
        </span>
        <button
          onclick="requestContact('${donor.id}')"
          class="w-full py-2.5 border-2 border-accent text-accent font-semibold text-sm rounded-card hover:bg-accent hover:text-white transition-all"
        >
          🤝 ${t('தொடர்பு கோரவும்', 'Request Contact')}
        </button>
      </div>
    `;
  }

  function buildUrl(bloodGroup, geographyId, nearby, offset) {
    let url = `${API_BASE}/api/v1/blood-donors?available_only=true&limit=${PAGE_SIZE}&offset=${offset}`;
    if (bloodGroup) url += `&blood_group=${encodeURIComponent(bloodGroup)}`;
    if (geographyId) {
      url += `&geography_id=${encodeURIComponent(geographyId)}`;
      if (nearby) url += `&nearby=true`;
    }
    return url;
  }

  function updateCountBadge(showing, total) {
    const el = document.getElementById('donors-count');
    if (!el) return;
    const lang = getLang();
    if (total === 0) { el.classList.add('hidden'); return; }
    el.textContent = lang === 'ta'
      ? `${showing} / ${total} இரத்த தானிகள்`
      : `Showing ${showing} of ${total} donors`;
    el.classList.remove('hidden');
  }

  function updateLoadMore(showing, total) {
    const wrap = document.getElementById('load-more-wrap');
    if (!wrap) return;
    if (showing < total) {
      wrap.classList.remove('hidden');
    } else {
      wrap.classList.add('hidden');
    }
  }

  async function loadDonors(bloodGroup = '', geographyId = '', nearby = false) {
    const grid = document.getElementById('donors-grid');
    const loading = document.getElementById('donors-loading');
    const error = document.getElementById('donors-error');
    const empty = document.getElementById('donors-empty');
    const countEl = document.getElementById('donors-count');

    currentOffset = 0;
    grid.innerHTML = '';
    grid.classList.add('hidden');
    loading.classList.remove('hidden');
    error.classList.add('hidden');
    empty.classList.add('hidden');
    if (countEl) countEl.classList.add('hidden');
    document.getElementById('load-more-wrap')?.classList.add('hidden');

    try {
      const response = await fetch(buildUrl(bloodGroup, geographyId, nearby, 0), {
        headers: { 'X-Organization-ID': DEFAULT_ORG_ID }
      });
      if (!response.ok) throw new Error('API error');

      totalDonors = parseInt(response.headers.get('X-Total-Count') || '0', 10);
      const donors = await response.json();
      currentOffset = donors.length;

      loading.classList.add('hidden');
      if (donors.length === 0) { empty.classList.remove('hidden'); return; }

      grid.innerHTML = donors.map(createDonorCard).join('');
      grid.classList.remove('hidden');
      updateCountBadge(currentOffset, totalDonors);
      updateLoadMore(currentOffset, totalDonors);
    } catch (e) {
      loading.classList.add('hidden');
      error.classList.remove('hidden');
    }
  }

  async function loadMore() {
    const btn = document.getElementById('load-more-btn');
    const grid = document.getElementById('donors-grid');
    if (btn) btn.disabled = true;

    try {
      const response = await fetch(
        buildUrl(currentFilter, selectedGeographyId, includeNearby, currentOffset),
        { headers: { 'X-Organization-ID': DEFAULT_ORG_ID } }
      );
      if (!response.ok) throw new Error('API error');

      const donors = await response.json();
      currentOffset += donors.length;
      grid.insertAdjacentHTML('beforeend', donors.map(createDonorCard).join(''));
      updateCountBadge(currentOffset, totalDonors);
      updateLoadMore(currentOffset, totalDonors);
    } catch (_) {}
    if (btn) btn.disabled = false;
  }

  // Fetch geography nodes for dropdown selection
  async function loadGeographyNodes() {
    const select = document.getElementById('location-select');
    try {
      const response = await fetch(`${API_BASE}/api/v1/geography?level=TALUK`);
      if (!response.ok) return;
      const nodes = await response.json();
      
      const lang = getLang();
      nodes.sort((a, b) => {
        const nameA = lang === 'ta' ? a.name_ta : a.name_en;
        const nameB = lang === 'ta' ? b.name_ta : b.name_en;
        return nameA.localeCompare(nameB);
      });

      nodes.forEach(node => {
        const option = document.createElement('option');
        option.value = node.id;
        option.setAttribute('data-ta', node.name_ta);
        option.setAttribute('data-en', node.name_en);
        option.textContent = lang === 'ta' ? node.name_ta : node.name_en;
        select.appendChild(option);
      });
    } catch (e) {
      console.error('Failed to load geography nodes:', e);
    }
  }

  function showContactModal() {
    const modal = document.getElementById('contact-modal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  async function requestContact(donorId) {
    const loading = document.getElementById('contact-modal-loading');
    const result = document.getElementById('contact-modal-result');
    const errorEl = document.getElementById('contact-modal-error');

    loading.classList.remove('hidden');
    result.classList.add('hidden');
    errorEl.classList.add('hidden');
    showContactModal();

    try {
      const response = await fetch(`${API_BASE}/api/v1/blood-donors/${donorId}/request-contact`, {
        method: 'POST',
        headers: { 'X-Organization-ID': DEFAULT_ORG_ID }
      });
      if (!response.ok) throw new Error('API error');

      const data = await response.json();
      document.getElementById('contact-phone').textContent = data.phone_number;
      document.getElementById('contact-whatsapp-link').href = data.whatsapp_link;

      loading.classList.add('hidden');
      result.classList.remove('hidden');
    } catch (e) {
      loading.classList.add('hidden');
      errorEl.classList.remove('hidden');
    }
  }

  // Filter button logic
  document.querySelectorAll('.blood-filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.blood-filter-btn').forEach((b) => {
        b.classList.remove('active', 'bg-accent', 'text-white', 'border-accent');
        b.classList.add('border-gray-200', 'text-gray-700');
      });
      btn.classList.add('active', 'bg-accent', 'text-white', 'border-accent');
      btn.classList.remove('border-gray-200', 'text-gray-700');
      currentFilter = btn.dataset.group || '';
      loadDonors(currentFilter, selectedGeographyId, includeNearby);
    });
  });

  function closeContactModal() {
    const modal = document.getElementById('contact-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // Set up event listeners
  document.addEventListener('DOMContentLoaded', () => {
    loadGeographyNodes();

    const locationSelect = document.getElementById('location-select');
    const nearbyCheckbox = document.getElementById('nearby-checkbox');
    const nearbyLabel = document.getElementById('nearby-label');

    locationSelect.addEventListener('change', (e) => {
      selectedGeographyId = e.target.value;
      if (selectedGeographyId) {
        nearbyCheckbox.removeAttribute('disabled');
        nearbyCheckbox.classList.remove('cursor-not-allowed');
        nearbyLabel.classList.remove('cursor-not-allowed', 'text-gray-400');
        nearbyLabel.classList.add('text-gray-700', 'cursor-pointer');
      } else {
        nearbyCheckbox.setAttribute('disabled', 'true');
        nearbyCheckbox.checked = false;
        includeNearby = false;
        nearbyCheckbox.classList.add('cursor-not-allowed');
        nearbyLabel.classList.add('cursor-not-allowed', 'text-gray-400');
        nearbyLabel.classList.remove('text-gray-700', 'cursor-pointer');
      }
      loadDonors(currentFilter, selectedGeographyId, includeNearby);
    });

    nearbyCheckbox.addEventListener('change', (e) => {
      includeNearby = e.target.checked;
      loadDonors(currentFilter, selectedGeographyId, includeNearby);
    });

    document.getElementById('close-contact-modal').addEventListener('click', closeContactModal);
    document.getElementById('close-contact-modal-error').addEventListener('click', closeContactModal);

    document.getElementById('contact-modal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeContactModal();
    });

    // Intercept language toggle to reload cards with current filters
    const originalToggleLang = window.toggleLang;
    window.toggleLang = function () {
      if (typeof originalToggleLang === 'function') originalToggleLang();
      loadDonors(currentFilter, selectedGeographyId, includeNearby);
    };

    // Initial load
    loadDonors();
  });
</script>

