---
import BaseLayout from '../layouts/BaseLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8000';
const DEFAULT_ORG_ID = import.meta.env.PUBLIC_DEFAULT_ORG_ID ?? '8f8b80b7-4b71-4770-b183-5c5f49e49a1d';
---

<BaseLayout
  title="நிகழ்வுகள் - Community Events"
  description="FYC நடத்தும் சமூக நிகழ்வுகள் - மரம் நடுவு, இரத்த முகாம், சுதந்திர தினம். Upcoming FYC community events."
>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-primary-900 to-primary-700 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="text-5xl mb-4">🎗️</div>
      <h1 class="text-3xl sm:text-4xl font-bold mb-3" data-ta="நிகழ்வுகள்" data-en="Community Events">
        நிகழ்வுகள்
      </h1>
      <p class="text-green-100" data-ta="வரவிருக்கும் FYC சமூக நிகழ்வுகள்" data-en="Upcoming FYC community events">
        வரவிருக்கும் FYC சமூக நிகழ்வுகள்
      </p>
    </div>
  </section>

  <!-- Events List -->
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Loading -->
      <div id="events-loading" class="text-center py-16">
        <div class="inline-block w-10 h-10 border-4 border-primary border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-gray-500" data-ta="நிகழ்வுகள் ஏற்றுகிறது..." data-en="Loading events...">நிகழ்வுகள் ஏற்றுகிறது...</p>
      </div>

      <!-- Error -->
      <div id="events-error" class="hidden text-center py-16">
        <div class="text-5xl mb-4">⚠️</div>
        <p class="text-gray-600 font-medium" data-ta="நிகழ்வுகள் ஏற்றுவதில் பிழை" data-en="Failed to load events">
          நிகழ்வுகள் ஏற்றுவதில் பிழை
        </p>
        <button
          onclick="loadEvents()"
          class="mt-4 px-6 py-2 bg-primary text-white rounded-card text-sm font-medium hover:bg-primary-700 transition-colors"
          data-ta="மீண்டும் முயற்சிக்கவும்" data-en="Try Again"
        >
          மீண்டும் முயற்சிக்கவும்
        </button>
      </div>

      <!-- Empty -->
      <div id="events-empty" class="hidden text-center py-16">
        <div class="text-5xl mb-4">📅</div>
        <p class="text-gray-600 font-medium" data-ta="தற்போது நிகழ்வுகள் இல்லை" data-en="No upcoming events at this time">
          தற்போது நிகழ்வுகள் இல்லை
        </p>
        <p class="text-sm text-gray-400 mt-2" data-ta="விரைவில் நிகழ்வுகள் சேர்க்கப்படும்" data-en="Events will be added soon">
          விரைவில் நிகழ்வுகள் சேர்க்கப்படும்
        </p>
      </div>

      <!-- Events grid -->
      <div id="events-grid" class="hidden grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Populated by JS -->
      </div>
    </div>
  </section>

  <!-- App CTA -->
  <section class="bg-gray-50 border-t border-gray-100 py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-xl font-bold text-gray-900 mb-2" data-ta="நிகழ்வில் பங்கேற்க விரும்புகிறீர்களா?" data-en="Want to attend events?">
        நிகழ்வில் பங்கேற்க விரும்புகிறீர்களா?
      </h2>
      <p class="text-gray-600 text-sm mb-6" data-ta="FYC App பதிவிறக்கி, QR குறியீடு ஸ்கேன் செய்து நிகழ்விற்கு வருகை பதிவிட்டு, தன்னார்வ மணிகளை சம்பாதியுங்கள்." data-en="Download the FYC App, scan the event QR code, log your attendance, and earn volunteer hours.">
        FYC App பதிவிறக்கி, QR குறியீடு ஸ்கேன் செய்து நிகழ்விற்கு வருகை பதிவிட்டு, தன்னார்வ மணிகளை சம்பாதியுங்கள்.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="#" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-card font-semibold text-sm hover:bg-primary-700 transition-colors">
          <span>📱</span>
          <span data-ta="ஆப் பதிவிறக்கம் (விரைவில்)" data-en="Download App (Coming Soon)">ஆப் பதிவிறக்கம் (விரைவில்)</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ API_BASE, DEFAULT_ORG_ID }}>
  function getLang() {
    return localStorage.getItem('fyc_lang') || 'ta';
  }

  function t(ta, en) {
    return getLang() === 'ta' ? ta : en;
  }

  function formatDate(isoString) {
    try {
      const d = new Date(isoString);
      const lang = getLang();
      return d.toLocaleDateString(lang === 'ta' ? 'ta-IN' : 'en-IN', {
        weekday: 'short', year: 'numeric', month: 'short', day: 'numeric',
        hour: '2-digit', minute: '2-digit',
      });
    } catch {
      return isoString;
    }
  }

  function isUpcoming(isoString) {
    return new Date(isoString) > new Date();
  }

  function createEventCard(event) {
    const lang = getLang();
    const title = lang === 'ta' ? event.title_ta : event.title_en;
    const desc = lang === 'ta' ? event.description_ta : event.description_en;
    const upcoming = isUpcoming(event.event_start);

    return `
      <div class="bg-white rounded-card shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
        ${event.banner_url ? `
          <div class="h-40 bg-primary-100 overflow-hidden">
            <img src="${event.banner_url}" alt="${title}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='<div class=\\"h-full bg-gradient-to-br from-primary-200 to-primary-300 flex items-center justify-center text-5xl\\">🎗️</div>'" />
          </div>
        ` : `
          <div class="h-40 bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center text-5xl">🎗️</div>
        `}
        <div class="p-5">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-medium px-2 py-0.5 rounded-full ${upcoming ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600'}">
              ${upcoming ? t('வரவிருக்கிறது', 'Upcoming') : t('முடிந்தது', 'Past')}
            </span>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2 leading-snug">${title}</h3>
          <p class="text-sm text-gray-600 mb-3 line-clamp-2">${desc}</p>
          <div class="space-y-1.5">
            <div class="flex items-center gap-2 text-xs text-gray-500">
              <span>📅</span>
              <span>${formatDate(event.event_start)}</span>
            </div>
            <div class="flex items-center gap-2 text-xs text-gray-500">
              <span>⏱️</span>
              <span>${t('முடிவு', 'Ends')}: ${formatDate(event.event_end)}</span>
            </div>
          </div>
          ${upcoming ? `
            <div class="mt-4 pt-4 border-t border-gray-100">
              <p class="text-xs text-gray-400" data-ta="வருகை பதிவிட FYC App பயன்படுத்துங்கள்" data-en="Use the FYC App to check in at this event">
                ${t('வருகை பதிவிட FYC App பயன்படுத்துங்கள்', 'Use the FYC App to check in at this event')}
              </p>
            </div>
          ` : ''}
        </div>
      </div>
    `;
  }

  async function loadEvents() {
    const grid = document.getElementById('events-grid');
    const loading = document.getElementById('events-loading');
    const error = document.getElementById('events-error');
    const empty = document.getElementById('events-empty');

    grid.classList.add('hidden');
    loading.classList.remove('hidden');
    error.classList.add('hidden');
    empty.classList.add('hidden');

    try {
      const response = await fetch(`${API_BASE}/api/v1/events`, {
        headers: { 'X-Organization-ID': DEFAULT_ORG_ID }
      });

      if (!response.ok) throw new Error('API error');

      const events = await response.json();
      loading.classList.add('hidden');

      if (events.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      // Sort: upcoming first
      events.sort((a, b) => {
        const aUp = new Date(a.event_start) > new Date();
        const bUp = new Date(b.event_start) > new Date();
        if (aUp && !bUp) return -1;
        if (!aUp && bUp) return 1;
        return new Date(a.event_start) - new Date(b.event_start);
      });

      grid.innerHTML = events.map(createEventCard).join('');
      grid.classList.remove('hidden');
    } catch (e) {
      loading.classList.add('hidden');
      error.classList.remove('hidden');
    }
  }

  loadEvents();
</script>
