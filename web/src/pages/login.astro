---
import BaseLayout from '../layouts/BaseLayout.astro';
import { API_BASE, DEFAULT_ORG_ID } from '../lib/config';

const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID ?? '';
---

<BaseLayout
  title="உள்நுழைக - Login"
  description="Sign in to FYC Connect with your Google account or phone number."
>
  <section class="min-h-[80vh] flex items-center justify-center px-4 py-16 bg-gradient-to-br from-[#f8f9fa] via-white to-[#f0fdf4]">
    <div class="w-full max-w-sm">
      <!-- Card -->
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8">
        <!-- Logo -->
        <div class="text-center mb-8">
          <img src="/fyc_logo.png" alt="FYC" class="h-16 w-16 rounded-2xl mx-auto mb-3 shadow-sm border border-white/10" />
          <h1 class="text-xl font-extrabold text-gray-900" data-ta="FYC Connect இல் உள்நுழைக" data-en="Sign in to FYC Connect">
            FYC Connect இல் உள்நுழைக
          </h1>
          <p class="text-sm text-gray-500 mt-1" data-ta="நாகர்கோவில் சமூக இணைப்பு தளம்" data-en="Nagercoil Community Platform">
            நாகர்கோவில் சமூக இணைப்பு தளம்
          </p>
        </div>

        <!-- Alerts -->
        <div id="login-error" class="hidden mb-4 bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3"></div>
        <div id="login-success" class="hidden mb-4 bg-green-50 border border-green-200 text-green-700 text-sm rounded-xl px-4 py-3"></div>

        <!-- Google Sign-In -->
        {GOOGLE_CLIENT_ID ? (
          <div class="mb-6">
            <div id="google-signin-btn" class="flex justify-center"></div>
            <p class="text-center text-xs text-gray-400 mt-3" data-ta="Google கணக்கு மூலம் உடனடியாக உள்நுழைக" data-en="Sign in instantly with your Google account">
              Sign in instantly with your Google account
            </p>
          </div>

          <div class="relative mb-6">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-100"></div></div>
            <div class="relative flex justify-center">
              <span class="px-3 bg-white text-xs text-gray-400 font-medium" data-ta="அல்லது" data-en="or">அல்லது</span>
            </div>
          </div>
        ) : (
          <div class="mb-4 bg-amber-50 border border-amber-200 text-amber-700 text-xs rounded-xl px-4 py-3">
            Google Sign-In is not configured yet. Use phone/OTP login below or contact the admin to enable it.
          </div>
        )}

        <!-- Phone / OTP login -->
        <div id="otp-section">
          <!-- Step 1: phone -->
          <div id="step-phone">
            <label class="block text-sm font-semibold text-gray-700 mb-1.5" data-ta="தொலைபேசி எண்" data-en="Phone number">
              தொலைபேசி எண்
            </label>
            <div class="flex gap-2">
              <span class="flex items-center px-3 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-500 font-medium">+91</span>
              <input
                id="phone-input"
                type="tel"
                inputmode="numeric"
                maxlength="10"
                placeholder="98765 43210"
                class="flex-1 px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#0F5132]/30 focus:border-[#0F5132]"
              />
            </div>
            <button
              id="send-otp-btn"
              onclick="sendOtp()"
              class="mt-3 w-full py-2.5 bg-[#0F5132] text-white font-semibold rounded-xl text-sm hover:bg-[#136b41] active:scale-95 transition-all"
            >
              <span data-ta="OTP அனுப்பு" data-en="Send OTP">OTP அனுப்பு</span>
            </button>
          </div>

          <!-- Step 2: OTP -->
          <div id="step-otp" class="hidden">
            <p class="text-sm text-gray-600 mb-3">
              <span data-ta="OTP அனுப்பப்பட்டது:" data-en="OTP sent to:">OTP sent to:</span>
              <strong id="otp-phone-display" class="text-gray-900"></strong>
            </p>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5" data-ta="6-இலக்க OTP" data-en="6-digit OTP">6-இலக்க OTP</label>
            <input
              id="otp-input"
              type="text"
              inputmode="numeric"
              maxlength="6"
              placeholder="------"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm text-center tracking-[0.4em] font-mono focus:outline-none focus:ring-2 focus:ring-[#0F5132]/30 focus:border-[#0F5132]"
            />
            <button
              id="verify-otp-btn"
              onclick="verifyOtp()"
              class="mt-3 w-full py-2.5 bg-[#0F5132] text-white font-semibold rounded-xl text-sm hover:bg-[#136b41] active:scale-95 transition-all"
            >
              <span data-ta="உள்நுழை" data-en="Sign in">உள்நுழை</span>
            </button>
            <button onclick="resetToPhone()" class="mt-2 w-full text-xs text-gray-400 hover:text-gray-600 py-1">
              <span data-ta="மீண்டும் தொலைபேசி எண் மாற்று" data-en="Change phone number">Change phone number</span>
            </button>
          </div>

          <!-- Step 3: Register (new user) -->
          <div id="step-register" class="hidden">
            <div class="bg-blue-50 border border-blue-200 text-blue-700 text-xs rounded-xl px-4 py-3 mb-4">
              <span data-ta="புதிய பயனர் — உங்கள் விவரங்களை பதிவு செய்யுங்கள்" data-en="New user — please register to continue">New user — please register to continue</span>
            </div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1" data-ta="பெயர் (தமிழில்)" data-en="Name (Tamil)">பெயர் (தமிழில்)</label>
                <input id="reg-name-ta" type="text" placeholder="உதா: வருண் குமார்"
                  class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#0F5132]/30 focus:border-[#0F5132]" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1" data-ta="பெயர் (ஆங்கிலத்தில்)" data-en="Name (English)">Name (English)</label>
                <input id="reg-name-en" type="text" placeholder="e.g. Varun Kumar"
                  class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#0F5132]/30 focus:border-[#0F5132]" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1" data-ta="உறுப்பினர் வகை" data-en="Member type">Member type</label>
                <select id="reg-role"
                  class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#0F5132]/30 focus:border-[#0F5132] bg-white">
                  <option value="PUBLIC_CITIZEN">பொது குடிமகன் / Public Citizen</option>
                  <option value="VOLUNTEER">தன்னார்வலர் / Volunteer</option>
                  <option value="CLUB_MEMBER">கிளப் உறுப்பினர் / Club Member</option>
                </select>
              </div>
            </div>
            <button
              id="register-btn"
              onclick="registerUser()"
              class="mt-4 w-full py-2.5 bg-[#0F5132] text-white font-semibold rounded-xl text-sm hover:bg-[#136b41] active:scale-95 transition-all"
            >
              <span data-ta="பதிவு செய்க" data-en="Register">பதிவு செய்க</span>
            </button>
            <button onclick="resetToPhone()" class="mt-2 w-full text-xs text-gray-400 hover:text-gray-600 py-1">
              <span data-ta="மீண்டும் தொலைபேசி எண் மாற்று" data-en="Change phone number">Change phone number</span>
            </button>
          </div>
        </div>

        <!-- Loading overlay -->
        <div id="login-loading" class="hidden mt-4 text-center">
          <div class="inline-block w-6 h-6 border-2 border-[#0F5132] border-t-transparent rounded-full animate-spin"></div>
        </div>

        <p class="mt-6 text-center text-[11px] text-gray-400 leading-relaxed">
          <span data-ta="உள்நுழைவதன் மூலம் நீங்கள் எங்கள் விதிமுறைகளை ஒப்புக்கொள்கிறீர்கள்" data-en="By signing in you agree to our terms of service">
            By signing in you agree to our terms of service
          </span>
        </p>
      </div>

      <p class="text-center text-xs text-gray-400 mt-4">
        <a href="/" class="hover:text-gray-600 transition-colors" data-ta="← முகப்பு பக்கம்" data-en="← Back to home">← Back to home</a>
      </p>
    </div>
  </section>
</BaseLayout>

{GOOGLE_CLIENT_ID && (
  <script src="https://accounts.google.com/gsi/client" async defer></script>
)}

<script define:vars={{ API_BASE, DEFAULT_ORG_ID, GOOGLE_CLIENT_ID }}>
  // ── Utilities ─────────────────────────────────────────────────────────────
  function showError(msg) {
    const el = document.getElementById('login-error');
    el.textContent = msg;
    el.classList.remove('hidden');
    document.getElementById('login-success').classList.add('hidden');
  }
  function showSuccess(msg) {
    const el = document.getElementById('login-success');
    el.textContent = msg;
    el.classList.remove('hidden');
    document.getElementById('login-error').classList.add('hidden');
  }
  function setLoading(on) {
    document.getElementById('login-loading').classList.toggle('hidden', !on);
    ['send-otp-btn', 'verify-otp-btn'].forEach(id => {
      const btn = document.getElementById(id);
      if (btn) btn.disabled = on;
    });
  }

  // Store JWT + user and redirect
  function onAuthSuccess(data) {
    localStorage.setItem('fyc_token', data.access_token);
    localStorage.setItem('fyc_user', JSON.stringify(data.user ?? {}));
    showSuccess('ஆம்! உள்நுழைவு வெற்றிகரமாக முடிந்தது. / Signed in successfully!');
    setTimeout(() => {
      const next = new URLSearchParams(window.location.search).get('next') || '/';
      window.location.href = next;
    }, 800);
  }

  // ── Google Sign-In ─────────────────────────────────────────────────────────
  if (GOOGLE_CLIENT_ID) {
    window.addEventListener('load', () => {
      if (typeof google === 'undefined') return;
      google.accounts.id.initialize({
        client_id: GOOGLE_CLIENT_ID,
        callback: async (resp) => {
          setLoading(true);
          try {
            const res = await fetch(`${API_BASE}/api/v1/auth/google`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ organization_id: DEFAULT_ORG_ID, id_token: resp.credential }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.detail || 'Google sign-in failed');
            onAuthSuccess(data);
          } catch (e) {
            showError(e.message);
          } finally {
            setLoading(false);
          }
        },
      });
      google.accounts.id.renderButton(
        document.getElementById('google-signin-btn'),
        { theme: 'outline', size: 'large', text: 'signin_with', shape: 'rectangular', width: 280 }
      );
    });
  }

  // ── OTP flow ───────────────────────────────────────────────────────────────
  let _verificationId = '';

  window.sendOtp = async function () {
    const raw = document.getElementById('phone-input').value.trim().replace(/\s/g, '');
    if (!/^\d{10}$/.test(raw)) { showError('10-digit phone number required.'); return; }
    const phone = '+91' + raw;
    setLoading(true);
    try {
      const res = await fetch(`${API_BASE}/api/v1/auth/otp/send`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone_number: phone, organization_id: DEFAULT_ORG_ID }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail || 'Failed to send OTP');
      _verificationId = data.verification_id;
      document.getElementById('otp-phone-display').textContent = ' ' + phone;
      document.getElementById('step-phone').classList.add('hidden');
      document.getElementById('step-otp').classList.remove('hidden');
      document.getElementById('otp-input').focus();
      document.getElementById('login-error').classList.add('hidden');
    } catch (e) {
      showError(e.message);
    } finally {
      setLoading(false);
    }
  };

  let _phoneForRegister = '';

  window.verifyOtp = async function () {
    const otp = document.getElementById('otp-input').value.trim();
    if (!/^\d{6}$/.test(otp)) { showError('Enter the 6-digit OTP.'); return; }
    setLoading(true);
    try {
      const res = await fetch(`${API_BASE}/api/v1/auth/otp/verify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ verification_id: _verificationId, otp_code: otp }),
      });
      const data = await res.json();
      if (res.status === 404 && data.detail?.toLowerCase().includes('register')) {
        // New user — show registration form
        _phoneForRegister = document.getElementById('otp-phone-display').textContent.trim();
        document.getElementById('step-otp').classList.add('hidden');
        document.getElementById('step-register').classList.remove('hidden');
        document.getElementById('login-error').classList.add('hidden');
        document.getElementById('reg-name-en').focus();
        return;
      }
      if (!res.ok) throw new Error(data.detail || 'OTP verification failed');
      onAuthSuccess(data);
    } catch (e) {
      showError(e.message);
    } finally {
      setLoading(false);
    }
  };

  window.registerUser = async function () {
    const nameTa = document.getElementById('reg-name-ta').value.trim();
    const nameEn = document.getElementById('reg-name-en').value.trim();
    const role = document.getElementById('reg-role').value;
    if (!nameEn) { showError('Please enter your name in English.'); return; }
    if (!nameTa) { showError('Please enter your name in Tamil.'); return; }
    setLoading(true);
    try {
      const res = await fetch(`${API_BASE}/api/v1/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          organization_id: DEFAULT_ORG_ID,
          phone_number: _phoneForRegister,
          role,
          full_name_ta: nameTa,
          full_name_en: nameEn,
          preferred_language: localStorage.getItem('fyc_lang') || 'ta',
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail || 'Registration failed');
      onAuthSuccess(data);
    } catch (e) {
      showError(e.message);
    } finally {
      setLoading(false);
    }
  };

  window.resetToPhone = function () {
    _verificationId = '';
    _phoneForRegister = '';
    document.getElementById('step-otp').classList.add('hidden');
    document.getElementById('step-register').classList.add('hidden');
    document.getElementById('step-phone').classList.remove('hidden');
    document.getElementById('login-error').classList.add('hidden');
    document.getElementById('otp-input').value = '';
  };

  // Redirect if already logged in
  if (localStorage.getItem('fyc_token')) {
    const next = new URLSearchParams(window.location.search).get('next') || '/';
    window.location.replace(next);
  }

  // Enter key shortcuts
  document.getElementById('phone-input')?.addEventListener('keydown', e => { if (e.key === 'Enter') window.sendOtp(); });
  document.getElementById('otp-input')?.addEventListener('keydown', e => { if (e.key === 'Enter') window.verifyOtp(); });
</script>
