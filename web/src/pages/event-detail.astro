---
import BaseLayout from '../layouts/BaseLayout.astro';
import { API_BASE, DEFAULT_ORG_ID } from '../lib/config';
---

<BaseLayout
  title="நிகழ்வு பதிவு | Event Registration"
  description="Register for upcoming FYC events and competitions."
>
  <main class="registration-page">
    <div id="loading" class="text-center py-16">
        <div class="inline-block w-10 h-10 border-4 border-primary border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-gray-500">Loading event details...</p>
    </div>
    
    <div id="error" class="hidden text-center py-16">
        <div class="text-5xl mb-4">⚠️</div>
        <p class="text-gray-600 font-medium">Event not found or failed to load.</p>
        <a href="/events" class="inline-block mt-4 text-primary underline">Back to Events</a>
    </div>

    <div id="event-content" class="hidden">
        <div class="header-banner">
        <div class="container mx-auto px-4 max-w-6xl">
            <a href="/events" class="back-link mb-4 inline-block text-green-200 hover:text-white transition-colors">← Back to Events</a>
            <h1 id="ev-title-en" class="text-3xl font-bold mb-2"></h1>
            <p id="ev-title-ta" class="ta-title text-green-100 text-lg mb-6"></p>
            <div class="meta flex flex-wrap gap-6 text-sm text-green-100">
                <span id="ev-date" class="flex items-center gap-2">📅 <span></span></span>
                <span id="ev-time" class="flex items-center gap-2">⏰ <span></span></span>
            </div>
        </div>
        </div>

        <div class="container mx-auto px-4 max-w-6xl content-split mt-8 mb-16 grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="details lg:col-span-7">
            <h3 class="text-2xl font-bold mb-4 text-gray-900">About Event</h3>
            <p id="ev-desc-en" class="text-gray-600 mb-4 leading-relaxed"></p>
            <p id="ev-desc-ta" class="text-gray-600 leading-relaxed"></p>
            
            <div id="ev-deadline-container" class="hidden alert warning mt-8 p-4 bg-amber-50 border border-amber-200 rounded-lg text-amber-800">
                Registration Deadline: <strong id="ev-deadline"></strong>
            </div>
        </div>

        <div class="registration-form-container lg:col-span-5 bg-white p-6 rounded-2xl shadow-sm border border-gray-100 relative">
            <div id="reg-status-badge" class="hidden absolute top-4 right-4 bg-green-100 text-green-800 text-xs font-bold px-3 py-1 rounded-full flex items-center gap-1">
                ✓ Registered
            </div>
            
            <h3 class="text-xl font-bold mb-2">Register Now</h3>
            <p id="reg-count" class="text-sm text-gray-500 mb-6 pb-4 border-b border-gray-100">0 Registered</p>
            
            <div id="reg-closed-msg" class="hidden p-4 bg-red-50 text-red-700 rounded-lg font-medium text-center mb-4">
                Registration Closed
            </div>

            <form id="regForm" class="reg-form flex flex-col gap-4">
            <input type="hidden" id="eventId" />
            
            <div class="form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Full Name *</label>
                <input type="text" id="name" required class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" />
            </div>
            
            <div class="grid grid-cols-2 gap-4">
                <div class="form-group flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-700">Date of Birth *</label>
                    <input type="date" id="dob" required class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" />
                </div>
                <div class="form-group flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-700">Gender *</label>
                    <select id="gender" required class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none bg-white">
                        <option value="">Select</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="form-group flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-700">Mobile *</label>
                    <input type="tel" id="mobile" required pattern="[0-9]{10}" class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" />
                </div>
                <div class="form-group flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-700">Email</label>
                    <input type="email" id="email" class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="Optional" />
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="form-group flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-700">School / College *</label>
                    <input type="text" id="school" required class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" />
                </div>
                <div class="form-group flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-700">Class / Grade *</label>
                    <select id="grade" required class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none bg-white">
                        <option value="">Select</option>
                        <option value="1 முதல் 3 ஆம் வகுப்பு">1 முதல் 3 ஆம் வகுப்பு</option>
                        <option value="4 முதல் 5 ஆம் வகுப்பு">4 முதல் 5 ஆம் வகுப்பு</option>
                        <option value="6 முதல் 8 ஆம் வகுப்பு">6 முதல் 8 ஆம் வகுப்பு</option>
                        <option value="9 முதல் 10 ஆம் வகுப்பு">9 முதல் 10 ஆம் வகுப்பு</option>
                        <option value="11 மற்றும் 12 ஆம் வகுப்பு">11 மற்றும் 12 ஆம் வகுப்பு</option>
                        <option value="கல்லூரி மாணவர்கள்">கல்லூரி மாணவர்கள்</option>
                        <option value="திறந்த பிரிவு">திறந்த பிரிவு</option>
                    </select>
                </div>
            </div>

            <div class="form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Address</label>
                <textarea id="address" rows="2" class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="Optional"></textarea>
            </div>

            <div class="form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Member ID</label>
                <input type="text" id="member_id" class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="Optional" />
            </div>

            <!-- Shown only for Submission type events -->
            <div id="submission-topic-container" class="hidden form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Topic *</label>
                <input type="text" id="topic" class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="Enter your submission topic" />
            </div>

            <div class="form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Remarks</label>
                <textarea id="remarks" rows="2" class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" placeholder="Optional"></textarea>
            </div>

            <button type="submit" id="submitBtn" class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:bg-primary-700 transition-colors mt-2 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">Submit Registration</button>
            <div id="msg" class="hidden mt-4 p-3 rounded-lg text-sm text-center"></div>
            </form>
        </div>
        
        <!-- Participant List (Admins Only) -->
        <div id="participants-section" class="hidden col-span-1 lg:col-span-12 mt-8">
            <h3 class="text-2xl font-bold mb-4 text-gray-900">Registered Participants (Admin View)</h3>
            <div class="overflow-x-auto bg-white rounded-xl shadow-sm border border-gray-100">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-gray-50 border-b border-gray-100">
                            <th class="p-4 font-semibold text-gray-700">Name</th>
                            <th class="p-4 font-semibold text-gray-700">DOB</th>
                            <th class="p-4 font-semibold text-gray-700">Gender</th>
                            <th class="p-4 font-semibold text-gray-700">Mobile</th>
                            <th class="p-4 font-semibold text-gray-700">School/College</th>
                            <th class="p-4 font-semibold text-gray-700">Class/Grade</th>
                        </tr>
                    </thead>
                    <tbody id="participants-tbody" class="divide-y divide-gray-100">
                    </tbody>
                </table>
            </div>
        </div>

        </div>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ API_BASE, DEFAULT_ORG_ID }}>
    const urlParams = new URLSearchParams(window.location.search);
    const eventId = urlParams.get('id');

    async function loadEvent() {
        if (!eventId) {
            document.getElementById('loading').classList.add('hidden');
            document.getElementById('error').classList.remove('hidden');
            return;
        }

        try {
            const res = await fetch(`${API_BASE}/api/v1/events/${eventId}`, {
                headers: { 'X-Organization-ID': DEFAULT_ORG_ID }
            });
            if (!res.ok) throw new Error('Not found');
            const event = await res.json();

            document.getElementById('eventId').value = event.id;
            document.getElementById('ev-title-en').textContent = event.title_en;
            document.getElementById('ev-title-ta').textContent = event.title_ta;
            document.querySelector('#ev-date span').textContent = new Date(event.event_start).toLocaleDateString();
            document.querySelector('#ev-time span').textContent = `${new Date(event.event_start).toLocaleTimeString()} - ${new Date(event.event_end).toLocaleTimeString()}`;
            document.getElementById('ev-desc-en').textContent = event.description_en;
            document.getElementById('ev-desc-ta').textContent = event.description_ta;

            if (event.registration_deadline) {
                document.getElementById('ev-deadline-container').classList.remove('hidden');
                document.getElementById('ev-deadline').textContent = new Date(event.registration_deadline).toLocaleDateString();
            }

            document.getElementById('reg-count').textContent = `${event.registration_count || 0} Registered`;

            if (event.registration_type === 'Submission') {
                document.getElementById('submission-topic-container').classList.remove('hidden');
                document.getElementById('topic').required = true;
            }

            // Check if registered
            const token = localStorage.getItem('fyc_token');
            if (token) {
                try {
                    const stRes = await fetch(`${API_BASE}/api/v1/events/${eventId}/registration-status`, {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    if (stRes.ok) {
                        const stData = await stRes.json();
                        if (stData.is_registered) {
                            document.getElementById('reg-status-badge').classList.remove('hidden');
                            const btn = document.getElementById('submitBtn');
                            btn.disabled = true;
                            btn.textContent = 'Already Registered';
                        }
                    }
                } catch(e) {}
                
                // Check if admin and fetch participants
                try {
                    const pRes = await fetch(`${API_BASE}/api/v1/events/${eventId}/registrations`, {
                        headers: { 'Authorization': `Bearer ${token}` }
                    });
                    if (pRes.ok) {
                        const participants = await pRes.json();
                        if (participants && participants.length > 0) {
                            document.getElementById('participants-section').classList.remove('hidden');
                            const tbody = document.getElementById('participants-tbody');
                            tbody.innerHTML = participants.map(p => `
                                <tr class="hover:bg-gray-50">
                                    <td class="p-4 text-gray-900 font-medium">${p.name}</td>
                                    <td class="p-4 text-gray-600">${new Date(p.dob).toLocaleDateString()}</td>
                                    <td class="p-4 text-gray-600">${p.gender}</td>
                                    <td class="p-4 text-gray-600">${p.mobile_number}</td>
                                    <td class="p-4 text-gray-600">${p.school_college}</td>
                                    <td class="p-4 text-gray-600">${p.class_grade}</td>
                                </tr>
                            `).join('');
                        }
                    }
                } catch(e) {}
            }

            // Check if registration closed
            const now = new Date();
            const deadline = event.registration_deadline ? new Date(event.registration_deadline) : null;
            if (!event.registration_enabled || (deadline && now > deadline) || (event.max_participants && event.registration_count >= event.max_participants)) {
                document.getElementById('reg-closed-msg').classList.remove('hidden');
                document.getElementById('regForm').classList.add('hidden');
            }

            document.getElementById('loading').classList.add('hidden');
            document.getElementById('event-content').classList.remove('hidden');
        } catch (e) {
            document.getElementById('loading').classList.add('hidden');
            document.getElementById('error').classList.remove('hidden');
        }
    }

    loadEvent();

    const form = document.getElementById('regForm');
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const evId = document.getElementById('eventId').value;
        const msgEl = document.getElementById('msg');
        
        let categories = [];
        const topicVal = document.getElementById('topic').value;
        if (topicVal) {
            categories.push(topicVal);
        }

        const payload = {
            name: document.getElementById('name').value,
            dob: new Date(document.getElementById('dob').value).toISOString(),
            gender: document.getElementById('gender').value,
            mobile_number: document.getElementById('mobile').value,
            email: document.getElementById('email').value || null,
            address: document.getElementById('address').value || null,
            school_college: document.getElementById('school').value,
            class_grade: document.getElementById('grade').value,
            member_id: document.getElementById('member_id').value || null,
            competition_category: categories,
            remarks: document.getElementById('remarks').value || null
        };

        try {
            const res = await fetch(`${API_BASE}/api/v1/events/${evId}/register`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Organization-ID': DEFAULT_ORG_ID
                },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            
            msgEl.classList.remove('hidden', 'bg-green-100', 'text-green-800', 'bg-red-100', 'text-red-800', 'bg-amber-100', 'text-amber-800');
            
            if (res.ok) {
                msgEl.classList.add('block', 'bg-green-100', 'text-green-800');
                msgEl.textContent = 'Registration successful!';
                form.reset();
                document.getElementById('reg-status-badge').classList.remove('hidden');
                const btn = document.getElementById('submitBtn');
                btn.disabled = true;
                btn.textContent = 'Registered';
            } else if (res.status === 401) {
                localStorage.removeItem('fyc_token');
                msgEl.classList.add('block', 'bg-amber-100', 'text-amber-800');
                msgEl.innerHTML = 'Session expired. Please <a href="/login" class="underline font-bold text-amber-900">log in again</a>.';
            } else {
                msgEl.classList.add('block', 'bg-red-100', 'text-red-800');
                msgEl.textContent = data.detail || 'Registration failed';
            }
        } catch (err) {
            msgEl.classList.remove('hidden');
            msgEl.classList.add('block', 'bg-red-100', 'text-red-800');
            msgEl.textContent = 'Network error. Please try again.';
        }
    });
</script>

<style>
  .header-banner { background: linear-gradient(135deg, #064e3b, #0f766e); color: white; padding: 2.5rem 0; }
</style>
