---
import BaseLayout from '../layouts/BaseLayout.astro';

// Backend base URL — same convention as the other pages. Baked in at build
// time (the PUBLIC_ prefix also exposes it to the client script below).
import { API_BASE, DEFAULT_ORG_ID } from '../lib/config';

const stats = [
  { value: '1,500+', ta: 'நட்ட மரங்கள்', en: 'Trees Planted', icon: '🌱', color: 'text-emerald-600 bg-emerald-50' },
  { value: '1,200+', ta: 'இரத்த தானம் பதிவாளர்கள்', en: 'Blood Donors', icon: '🩸', color: 'text-rose-600 bg-rose-50' },
  { value: '80+', ta: 'நடத்திய நிகழ்வுகள்', en: 'Events Hosted', icon: '🎉', color: 'text-amber-600 bg-amber-50' },
  { value: '5,000+', ta: 'பயன் பெற்றோர்', en: 'Lives Impacted', icon: '❤️', color: 'text-blue-600 bg-blue-50' },
];

const modules = [
  {
    icon: '🩸',
    href: '/blood-donors',
    tag_ta: 'அவசியம்',
    tag_en: 'Urgent',
    color: 'from-red-50 to-rose-50 border-red-200/60',
    ta: { title: 'இரத்த தானம்', desc: 'அவசரகால தேவைகளுக்காக இரத்த கொடையாளர்களை உடனே தொடர்பு கொள்ளுங்கள்.' },
    en: { title: 'Blood Donation', desc: 'Find verified blood donors in Nagercoil. Connect securely in emergencies.' },
  },
  {
    icon: '📅',
    href: '/events',
    tag_ta: 'நேரடி',
    tag_en: 'Live',
    color: 'from-purple-50 to-violet-50 border-purple-200/60',
    ta: { title: 'நிகழ்வுகள்', desc: 'வரும் நிகழ்வுகள், விழாக்கள் மற்றும் சமூக கூட்டங்களில் கலந்துகொள்ளுங்கள்.' },
    en: { title: 'Events', desc: 'Upcoming community events, festivals, and meetings. Register and attend.' },
  },
  {
    icon: '⚽',
    href: '/sports',
    tag_ta: 'புதியது',
    tag_en: 'New',
    color: 'from-amber-50 to-orange-50 border-amber-200/60',
    ta: { title: 'விளையாட்டு அரங்கம்', desc: 'உள்ளூர் போட்டிகள், அணிகள், அட்டவணைகள் மற்றும் விளையாட்டு சவால்கள்.' },
    en: { title: 'Sports Arena', desc: 'Track local tournaments, teams, fixtures, and community sports challenges.' },
  },
  {
    icon: '🚧',
    href: '/submit-issue',
    tag_ta: 'தீர்வு',
    tag_en: 'Active',
    color: 'from-blue-50 to-indigo-50 border-blue-200/60',
    ta: { title: 'பிரச்னை தீர்வு', desc: 'குடிநீர், தெருவிளக்கு மற்றும் சாலைப் பிரச்னைகளைத் தெரிவித்து தீர்வு காணுங்கள்.' },
    en: { title: 'Report Issue', desc: 'Report civic complaints like water supply or street lights and track resolution.' },
  },
  {
    icon: '🌱',
    href: '/green',
    tag_ta: 'சுற்றுச்சூழல்',
    tag_en: 'Eco',
    color: 'from-green-50 to-emerald-50 border-green-200/60',
    ta: { title: 'பசுமை FYC', desc: 'மர நடும் பிரச்சாரங்கள், சுற்றுச்சூழல் செயல்பாடுகள் மற்றும் இயற்கை சேவை.' },
    en: { title: 'Green FYC', desc: 'Tree planting drives, eco initiatives, and environmental service activities.' },
  },
  {
    icon: '🛍️',
    href: '/directory',
    tag_ta: 'புதியது',
    tag_en: 'New',
    color: 'from-emerald-50 to-teal-50 border-emerald-200/60',
    ta: { title: 'சமூக கடை', desc: 'தச்சர்கள், மின்சாரிகள், ஆசிரியர்கள் — உங்களைச் சுற்றியுள்ள திறமைகளைக் கண்டறியவும்.' },
    en: { title: 'Skills Directory', desc: 'Find local carpenters, electricians, tutors, and verified community profiles.' },
  },
  {
    icon: '🪪',
    href: '/verify',
    tag_ta: 'அதிகாரப்பூர்வம்',
    tag_en: 'Official',
    color: 'from-slate-50 to-gray-50 border-slate-200/60',
    ta: { title: 'அட்டை சரிபார்', desc: 'FYC உறுப்பினர் அட்டையை QR மூலம் சரிபார்க்கவும்.' },
    en: { title: 'Verify Card', desc: 'Scan and verify FYC membership cards using QR code.' },
  },
  {
    icon: '💼',
    href: '/opportunities',
    tag_ta: 'வேலை',
    tag_en: 'Jobs',
    color: 'from-cyan-50 to-sky-50 border-cyan-200/60',
    ta: { title: 'வாய்ப்புகள்', desc: 'TN அரசு வேலைகள், மத்திய அரசு வேலைகள் மற்றும் சமூக வாய்ப்புகள்.' },
    en: { title: 'Opportunities', desc: 'TN & Central govt jobs, scholarships, and community opportunities.' },
  },
];

const updates = [
  {
    avatar: '👨‍💼',
    name: 'R. Prathap',
    role: 'Club President',
    time: '2 hours ago',
    ta: 'நாகர்கோவில் கிரிக்கெட் கோப்பை 2026 போட்டிக்கான பதிவுகள் ஆரம்பம்! உங்கள் அணியை இப்போதே பதிவு செய்யுங்கள்.',
    en: 'Nagercoil Cricket Cup 2026 registrations are now open! Register your team today.',
    tag: 'Sports Hub',
  },
  {
    avatar: '👩‍⚕️',
    name: 'Kavitha S.',
    role: 'Volunteer Coordinator',
    time: '5 hours ago',
    ta: 'ஆசாத் நகர் பகுதியில் நட்ட மரக்கன்றுகளுக்கு நீர் ஊற்றும் பணி வெற்றிகரமாக முடிந்தது. தன்னார்வலர்களுக்கு நன்றி!',
    en: 'Watering drive for planted saplings in Azad Nagar completed successfully. Thanks to all volunteers!',
    tag: 'Green FYC',
  },
  {
    avatar: '🚧',
    name: 'Triage System',
    role: 'System Bot',
    time: '1 day ago',
    ta: 'வார்டு 4-ல் பதிவான குடிநீர் குழாய் உடைப்பு பிரச்னை சரிசெய்யப்பட்டு "முடிந்தது" என மாற்றப்பட்டது.',
    en: 'Water pipeline leak reported in Ward 4 has been repaired and marked as RESOLVED.',
    tag: 'Civic Triage',
  },
];
---

<BaseLayout
  title="FYC Connect — Unite &bull; Play &bull; Thrive"
  description="Connect with Nagercoil's premium community service, sports tournaments, citizen issues triage, and verified blood donor network."
>
  <!-- Modern Split Hero Section -->
  <section class="relative bg-gradient-to-b from-[#f8f9fa] via-white to-[#f8f9fa] overflow-hidden py-16 lg:py-24 border-b border-gray-100">
    <!-- Background grid decoration -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px] pointer-events-none"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-[#198754]/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Hero Text -->
        <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 bg-[#0F5132]/10 border border-[#0F5132]/20 rounded-full px-4 py-1.5 text-xs font-semibold text-[#0F5132]">
            <span class="animate-pulse">🟢</span>
            <span data-ta="பிரண்ட்ஸ் இளைஞர் மன்றத்தின் டிஜிட்டல் தளம்" data-en="Friends Youth Club Digital Hub">
              Friends Youth Club Digital Hub
            </span>
          </div>

          <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 leading-[1.15] tracking-tight">
            <span data-ta="சமூகத்தை இணைப்போம்" data-en="Connecting Nagercoil's">Connecting Nagercoil's</span>
            <br />
            <span class="bg-gradient-to-r from-[#0F5132] to-[#198754] bg-clip-text text-transparent" data-ta="ஒன்றாக உயர்வோம்" data-en="Vibrant Community">Vibrant Community</span>
          </h1>

          <p class="text-base sm:text-lg text-gray-600 max-w-xl mx-auto lg:mx-0 leading-relaxed" data-ta="விளையாட்டு போட்டிகள், சமூக சேவைகள், அவசர இரத்த தானம் மற்றும் பொதுப் பிரச்னைகளுக்கான தீர்வு தளம்." data-en="A modern platform designed to unite sports events, public directory services, emergency blood donations, and civic issue triage under one digital roof.">
            விளையாட்டு போட்டிகள், சமூக சேவைகள், அவசர இரத்த தானம் மற்றும் பொதுப் பிரச்னைகளுக்கான தீர்வு தளம்.
          </p>

          <div id="hero-guest-cta" class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start pt-2">
            <a
              href="/login"
              class="inline-flex items-center justify-center gap-2 bg-[#0F5132] text-white font-semibold px-6 py-3.5 rounded-xl hover:bg-[#136b41] active:scale-95 transition-all shadow-md"
            >
              <span>👤</span>
              <span data-ta="உள்நுழை / பதிவு செய்க" data-en="Login / Register">உள்நுழை / பதிவு செய்க</span>
            </a>
            <a
              href="/blood-donors"
              class="inline-flex items-center justify-center gap-2 bg-white border border-gray-200 text-gray-700 font-semibold px-6 py-3.5 rounded-xl hover:bg-gray-50 active:scale-95 transition-all"
            >
              <span>🩸</span>
              <span data-ta="இரத்த தானம் தேடு" data-en="Find Blood Donors">Find Blood Donors</span>
            </a>
          </div>

          <!-- Logged-in welcome (hidden until JS sets it) -->
          <div id="hero-user-cta" class="hidden pt-2 space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-xl bg-[#0F5132] text-white flex items-center justify-center text-xl font-extrabold shadow-md" id="hero-avatar">V</div>
              <div>
                <div class="text-lg font-extrabold text-gray-900" id="hero-welcome-name">வரவேற்கிறோம்!</div>
                <div id="hero-role-badge" class="inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-0.5 rounded-full bg-[#0F5132]/10 text-[#0F5132] border border-[#0F5132]/20 mt-0.5"></div>
              </div>
            </div>
            <div id="hero-user-links" class="flex flex-wrap gap-2"></div>
          </div>
        </div>

        <!-- Quick feature tiles -->
        <div class="lg:col-span-5 grid grid-cols-2 gap-3">
          <a href="/blood-donors" class="bg-red-50 border border-red-100 rounded-2xl shadow-sm p-4 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <span class="text-3xl">🩸</span>
            <span class="text-sm font-bold text-gray-800" data-ta="இரத்த தானம்" data-en="Blood Donors">Blood Donors</span>
            <span class="text-xs text-gray-400" data-ta="உடனடி உதவி" data-en="Emergency help">Emergency help</span>
          </a>
          <a href="/events" class="bg-purple-50 border border-purple-100 rounded-2xl shadow-sm p-4 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <span class="text-3xl">📅</span>
            <span class="text-sm font-bold text-gray-800" data-ta="நிகழ்வுகள்" data-en="Events">Events</span>
            <span class="text-xs text-gray-400" data-ta="வரும் நிகழ்வுகள்" data-en="Community events">Community events</span>
          </a>
          <a href="/sports" class="bg-amber-50 border border-amber-100 rounded-2xl shadow-sm p-4 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <span class="text-3xl">⚽</span>
            <span class="text-sm font-bold text-gray-800" data-ta="விளையாட்டு" data-en="Sports">Sports</span>
            <span class="text-xs text-gray-400" data-ta="போட்டிகள் & அட்டவணை" data-en="Tournaments">Tournaments</span>
          </a>
          <a href="/submit-issue" class="bg-blue-50 border border-blue-100 rounded-2xl shadow-sm p-4 flex flex-col gap-2 hover:shadow-md transition-shadow">
            <span class="text-3xl">🚧</span>
            <span class="text-sm font-bold text-gray-800" data-ta="பிரச்னை தெரிவி" data-en="Report Issue">Report Issue</span>
            <span class="text-xs text-gray-400" data-ta="குடிமக்கள் குரல்" data-en="Civic triage">Civic triage</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Modern Analytical Stats Grid -->
  <section class="py-8 bg-white border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {stats.map((stat) => (
          <div class="flex items-center gap-4 p-4 rounded-xl hover:bg-gray-50/80 transition-colors">
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl font-bold ${stat.color} flex-shrink-0 shadow-sm`}>
              {stat.icon}
            </div>
            <div>
              <div class="text-2xl font-extrabold text-gray-900 tracking-tight">{stat.value}</div>
              <div class="text-xs text-gray-500 font-medium" data-ta={stat.ta} data-en={stat.en}>{stat.ta}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Profile incomplete soft banner (shown instead of hard redirect) -->
  <div id="profile-incomplete-banner" class="hidden bg-amber-50 border-b border-amber-200 py-3 px-4">
    <div class="max-w-6xl mx-auto flex items-center justify-between gap-4">
      <p class="text-sm text-amber-800">
        <span data-ta="உங்கள் சுயவிவரம் முழுமையடையவில்லை — பிறந்த நாள் வாழ்த்துகள் மற்றும் சமூக அங்கீகாரத்திற்கு நிரப்புங்கள்." data-en="Your profile is incomplete — fill it in for birthday wishes and community recognition.">
          Your profile is incomplete — fill it in for birthday wishes and community recognition.
        </span>
      </p>
      <a href="/complete-profile" class="shrink-0 text-xs font-semibold text-amber-800 underline hover:text-amber-900" data-ta="இப்போது நிரப்பு →" data-en="Complete now →">Complete now →</a>
    </div>
  </div>

  <!-- Birthday Banner — visible only when there are birthdays today -->
  <section id="birthday-banner" class="hidden py-6 px-4 bg-gradient-to-r from-pink-50 to-amber-50 border-y border-pink-100">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3">
        <span class="text-3xl">🎂</span>
        <div>
          <h3 class="font-bold text-gray-900 text-base" data-ta="இன்றைய பிறந்த நாள் வாழ்த்துக்கள்!" data-en="Birthday Wishes Today!">பிறந்த நாள் வாழ்த்துக்கள்!</h3>
          <div id="birthday-names" class="text-sm text-gray-600 mt-0.5"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Daily Thirukkural + Today's Tamil News (live from backend) -->
  <section class="py-12 bg-[#f8f9fa] px-4 border-b border-gray-100">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Daily Thirukkural -->
      <div class="lg:col-span-5">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xl">📜</span>
          <h2 class="text-lg font-extrabold text-gray-900 tracking-tight" data-ta="இன்றைய திருக்குறள்" data-en="Daily Thirukkural">இன்றைய திருக்குறள்</h2>
        </div>
        <div id="kural-card" class="bg-gradient-to-br from-[#0c3f27] to-[#0F5132] text-white rounded-2xl p-6 shadow-md min-h-[220px] flex flex-col justify-center">
          <div id="kural-loading" class="text-green-100/70 text-sm">ஏற்றுகிறது… / Loading…</div>
          <div id="kural-content" class="hidden space-y-4">
            <div class="flex items-center justify-between">
              <span id="kural-paal" class="text-[10px] font-bold uppercase tracking-widest bg-white/15 px-2.5 py-1 rounded-full"></span>
              <span id="kural-number" class="text-[10px] font-bold text-[#D4AF37]"></span>
            </div>
            <p id="kural-tamil" class="text-lg font-bold leading-relaxed whitespace-pre-line" style="font-family:'Noto Sans Tamil',sans-serif"></p>
            <p id="kural-english" class="text-sm text-green-100/90 italic leading-relaxed"></p>
            <p id="kural-meaning" class="text-xs text-green-100/70 leading-relaxed border-t border-white/10 pt-3" style="font-family:'Noto Sans Tamil',sans-serif"></p>
          </div>
        </div>
      </div>

      <!-- Today's News — tabbed: Kanyakumari / Tamil / India / TN Jobs / Central -->
      <div class="lg:col-span-7">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-2">
            <span class="text-xl">📰</span>
            <h2 class="text-lg font-extrabold text-gray-900 tracking-tight" data-ta="இன்றைய செய்திகள்" data-en="Today's News">இன்றைய செய்திகள்</h2>
          </div>
          <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Google News</span>
        </div>
        <!-- Tab buttons -->
        <div class="flex gap-1 mb-3 bg-gray-100 rounded-xl p-1 flex-wrap">
          <button onclick="switchNewsTab('kanyakumari')" id="tab-kanyakumari"
            class="news-tab-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all text-gray-500 hover:text-gray-700">
            கன்னியாகுமரி
          </button>
          <button onclick="switchNewsTab('tamil')" id="tab-tamil"
            class="news-tab-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all bg-white text-[#0F5132] shadow-sm">
            தமிழ்
          </button>
          <button onclick="switchNewsTab('india')" id="tab-india"
            class="news-tab-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all text-gray-500 hover:text-gray-700">
            India
          </button>
          <button onclick="switchNewsTab('tn-jobs')" id="tab-tn-jobs"
            class="news-tab-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all text-gray-500 hover:text-gray-700">
            TN Jobs
          </button>
          <button onclick="switchNewsTab('central-jobs')" id="tab-central-jobs"
            class="news-tab-btn px-3 py-1.5 rounded-lg text-xs font-bold transition-all text-gray-500 hover:text-gray-700">
            Central
          </button>
        </div>
        <div class="bg-white border border-gray-200/80 rounded-2xl shadow-sm overflow-hidden min-h-[220px]">
          <div id="news-loading" class="p-6 text-gray-400 text-sm">Loading headlines…</div>
          <div id="news-list" class="hidden divide-y divide-gray-100"></div>
          <div id="news-error" class="hidden p-6 text-gray-400 text-sm">Could not load news right now.</div>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ API_BASE, DEFAULT_ORG_ID }}>
    const lang = () => localStorage.getItem('fyc_lang') || 'ta';
    const esc = (s) => (s || '').replace(/[&<>"]/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const rel = (iso) => {
      if (!iso) return '';
      const diff = Date.now() - new Date(iso).getTime();
      const m = Math.floor(diff / 60000);
      if (m < 1) return 'now';
      if (m < 60) return m + 'm';
      const h = Math.floor(m / 60);
      if (h < 24) return h + 'h';
      return Math.floor(h / 24) + 'd';
    };

    // ── Daily Thirukkural ────────────────────────────────────────────────
    (async () => {
      try {
        const res = await fetch(`${API_BASE}/api/v1/thirukkural/daily`);
        if (!res.ok) throw new Error('http ' + res.status);
        const k = await res.json();
        document.getElementById('kural-paal').textContent =
          (k.paal_ta || '') + (k.paal_en ? ' · ' + k.paal_en : '');
        document.getElementById('kural-number').textContent = 'குறள் ' + k.number;
        document.getElementById('kural-tamil').textContent =
          [k.line1, k.line2].filter(Boolean).join('\n');
        document.getElementById('kural-english').textContent = k.english_couplet || '';
        document.getElementById('kural-meaning').textContent = k.tamil_meaning || '';
        document.getElementById('kural-loading').classList.add('hidden');
        document.getElementById('kural-content').classList.remove('hidden');
      } catch (e) {
        document.getElementById('kural-loading').textContent = 'Could not load Thirukkural.';
      }
    })();

    // ── Tabbed News ──────────────────────────────────────────────────────
    const NEWS_URLS = {
      kanyakumari:  `${API_BASE}/api/v1/news/kanyakumari?limit=8`,
      tamil:        `${API_BASE}/api/v1/news/top?limit=10`,
      india:        `${API_BASE}/api/v1/news/india?limit=5`,
      'tn-jobs':    `${API_BASE}/api/v1/news/tn-jobs?limit=8`,
      'central-jobs': `${API_BASE}/api/v1/news/central-jobs?limit=8`,
    };
    const newsCache = {};
    let activeTab = 'tamil';

    function renderNewsItems(items) {
      return items.map((it) => `
        <a href="${esc(it.link)}" target="_blank" rel="noopener noreferrer"
           class="flex items-start gap-3 p-4 hover:bg-gray-50/80 transition-colors">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-gray-800 leading-snug line-clamp-2">${esc(it.title)}</p>
            <div class="mt-1 flex items-center gap-2 text-[11px]">
              <span class="font-bold text-[#0F5132]">${esc(it.source)}</span>
              ${it.published_at ? `<span class="text-gray-400">· ${rel(it.published_at)}</span>` : ''}
            </div>
          </div>
          <span class="text-gray-300 text-xs mt-0.5">↗</span>
        </a>`).join('');
    }

    async function loadNews(tab) {
      const loading = document.getElementById('news-loading');
      const list = document.getElementById('news-list');
      const errBox = document.getElementById('news-error');

      if (newsCache[tab]) {
        list.innerHTML = renderNewsItems(newsCache[tab]);
        loading.classList.add('hidden');
        errBox.classList.add('hidden');
        list.classList.remove('hidden');
        return;
      }

      loading.classList.remove('hidden');
      list.classList.add('hidden');
      errBox.classList.add('hidden');

      try {
        const res = await fetch(NEWS_URLS[tab]);
        if (!res.ok) throw new Error('http ' + res.status);
        const items = await res.json();
        if (!Array.isArray(items) || items.length === 0) throw new Error('empty');
        newsCache[tab] = items;
        list.innerHTML = renderNewsItems(items);
        loading.classList.add('hidden');
        list.classList.remove('hidden');
      } catch (e) {
        loading.classList.add('hidden');
        errBox.classList.remove('hidden');
      }
    }

    window.switchNewsTab = function(tab) {
      activeTab = tab;
      ['kanyakumari', 'tamil', 'india', 'tn-jobs', 'central-jobs'].forEach((t) => {
        const btn = document.getElementById('tab-' + t);
        if (t === tab) {
          btn.classList.add('bg-white', 'text-[#0F5132]', 'shadow-sm');
          btn.classList.remove('text-gray-500');
        } else {
          btn.classList.remove('bg-white', 'text-[#0F5132]', 'shadow-sm');
          btn.classList.add('text-gray-500');
        }
      });
      loadNews(tab);
    };

    loadNews('tamil');

    // Birthday banner
    fetch(`${API_BASE}/api/v1/users/birthdays/today`, {
      headers: { 'X-Organization-ID': DEFAULT_ORG_ID }
    })
    .then(r => r.json())
    .then(birthdays => {
      if (!birthdays || birthdays.length === 0) return;
      const lang = localStorage.getItem('fyc_lang') || 'ta';
      const names = birthdays.map(b => lang === 'ta' ? b.full_name_ta : b.full_name_en).join(', ');
      const el = document.getElementById('birthday-names');
      if (el) el.textContent = names;
      document.getElementById('birthday-banner')?.classList.remove('hidden');
    })
    .catch(() => {});

    // Personalise hero for logged-in vs. guest
    const _fycUser = localStorage.getItem('fyc_user');
    if (_fycUser) {
      try {
        const _u = JSON.parse(_fycUser);
        const lang = localStorage.getItem('fyc_lang') || 'ta';
        const name = lang === 'ta' ? (_u.full_name_ta || _u.full_name_en || '') : (_u.full_name_en || _u.full_name_ta || '');
        const firstName = name.split(' ')[0] || 'நண்பர்';

        // Show welcome, hide guest CTA
        document.getElementById('hero-guest-cta')?.classList.add('hidden');
        document.getElementById('hero-user-cta')?.classList.remove('hidden');

        // Avatar initials
        const avatarEl = document.getElementById('hero-avatar');
        if (avatarEl) avatarEl.textContent = firstName.charAt(0).toUpperCase();

        // Welcome name
        const nameEl = document.getElementById('hero-welcome-name');
        if (nameEl) nameEl.textContent = lang === 'ta'
          ? `வரவேற்கிறோம், ${firstName}!`
          : `Welcome back, ${firstName}!`;

        // Role badge
        const roleBadge = document.getElementById('hero-role-badge');
        const roleLabels = {
          PUBLIC_CITIZEN: { ta: 'பொது குடிமகன்', en: 'Public Citizen', icon: '👤' },
          VOLUNTEER: { ta: 'தன்னார்வலர்', en: 'Volunteer', icon: '🤝' },
          CLUB_MEMBER: { ta: 'கிளப் உறுப்பினர்', en: 'Club Member', icon: '⭐' },
          EXECUTIVE_MEMBER: { ta: 'நிர்வாக உறுப்பினர்', en: 'Executive', icon: '🏅' },
          ADMIN: { ta: 'நிர்வாகி', en: 'Admin', icon: '🔑' },
          SUPER_ADMIN: { ta: 'சூப்பர் நிர்வாகி', en: 'Super Admin', icon: '👑' },
        };
        const rl = roleLabels[_u.role] || { ta: _u.role, en: _u.role, icon: '👤' };
        if (roleBadge) roleBadge.textContent = `${rl.icon} ${lang === 'ta' ? rl.ta : rl.en}`;

        // Role-specific quick links
        const linksEl = document.getElementById('hero-user-links');
        const links = [
          { href: '/events', icon: '📅', ta: 'நிகழ்வுகள்', en: 'Events' },
          { href: '/blood-donors', icon: '🩸', ta: 'இரத்த தானம்', en: 'Blood Donors' },
          { href: '/submit-issue', icon: '📢', ta: 'பிரச்சனை தெரிவி', en: 'Report Issue' },
        ];
        if (_u.role === 'VOLUNTEER') links.unshift({ href: '/users/volunteers/my-certificate', icon: '📜', ta: 'சான்றிதழ்', en: 'My Certificate' });
        if (['ADMIN','SUPER_ADMIN','EXECUTIVE_MEMBER'].includes(_u.role)) links.unshift({ href: '/admin', icon: '⚙️', ta: 'நிர்வாக பலகை', en: 'Admin Panel' });
        if (linksEl) linksEl.innerHTML = links.map(l =>
          `<a href="${l.href}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs font-semibold text-gray-700 hover:bg-gray-50 transition-colors">
            <span>${l.icon}</span><span data-ta="${l.ta}" data-en="${l.en}">${lang === 'ta' ? l.ta : l.en}</span>
          </a>`
        ).join('');

        // Profile incomplete → soft banner, no redirect
        if (_u.is_profile_complete === false) {
          document.getElementById('profile-incomplete-banner')?.classList.remove('hidden');
        }
      } catch (_) {}
    }

  </script>

  <!-- Modules Grid (Discord / Notion Style) -->
  <section class="py-16 bg-[#f8f9fa] px-4">
    <div class="max-w-6xl mx-auto px-2">
      <div class="text-center max-w-2xl mx-auto mb-12 space-y-2">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight" data-ta="எல்லா சேவைகளும் ஒரே இடத்தில்" data-en="All Services in One Place">
          All Services in One Place
        </h2>
        <p class="text-sm text-gray-500 leading-relaxed" data-ta="இரத்த தானம், விளையாட்டு, நிகழ்வுகள், பிரச்னைகள், பசுமை FYC — அனைத்தும் இங்கே." data-en="Blood donors, sports, events, civic issues, green drives, jobs — everything the community needs.">
          Blood donors, sports, events, civic issues, green drives, jobs — everything the community needs.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {modules.map((m) => (
          <a
            href={m.href}
            class={`group flex flex-col bg-gradient-to-br ${m.color} border rounded-2xl p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative overflow-hidden`}
          >
            <!-- Module indicator tag -->
            <span class="absolute top-4 right-4 text-[9px] font-extrabold uppercase tracking-widest bg-white/80 border border-gray-100 text-[#0F5132] px-2 py-0.5 rounded-full shadow-sm" data-ta={m.tag_ta} data-en={m.tag_en}>
              {m.tag_ta}
            </span>

            <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-2xl shadow-sm mb-5 group-hover:scale-110 transition-transform">
              {m.icon}
            </div>

            <h3 class="font-extrabold text-gray-900 text-lg mb-2 group-hover:text-[#0F5132] transition-colors" data-ta={m.ta.title} data-en={m.en.title}>
              {m.ta.title}
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed flex-1" data-ta={m.ta.desc} data-en={m.en.desc}>
              {m.ta.desc}
            </p>

            <div class="mt-4 flex items-center gap-1.5 text-xs font-bold text-[#0F5132]">
              <span data-ta="இப்போதே செல்" data-en="Get Started">Get Started</span>
              <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Activity Feed & Updates (LinkedIn / Discord inspired) -->
  <section class="py-16 bg-white px-4 border-t border-gray-100">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- Feed updates -->
        <div class="lg:col-span-8 space-y-6">
          <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2 pb-3 border-b border-gray-100">
            <span>📢</span>
            <span data-ta="சமீபத்திய அறிவிப்புகள்" data-en="Recent Activity Feed">Recent Activity Feed</span>
          </h2>

          <div class="space-y-4">
            {updates.map((up) => (
              <div class="bg-white border border-gray-200/80 rounded-xl p-5 hover:border-gray-300 transition-colors shadow-sm space-y-3">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gray-100 border border-gray-200 flex items-center justify-center text-xl">
                      {up.avatar}
                    </div>
                    <div>
                      <div class="font-bold text-gray-900 text-sm">{up.name}</div>
                      <div class="text-xs text-gray-500 font-medium">{up.role}</div>
                    </div>
                  </div>
                  <div class="text-right">
                    <span class="text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-semibold">{up.tag}</span>
                    <div class="text-[10px] text-gray-400 mt-1 font-medium">{up.time}</div>
                  </div>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed font-medium" data-ta={up.ta} data-en={up.en}>
                  {up.ta}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar / Notion Info block -->
        <div class="lg:col-span-4 space-y-6">
          <div class="bg-[#f8f9fa] border border-gray-200 rounded-2xl p-5 space-y-4 shadow-sm">
            <h3 class="font-bold text-gray-900 flex items-center gap-2" data-ta="எங்களை பற்றி" data-en="Who are We?">
              <span>🤝</span>
              <span>Who are We?</span>
            </h3>
            <p class="text-xs text-gray-600 leading-relaxed" data-ta="நண்பர்கள் இளைஞர் மன்றம் (Friends Youth Club) நாகர்கோவிலில் 2000-ல் தொடங்கப்பட்ட ஒரு சமூக சேவை அமைப்பாகும். மரங்கள் நடுதல், இரத்த கொடை, மற்றும் இளைஞர் விளையாட்டு போன்ற பணிகளை 25 ஆண்டுகளாக செய்து வருகிறோம்." data-en="Friends Youth Club (FYC) was established in 2000 in Nagercoil. For 25 years, our members and volunteers have driven grassroot initiatives in environmental sapling plantation, emergency blood donations, and youth tournament events.">
              Friends Youth Club (FYC) was established in 2000 in Nagercoil. For 25 years, our members and volunteers have driven grassroot initiatives in environmental sapling plantation, emergency blood donations, and youth tournament events.
            </p>
            <div class="pt-2">
              <a href="/about" class="inline-flex items-center gap-1.5 text-xs font-bold text-[#0F5132] hover:underline">
                <span data-ta="எங்கள் வரலாறு வாசி" data-en="Read our history">Read our history</span>
                <span>→</span>
              </a>
            </div>
          </div>

          <!-- Quick Emergency call to action -->
          <div class="bg-gradient-to-br from-[#991b1b] to-red-800 text-white rounded-2xl p-5 space-y-3 shadow-md">
            <div class="flex items-center gap-2.5">
              <span class="text-2xl">🩸</span>
              <h3 class="font-bold" data-ta="இரத்த அவசரநிலை?" data-en="Need Blood urgently?">Need Blood urgently?</h3>
            </div>
            <p class="text-xs text-red-100 leading-relaxed" data-ta="நாகர்கோவில் பகுதியில் அவசர தேவைகளுக்காக உடனடியாக இரத்த கொடையாளர்களைத் தேடி தொடர்பு கொள்ளுங்கள்." data-en="Search verified donors in Nagercoil instantly. Access masked listings for emergencies.">
              Search verified donors in Nagercoil instantly. Access masked listings for emergencies.
            </p>
            <div class="pt-2">
              <a
                href="/blood-donors"
                class="inline-block bg-white text-[#991b1b] text-xs font-bold px-4 py-2 rounded-lg hover:bg-red-50 transition-colors shadow-sm"
                data-ta="தானிகளை தேடு"
                data-en="Search Donors Now"
              >
                Search Donors Now
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Verified Digital ID card invite -->
  <section class="py-16 bg-[#0c3f27] text-white px-4 relative overflow-hidden">
