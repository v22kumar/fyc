  <!-- ─── Shared scripts ───────────────────────────────────────────── -->
  <script define:vars={{ API_BASE, DEFAULT_ORG_ID }}>
    // ── Auth state → personalise welcome ─────────────────────────────
    const _tok = localStorage.getItem('fyc_token');
    const _usr = localStorage.getItem('fyc_user');
    const _lang = localStorage.getItem('fyc_lang') || 'ta';

    if (_tok && _usr) {
      try {
        const u = JSON.parse(_usr);
        const name = _lang === 'ta' ? (u.full_name_ta || u.full_name_en || '') : (u.full_name_en || u.full_name_ta || '');
        const firstName = name.split(' ')[0] || 'நண்பர்';
        const avatarEl = document.getElementById('auth-avatar');
        if (avatarEl) avatarEl.textContent = firstName.charAt(0).toUpperCase();
        const nameEl = document.getElementById('auth-welcome-name');
        if (nameEl) nameEl.textContent = _lang === 'ta' ? `வணக்கம், ${firstName}!` : `Hello, ${firstName}!`;
        const roleLabels = {
          PUBLIC_CITIZEN:   { ta: 'பொது குடிமகன்', en: 'Public Citizen', icon: '👤' },
          VOLUNTEER:        { ta: 'தன்னார்வலர்', en: 'Volunteer', icon: '🤝' },
          CLUB_MEMBER:      { ta: 'கிளப் உறுப்பினர்', en: 'Club Member', icon: '⭐' },
          EXECUTIVE_MEMBER: { ta: 'நிர்வாக உறுப்பினர்', en: 'Executive', icon: '🏅' },
          ADMIN:            { ta: 'நிர்வாகி', en: 'Admin', icon: '🔑' },
          SUPER_ADMIN:      { ta: 'சூப்பர் நிர்வாகி', en: 'Super Admin', icon: '👑' },
        };
        const rl = roleLabels[u.role] || { ta: u.role, en: u.role, icon: '👤' };
        const badge = document.getElementById('auth-role-badge');
        if (badge) badge.textContent = `${rl.icon} ${_lang === 'ta' ? rl.ta : rl.en}`;
        const links = [
          { href: '/events', icon: '📅', ta: 'நிகழ்வுகள்', en: 'Events' },
          { href: '/blood-donors', icon: '🩸', ta: 'இரத்த தானம்', en: 'Blood' },
          { href: '/submit-issue', icon: '📢', ta: 'பிரச்னை', en: 'Report Issue' },
        ];
        if (u.role === 'VOLUNTEER') links.unshift({ href: '/users/volunteers/my-certificate', icon: '📜', ta: 'சான்றிதழ்', en: 'Certificate' });
        if (['ADMIN','SUPER_ADMIN','EXECUTIVE_MEMBER'].includes(u.role)) links.unshift({ href: '/admin', icon: '⚙️', ta: 'நிர்வாகம்', en: 'Admin' });
        const linksEl = document.getElementById('auth-quick-links');
        if (linksEl) linksEl.innerHTML = links.map(l =>
          `<a href="${l.href}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-white/15 border border-white/20 rounded-xl text-xs font-semibold text-white hover:bg-white/25 transition-colors">
            <span>${l.icon}</span><span>${_lang === 'ta' ? l.ta : l.en}</span>
          </a>`
        ).join('');
        if (u.is_profile_complete === false) {
          document.getElementById('profile-incomplete-banner')?.classList.remove('hidden');
        }
      } catch (_) {}
    }

    // ── Birthdays ────────────────────────────────────────────────────
    if (_tok) {
      fetch(`${API_BASE}/api/v1/users/birthdays/today`, {
        headers: { 'X-Organization-ID': DEFAULT_ORG_ID, 'Authorization': 'Bearer ' + _tok }
      }).then(r => r.json()).then(b => {
        if (!b || !b.length) return;
        const names = b.map(x => _lang === 'ta' ? x.full_name_ta : x.full_name_en).join(', ');
        const el = document.getElementById('birthday-names');
        if (el) el.textContent = names;
        document.getElementById('birthday-banner')?.classList.remove('hidden');
      }).catch(() => {});
    }

    // ── Thirukkural ─────────────────────────────────────────────────
    if (_tok) {
      (async () => {
        try {
          const res = await fetch(`${API_BASE}/api/v1/thirukkural/daily`);
          if (!res.ok) throw new Error();
          const k = await res.json();
          document.getElementById('kural-paal').textContent = (k.paal_ta || '') + (k.paal_en ? ' · ' + k.paal_en : '');
          document.getElementById('kural-number').textContent = 'குறள் ' + k.number;
          document.getElementById('kural-tamil').textContent = [k.line1, k.line2].filter(Boolean).join('\n');
          document.getElementById('kural-english').textContent = k.english_couplet || '';
          document.getElementById('kural-meaning').textContent = k.tamil_meaning || '';
          document.getElementById('kural-loading').classList.add('hidden');
          document.getElementById('kural-content').classList.remove('hidden');
        } catch (_) {
          document.getElementById('kural-loading').textContent = 'Could not load Thirukkural.';
        }
      })();
    }

    // ── Tabbed News ──────────────────────────────────────────────────
    const NEWS_URLS = {
      kanyakumari:    `${API_BASE}/api/v1/news/kanyakumari?limit=8`,
      tamil:          `${API_BASE}/api/v1/news/top?limit=10`,
      india:          `${API_BASE}/api/v1/news/india?limit=5`,
      'tn-jobs':      `${API_BASE}/api/v1/news/tn-jobs?limit=8`,
      'central-jobs': `${API_BASE}/api/v1/news/central-jobs?limit=8`,
    };
    const newsCache = {};
    const esc = s => (s || '').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
    const rel = iso => {
      if (!iso) return '';
      const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
      if (m < 1) return 'now'; if (m < 60) return m + 'm';
      const h = Math.floor(m / 60);
      return h < 24 ? h + 'h' : Math.floor(h / 24) + 'd';
    };

    async function loadNews(tab) {
      const loading = document.getElementById('news-loading');
      const list = document.getElementById('news-list');
      const errBox = document.getElementById('news-error');
      if (newsCache[tab]) {
        list.innerHTML = newsCache[tab];
        loading.classList.add('hidden'); errBox.classList.add('hidden'); list.classList.remove('hidden'); return;
      }
      loading.classList.remove('hidden'); list.classList.add('hidden'); errBox.classList.add('hidden');
      try {
        const res = await fetch(NEWS_URLS[tab]);
        if (!res.ok) throw new Error();
        const items = await res.json();
        if (!Array.isArray(items) || !items.length) throw new Error();
        newsCache[tab] = items.map(it => `
          <a href="${esc(it.link)}" target="_blank" rel="noopener noreferrer"
             class="flex items-start gap-3 p-4 hover:bg-gray-50/80 transition-colors">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-800 leading-snug line-clamp-2">${esc(it.title)}</p>
              <div class="mt-1 flex items-center gap-2 text-[11px]">
                <span class="font-bold text-[#0F5132]">${esc(it.source)}</span>
                ${it.published_at ? `<span class="text-gray-400">· ${rel(it.published_at)}</span>` : ''}
              </div>
            </div>
            <span class="text-gray-300 text-xs mt-0.5">↗</span>
          </a>`).join('');
        list.innerHTML = newsCache[tab];
        loading.classList.add('hidden'); list.classList.remove('hidden');
      } catch (_) { loading.classList.add('hidden'); errBox.classList.remove('hidden'); }
    }

    window.switchNewsTab = function(tab) {
      ['kanyakumari','tamil','india','tn-jobs','central-jobs'].forEach(t => {
        const btn = document.getElementById('tab-' + t);
        if (!btn) return;
        if (t === tab) { btn.classList.add('bg-white','text-[#0F5132]','shadow-sm'); btn.classList.remove('text-gray-500'); }
        else { btn.classList.remove('bg-white','text-[#0F5132]','shadow-sm'); btn.classList.add('text-gray-500'); }
      });
      loadNews(tab);
    };

    if (_tok) loadNews('tamil');

    // ── Scroll reveal ────────────────────────────────────────────────
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); revealObserver.unobserve(e.target); } });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // ── Counter animation ────────────────────────────────────────────
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.dataset.target, 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1800;
        const start = Date.now();
        const tick = () => {
          const p = Math.min((Date.now() - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.floor(eased * target).toLocaleString() + (p >= 1 ? suffix : '');
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.counter').forEach(el => counterObserver.observe(el));
  </script>

</BaseLayout>
