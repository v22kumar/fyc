---
import BaseLayout from '../layouts/BaseLayout.astro';
import { API_BASE, DEFAULT_ORG_ID } from '../lib/config';

const modules = [
  { icon: '🩸', href: '/blood-donors', tag_ta: 'அவசியம்', tag_en: 'Urgent', tag_ml: 'അടിയന്തരം', tag_hi: 'जरूरी',
    color: 'from-red-50 to-rose-50 border-red-200/60',
    ta: { title: 'இரத்த தானம்', desc: 'அவசரகால தேவைகளுக்காக இரத்த கொடையாளர்களை உடனே தொடர்பு கொள்ளுங்கள்.' },
    en: { title: 'Blood Donation', desc: 'Find verified blood donors in Nagercoil. Connect securely in emergencies.' },
    ml: { title: 'രക്തദാനം', desc: 'നഗർകോവിലിൽ സ്ഥിരീകരിച്ച രക്തദാതാക്കളെ കണ്ടെത്തൂ.' },
    hi: { title: 'रक्तदान', desc: 'नागरकोइल में सत्यापित रक्तदाता खोजें। आपात स्थिति में जुड़ें।' },
  },
  { icon: '📅', href: '/events', tag_ta: 'நேரடி', tag_en: 'Live', tag_ml: 'തൽസമയം', tag_hi: 'लाइव',
    color: 'from-purple-50 to-violet-50 border-purple-200/60',
    ta: { title: 'நிகழ்வுகள்', desc: 'வரும் நிகழ்வுகள், விழாக்கள் மற்றும் சமூக கூட்டங்களில் கலந்துகொள்ளுங்கள்.' },
    en: { title: 'Events', desc: 'Upcoming community events, festivals, and meetings. Register and attend.' },
    ml: { title: 'ഇവന്റുകൾ', desc: 'ആഗതമായ കമ്മ്യൂണിറ്റി ഇവന്റുകൾ, ഉത്സവങ്ങൾ.' },
    hi: { title: 'कार्यक्रम', desc: 'आगामी सामुदायिक आयोजन, त्योहार और बैठकें।' },
  },
  { icon: '⚽', href: '/sports', tag_ta: 'புதியது', tag_en: 'New', tag_ml: 'പുതിയത്', tag_hi: 'नया',
    color: 'from-amber-50 to-orange-50 border-amber-200/60',
    ta: { title: 'விளையாட்டு அரங்கம்', desc: 'உள்ளூர் போட்டிகள், அணிகள், அட்டவணைகள் மற்றும் விளையாட்டு சவால்கள்.' },
    en: { title: 'Sports Arena', desc: 'Track local tournaments, teams, fixtures, and community sports challenges.' },
    ml: { title: 'കായിക മേഖല', desc: 'പ്രാദേശിക ടൂർണമെന്റുകൾ, ടീമുകൾ, ഷെഡ്യൂളുകൾ.' },
    hi: { title: 'खेल मैदान', desc: 'स्थानीय टूर्नामेंट, टीम, कार्यक्रम और खेल चुनौतियां।' },
  },
  { icon: '🚧', href: '/submit-issue', tag_ta: 'தீர்வு', tag_en: 'Active', tag_ml: 'സജീവം', tag_hi: 'सक्रिय',
    color: 'from-blue-50 to-indigo-50 border-blue-200/60',
    ta: { title: 'பிரச்னை தீர்வு', desc: 'குடிநீர், தெருவிளக்கு மற்றும் சாலைப் பிரச்னைகளைத் தெரிவித்து தீர்வு காணுங்கள்.' },
    en: { title: 'Report Issue', desc: 'Report civic complaints like water supply or street lights and track resolution.' },
    ml: { title: 'പ്രശ്നം റിപ്പോർട്ട്', desc: 'ജലവിതരണം, തെരുവ് വിളക്ക് തുടങ്ങിയ പ്രശ്നങ്ങൾ റിപ്പോർട്ട് ചെയ്യൂ.' },
    hi: { title: 'समस्या रिपोर्ट', desc: 'पानी की आपूर्ति, सड़क की रोशनी जैसी नागरिक शिकायतें दर्ज करें।' },
  },
  { icon: '🌱', href: '/green', tag_ta: 'சுற்றுச்சூழல்', tag_en: 'Eco', tag_ml: 'പരിസ്ഥിതി', tag_hi: 'पर्यावरण',
    color: 'from-green-50 to-emerald-50 border-green-200/60',
    ta: { title: 'பசுமை FYC', desc: 'மர நடும் பிரச்சாரங்கள், சுற்றுச்சூழல் செயல்பாடுகள் மற்றும் இயற்கை சேவை.' },
    en: { title: 'Green FYC', desc: 'Tree planting drives, eco initiatives, and environmental service activities.' },
    ml: { title: 'ഗ്രീൻ FYC', desc: 'മരം നടൽ, പരിസ്ഥിതി സംരക്ഷണ പ്രവർത്തനങ്ങൾ.' },
    hi: { title: 'हरित FYC', desc: 'वृक्षारोपण, पर्यावरण पहल और प्रकृति सेवा।' },
  },
  { icon: '🛍️', href: '/directory', tag_ta: 'புதியது', tag_en: 'New', tag_ml: 'പുതിയത്', tag_hi: 'नया',
    color: 'from-emerald-50 to-teal-50 border-emerald-200/60',
    ta: { title: 'சமூக கடை', desc: 'தச்சர்கள், மின்சாரிகள், ஆசிரியர்கள் — உங்களைச் சுற்றியுள்ள திறமைகளைக் கண்டறியவும்.' },
    en: { title: 'Skills Directory', desc: 'Find local carpenters, electricians, tutors, and verified community profiles.' },
    ml: { title: 'കഴിവ് ഡയറക്ടറി', desc: 'ആശാരിമാർ, ഇലക്ട്രീഷ്യൻ, അധ്യാപകർ — നിങ്ങളുടെ ചുറ്റുപാടിലുള്ള കഴിവുകൾ.' },
    hi: { title: 'कौशल निर्देशिका', desc: 'स्थानीय बढ़ई, बिजली मिस्त्री, शिक्षक खोजें।' },
  },
  { icon: '🪪', href: '/verify', tag_ta: 'அதிகாரப்பூர்வம்', tag_en: 'Official', tag_ml: 'ഔദ്യോഗികം', tag_hi: 'आधिकारिक',
    color: 'from-slate-50 to-gray-50 border-slate-200/60',
    ta: { title: 'அட்டை சரிபார்', desc: 'FYC உறுப்பினர் அட்டையை QR மூலம் சரிபார்க்கவும்.' },
    en: { title: 'Verify Card', desc: 'Scan and verify FYC membership cards using QR code.' },
    ml: { title: 'കാർഡ് സ്ഥിരീകരണം', desc: 'QR ഉപയോഗിച്ച് FYC അംഗ കാർഡ് സ്ഥിരീകരിക്കൂ.' },
    hi: { title: 'कार्ड सत्यापन', desc: 'QR कोड से FYC सदस्यता कार्ड सत्यापित करें।' },
  },
  { icon: '💼', href: '/opportunities', tag_ta: 'வேலை', tag_en: 'Jobs', tag_ml: 'ജോലി', tag_hi: 'नौकरी',
    color: 'from-cyan-50 to-sky-50 border-cyan-200/60',
    ta: { title: 'வாய்ப்புகள்', desc: 'TN அரசு வேலைகள், மத்திய அரசு வேலைகள் மற்றும் சமூக வாய்ப்புகள்.' },
    en: { title: 'Opportunities', desc: 'TN & Central govt jobs, scholarships, and community opportunities.' },
    ml: { title: 'അവസരങ്ങൾ', desc: 'TN & കേന്ദ്ര സർക്കാർ ജോലികൾ, സ്കോളർഷിപ്പ്.' },
    hi: { title: 'अवसर', desc: 'TN और केंद्र सरकार की नौकरियां, छात्रवृत्ति।' },
  },
];

const updates = [
  { avatar: '👨‍💼', name: 'R. Prathap', role: 'Club President', time: '2 hours ago',
    ta: 'நாகர்கோவில் கிரிக்கெட் கோப்பை 2026 போட்டிக்கான பதிவுகள் ஆரம்பம்! உங்கள் அணியை இப்போதே பதிவு செய்யுங்கள்.',
    en: 'Nagercoil Cricket Cup 2026 registrations are now open! Register your team today.',
    ml: 'നഗർകോവിൽ ക്രിക്കറ്റ് കപ്പ് 2026 രജിസ്ട്രേഷൻ ആരംഭിച്ചു!',
    hi: 'नागरकोइल क्रिकेट कप 2026 पंजीकरण शुरू हो गया है!',
    tag: 'Sports Hub' },
  { avatar: '👩‍⚕️', name: 'Kavitha S.', role: 'Volunteer Coordinator', time: '5 hours ago',
    ta: 'ஆசாத் நகர் பகுதியில் நட்ட மரக்கன்றுகளுக்கு நீர் ஊற்றும் பணி வெற்றிகரமாக முடிந்தது. தன்னார்வலர்களுக்கு நன்றி!',
    en: 'Watering drive for planted saplings in Azad Nagar completed successfully. Thanks to all volunteers!',
    ml: 'അസദ് നഗറിലെ തൈകൾക്ക് വെള്ളം ഒഴിക്കൽ വിജയകരമായി പൂർത്തിയായി.',
    hi: 'अज़ाद नगर में लगाए गए पौधों की सिंचाई सफलतापूर्वक पूरी हुई।',
    tag: 'Green FYC' },
  { avatar: '🚧', name: 'Triage System', role: 'System Bot', time: '1 day ago',
    ta: 'வார்டு 4-ல் பதிவான குடிநீர் குழாய் உடைப்பு பிரச்னை சரிசெய்யப்பட்டு "முடிந்தது" என மாற்றப்பட்டது.',
    en: 'Water pipeline leak reported in Ward 4 has been repaired and marked as RESOLVED.',
    ml: 'വാർഡ് 4-ൽ റിപ്പോർട്ട് ചെയ്ത ജലക്കുഴൽ ചോർച്ച നന്നാക്കി പരിഹരിച്ചു.',
    hi: 'वार्ड 4 में रिपोर्ट की गई जल पाइप लीक की मरम्मत की गई।',
    tag: 'Civic Triage' },
];
---

<BaseLayout title="FYC Connect — Unite · Play · Thrive">

  <style>
    /* ── Auth-split: both views hidden until inline script decides ── */
    #guest-view  { display: none; }
    #auth-view   { display: none; }
    html.is-guest #guest-view { display: block; }
    html.is-auth  #auth-view  { display: block; }

    /* ── Aurora blobs ── */
    @keyframes aurora1 {
      0%,100% { transform: translate(0,0) scale(1); }
      33%      { transform: translate(40px,-30px) scale(1.08); }
      66%      { transform: translate(-25px,20px) scale(0.95); }
    }
    @keyframes aurora2 {
      0%,100% { transform: translate(0,0) scale(1); }
      33%      { transform: translate(-35px,25px) scale(1.05); }
      66%      { transform: translate(20px,-15px) scale(1.1); }
    }
    @keyframes aurora3 {
      0%,100% { transform: translate(0,0) scale(1); }
      50%      { transform: translate(20px,30px) scale(1.06); }
    }
    .aurora-1 { animation: aurora1 12s ease-in-out infinite; }
    .aurora-2 { animation: aurora2 16s ease-in-out infinite; }
    .aurora-3 { animation: aurora3 10s ease-in-out infinite; }

    /* ── Scroll-triggered reveals ── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }
    .reveal.in-view {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Scroll bounce indicator ── */
    @keyframes scrollBounce {
      0%,100% { transform: translateY(0); opacity:1; }
      50%      { transform: translateY(6px); opacity:0.4; }
    }
    .scroll-dot { animation: scrollBounce 1.6s ease-in-out infinite; }

    /* ── Locked preview blur ── */
    .locked-grid { filter: blur(5px); pointer-events: none; user-select: none; }

    /* ── Counter ── */
    .stat-num { font-variant-numeric: tabular-nums; }

    /* ── Module card hover ── */
    .module-card:hover .module-icon { transform: scale(1.12) rotate(-3deg); }
    .module-card:hover .module-arrow { transform: translateX(4px); }

    /* ── Bento grid ── */
    @media (min-width: 768px) {
      .bento-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: minmax(160px, auto);
        gap: 1rem;
      }
      .bento-grid > *:nth-child(1) { grid-column: span 2; }
      .bento-grid > *:nth-child(6) { grid-column: span 2; }
    }
  </style>

  <!-- ═══════════════════════════════════════════════════════════════
       GUEST VIEW
  ══════════════════════════════════════════════════════════════════ -->
  <div id="guest-view">

    <!-- ── Hero: Aurora Dark ── -->
    <section class="relative min-h-[100svh] bg-[#030c06] overflow-hidden flex flex-col items-center justify-center">

      <!-- Aurora blobs -->
      <div class="aurora-1 absolute top-[10%] left-[15%] w-[500px] h-[500px] rounded-full bg-[#0F5132] opacity-30 blur-[100px]"></div>
      <div class="aurora-2 absolute bottom-[15%] right-[10%] w-[450px] h-[450px] rounded-full bg-[#064e3b] opacity-35 blur-[110px]"></div>
      <div class="aurora-3 absolute top-[40%] right-[30%] w-[300px] h-[300px] rounded-full bg-[#D4AF37] opacity-10 blur-[80px]"></div>

      <!-- Grid overlay -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff06_1px,transparent_1px),linear-gradient(to_bottom,#ffffff06_1px,transparent_1px)] bg-[size:44px_44px] pointer-events-none"></div>

      <!-- Vignette -->
      <div class="absolute inset-0 bg-radial-[ellipse_at_center] from-transparent to-[#030c06]/80 pointer-events-none"></div>

      <!-- Content -->
      <div class="relative z-10 max-w-5xl mx-auto px-6 text-center py-24 space-y-8">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2.5 bg-[#0F5132]/25 border border-[#198754]/35 backdrop-blur-md rounded-full px-5 py-2 text-xs font-bold text-green-300 uppercase tracking-widest reveal">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse inline-block"></span>
          <span
            data-ta="நண்பர்கள் இளைஞர் மன்றம் · 2000 முதல்"
            data-en="Friends Youth Club · Since 2000"
            data-ml="ഫ്രണ്ട്സ് യൂത്ത് ക്ലബ് · 2000 മുതൽ"
            data-hi="फ्रेंड्स यूथ क्लब · 2000 से">Friends Youth Club · Since 2000</span>
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-[1.05] tracking-tight reveal">
          <span
            data-ta="நாகர்கோவிலின்"
            data-en="Let's Connect"
            data-ml="ചേരാം"
            data-hi="जुड़ें">Let's Connect</span><br />
          <span class="inline-block bg-gradient-to-r from-[#4ade80] via-[#86efac] to-[#fbbf24] bg-clip-text text-transparent">
            <span
              data-ta="துடிப்பான சமூகத்தில்"
              data-en="to Nagercoil's"
              data-ml="നഗർകോവിലിന്റെ"
              data-hi="नागरकोइल के">to Nagercoil's</span>
          </span><br />
          <span
            data-ta="இணைவோம்!"
            data-en="Vibrant Community"
            data-ml="ജനകീയ സമൂഹം"
            data-hi="जीवंत समुदाय">Vibrant Community</span>
        </h1>

        <!-- Subtext -->
        <p class="text-base sm:text-lg text-green-100/65 max-w-2xl mx-auto leading-relaxed reveal"
          data-ta="விளையாட்டு, இரத்த தானம், சமூக சேவை — 25 ஆண்டுகளாக ஒன்றிணைந்த நாகர்கோவில் சமூகம்."
          data-en="Sports, blood donation, civic service — 25 years of united community in Kanyakumari."
          data-ml="കായികം, രക്തദാനം, സേവനം — 25 വർഷത്തെ ഒന്നിച്ചുള്ള ജീവിതം."
          data-hi="खेल, रक्तदान, नागरिक सेवा — नागरकोइल में 25 साल की एकजुट यात्रा।">
          Sports, blood donation, civic service — 25 years of united community in Kanyakumari.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-2 reveal">
          <a href="/login" class="group inline-flex items-center justify-center gap-2.5 bg-[#D4AF37] text-gray-900 font-bold px-8 py-4 rounded-2xl text-sm hover:bg-amber-400 transition-all shadow-[0_0_40px_rgba(212,175,55,0.35)] hover:shadow-[0_0_60px_rgba(212,175,55,0.55)] active:scale-95">
            <span
              data-ta="உள்நுழை / சேரு"
              data-en="Sign In / Join"
              data-ml="സൈൻ ഇൻ / ചേരുക"
              data-hi="साइन इन / जुड़ें">Sign In / Join</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="#our-story" class="inline-flex items-center justify-center gap-2 bg-white/8 backdrop-blur-sm border border-white/15 text-white font-semibold px-8 py-4 rounded-2xl text-sm hover:bg-white/15 transition-all active:scale-95">
            <span
              data-ta="எங்களை பற்றி"
              data-en="Learn More"
              data-ml="കൂടുതൽ അറിയുക"
              data-hi="और जानें">Learn More</span>
            <span class="scroll-dot inline-block">↓</span>
          </a>
        </div>

        <!-- Floating stat pills -->
        <div class="flex flex-wrap justify-center gap-3 pt-4 reveal">
          {[
            { n:'1,500+', ta:'மரங்கள்', en:'Trees', ml:'മരങ്ങൾ', hi:'पेड़', c:'text-green-400' },
            { n:'1,200+', ta:'இரத்த கொடையாளர்', en:'Blood Donors', ml:'രക്തദാതാ', hi:'रक्तदाता', c:'text-rose-400' },
            { n:'80+', ta:'நிகழ்வுகள்', en:'Events', ml:'ഇവന്റ്', hi:'कार्यक्रम', c:'text-amber-400' },
            { n:'5,000+', ta:'பயன் பெற்றோர்', en:'Lives Impacted', ml:'ഗുണഭോക്തൃ', hi:'लाभान्वित', c:'text-blue-400' },
