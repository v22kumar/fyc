---
import BaseLayout from '../layouts/BaseLayout.astro';
import { API_BASE, DEFAULT_ORG_ID } from '../lib/config';
---

<BaseLayout
  title="FYC Sports | Team Registration & Fixtures"
  description="Register your team for FYC sports tournaments and view match fixtures."
>
  <main class="page-bg bg-gray-50 min-h-screen pb-16">
    <script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <div id="loading" class="text-center py-16">
        <div class="inline-block w-10 h-10 border-4 border-[#064e3b] border-t-transparent rounded-full animate-spin mb-4"></div>
        <p class="text-gray-500">Loading tournament details...</p>
    </div>
    
    <div id="error" class="hidden text-center py-16">
        <div class="text-5xl mb-4">⚠️</div>
        <p class="text-gray-600 font-medium">Tournament not found or failed to load.</p>
        <a href="/sports" class="inline-block mt-4 text-[#064e3b] underline font-medium">Back to Sports Hub</a>
    </div>

    <div id="content" class="hidden">
        <div class="header-banner bg-[#0f5132] text-white py-12">
        <div class="container mx-auto px-4 max-w-6xl">
            <a href="/sports" class="back-link inline-block text-green-200 hover:text-white transition-colors mb-4 text-sm font-medium">← Back to Sports Hub</a>
            <h1 id="t-name-en" class="text-3xl sm:text-4xl font-bold mb-2"></h1>
            <p id="t-name-ta" class="ta-title text-green-100 text-lg mb-6"></p>
            <div class="meta flex flex-wrap gap-6 text-sm text-green-100 font-medium">
                <span id="t-venue" class="flex items-center gap-2">🏟️ <span></span></span>
                <span id="t-sport" class="flex items-center gap-2">🏆 <span></span></span>
            </div>
        </div>
        </div>

        <div class="container mx-auto px-4 max-w-6xl content-split mt-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="details lg:col-span-7">
            
            <div id="admin-tools" class="hidden mb-10 bg-amber-50 p-6 rounded-xl border border-amber-200">
                <h3 class="text-xl font-bold mb-4 text-amber-900 border-b border-amber-200 pb-2 flex justify-between items-center">
                    <div class="flex gap-2">
                        <button id="generateFixturesBtn" class="bg-amber-600 text-white px-4 py-1.5 rounded-lg text-sm font-bold hover:bg-amber-700 transition-colors">Generate</button>
                        <button onclick="openAddFixtureModal()" class="bg-white border border-amber-600 text-amber-700 px-4 py-1.5 rounded-lg text-sm font-bold hover:bg-amber-50 transition-colors">+ Add Fixture</button>
                    </div>
                </h3>
                <div id="admin-teams-list" class="flex flex-col gap-3 max-h-96 overflow-y-auto pr-2">
                    <!-- Populated by JS -->
                </div>
            </div>

            <div id="t-description-container" class="hidden mb-10">
                <h3 class="text-2xl font-bold mb-6 text-gray-900 border-b border-gray-200 pb-2">About Tournament</h3>
                <div id="t-description" class="prose max-w-none text-gray-700 leading-relaxed"></div>
            </div>

            <h3 class="text-2xl font-bold mb-6 text-gray-900 border-b border-gray-200 pb-2">Match Fixtures</h3>
            <div id="fixtures-container">
                <!-- Populated by JS -->
            </div>
        </div>

        <div class="form-container lg:col-span-5 self-start bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-xl font-bold mb-6 pb-4 border-b border-gray-100 text-gray-900">Register Your Team</h3>
            
            <div id="auth-warning" class="hidden bg-amber-50 border border-amber-200 text-amber-800 p-4 rounded-lg mb-6 text-sm">
                You must <a href="/login" class="font-bold underline text-amber-900">Log In</a> to register a team.
            </div>

            <form id="teamForm" class="reg-form flex flex-col gap-5">
            <input type="hidden" id="tourneyId" />
            
            <div class="form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Team Name *</label>
                <input type="text" id="tname" required class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#064e3b] focus:border-[#064e3b] outline-none transition-shadow" placeholder="e.g. FYC Warriors" />
            </div>
            
            <div class="form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Captain Name *</label>
                <input type="text" id="cname" required class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#064e3b] focus:border-[#064e3b] outline-none transition-shadow" placeholder="Full Name" />
            </div>

            <div class="form-group flex flex-col gap-1.5">
                <label class="text-sm font-medium text-gray-700">Contact Number *</label>
                <input type="tel" id="mobile" required pattern="[0-9]{10}" class="p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#064e3b] focus:border-[#064e3b] outline-none transition-shadow" placeholder="10-digit mobile number" />
            </div>

            <button type="submit" id="submitBtn" class="submit-btn bg-[#064e3b] text-white font-bold py-3 px-4 rounded-lg hover:bg-[#0f5132] transition-colors mt-2 disabled:bg-gray-400 disabled:cursor-not-allowed shadow-sm">
                Submit Team Registration
            </button>
            <div id="msg" class="hidden mt-4 p-3 rounded-lg text-sm text-center font-medium"></div>
            </form>
        </div>
        </div>
    </div>

    <!-- Result Update Modal -->
    <div id="resultModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4 font-sans">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
            <div class="flex justify-between items-center border-b border-gray-100 pb-3 mb-4">
                <h3 class="text-lg font-bold text-gray-900">Update Match Result</h3>
                <button onclick="closeResultModal()" class="text-gray-400 hover:text-gray-600">✕</button>
            </div>
            
            <form id="resultForm" class="flex flex-col gap-4">
                <input type="hidden" id="modalFixtureId" />
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1">
                        <label id="lblTeamA" class="text-xs font-semibold text-gray-500 uppercase">Team A Score</label>
                        <input type="text" id="scoreA" required class="p-2.5 border border-gray-300 rounded-lg outline-none text-gray-900" placeholder="e.g. 120/5 (20)" />
                    </div>
                    <div class="flex flex-col gap-1">
                        <label id="lblTeamB" class="text-xs font-semibold text-gray-500 uppercase">Team B Score</label>
                        <input type="text" id="scoreB" required class="p-2.5 border border-gray-300 rounded-lg outline-none text-gray-900" placeholder="e.g. 121/2 (18.2)" />
                    </div>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-500 uppercase">Winner</label>
                    <select id="winnerSelect" class="p-2.5 border border-gray-300 rounded-lg outline-none bg-white text-gray-900">
                        <option value="">Select Winner (Or Draw)</option>
                        <option id="optTeamA" value="">Team A</option>
                        <option id="optTeamB" value="">Team B</option>
                    </select>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-500 uppercase">Result Notes / Description</label>
                    <input type="text" id="resultNotes" class="p-2.5 border border-gray-300 rounded-lg outline-none text-gray-900" placeholder="e.g. Team B won by 8 wickets" />
                </div>

                <div class="flex gap-3 justify-end mt-4">
                    <button type="button" onclick="closeResultModal()" class="flex-1 border border-gray-300 py-2 rounded-xl text-gray-600 font-medium">Cancel</button>
                    <button type="submit" id="saveResultBtn" class="flex-1 bg-[#064e3b] text-white py-2 rounded-xl font-semibold hover:bg-[#0f5132]">Save Result</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add Fixture Modal -->
    <div id="addFixtureModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4 font-sans">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
            <div class="flex justify-between items-center border-b border-gray-100 pb-3 mb-4">
                <h3 class="text-lg font-bold text-gray-900">Add Custom Fixture</h3>
                <button onclick="closeAddFixtureModal()" class="text-gray-400 hover:text-gray-600">✕</button>
            </div>
            
            <form id="addFixtureForm" class="flex flex-col gap-4">
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-500 uppercase">Team A</label>
                    <select id="fixtureTeamA" required class="p-2.5 border border-gray-300 rounded-lg outline-none bg-white text-gray-900">
                        <option value="">Select Team</option>
                    </select>
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-500 uppercase">Team B</label>
                    <select id="fixtureTeamB" required class="p-2.5 border border-gray-300 rounded-lg outline-none bg-white text-gray-900">
                        <option value="">Select Team</option>
                    </select>
                </div>
                
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-500 uppercase">Match Date & Time (Optional)</label>
                    <input type="datetime-local" id="fixtureDate" class="p-2.5 border border-gray-300 rounded-lg outline-none text-gray-900" />
                </div>
                
                <div class="flex flex-col gap-1">
                    <label class="text-xs font-semibold text-gray-500 uppercase">Venue (Optional)</label>
                    <input type="text" id="fixtureVenue" class="p-2.5 border border-gray-300 rounded-lg outline-none text-gray-900" placeholder="e.g. Main Ground" />
                </div>

                <div class="flex gap-3 justify-end mt-4">
                    <button type="button" onclick="closeAddFixtureModal()" class="flex-1 border border-gray-300 py-2 rounded-xl text-gray-600 font-medium">Cancel</button>
                    <button type="submit" id="saveAddFixtureBtn" class="flex-1 bg-amber-600 text-white py-2 rounded-xl font-semibold hover:bg-amber-700">Add Fixture</button>
                </div>
            </form>
        </div>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ API_BASE, DEFAULT_ORG_ID }}>
    const urlParams = new URLSearchParams(window.location.search);
    const tourneyId = urlParams.get('id');

    // Escape user/API-supplied values before inserting into innerHTML (XSS guard).
    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, (c) => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        }[c]));
    }

    // Strip <script>/<style> blocks and inline event handlers from rendered
    // markdown HTML as a defense-in-depth pass (marked does not sanitize).
    function sanitizeHtml(html) {
        return String(html ?? '')
            .replace(/<\/(?:script|style)>/gi, '')
            .replace(/<(?:script|style)\b[^>]*>/gi, '')
            .replace(/\son\w+\s*=\s*("[^"]*"|'[^']*'|[^\s>]+)/gi, '')
            .replace(/(href|src)\s*=\s*(["'])\s*javascript:[^"']*\2/gi, '$1="#"');
    }

    async function loadData() {
        if (!tourneyId) {
            document.getElementById('loading').classList.add('hidden');
            document.getElementById('error').classList.remove('hidden');
            return;
        }

        try {
            const [tRes, fixRes] = await Promise.all([
                fetch(`${API_BASE}/api/v1/sports/tournaments/${tourneyId}`, { headers: { 'X-Organization-ID': DEFAULT_ORG_ID } }),
                fetch(`${API_BASE}/api/v1/sports/tournaments/${tourneyId}/fixtures`, { headers: { 'X-Organization-ID': DEFAULT_ORG_ID } })
            ]);

            if (!tRes.ok) throw new Error('Not found');

            const tournament = await tRes.json();
            const fixtures = fixRes.ok ? await fixRes.json() : [];

            document.getElementById('tourneyId').value = tournament.id;
            document.getElementById('t-name-en').textContent = tournament.name_en;
            document.getElementById('t-name-ta').textContent = tournament.name_ta;
            document.querySelector('#t-venue span').textContent = tournament.venue || 'TBA';
            document.querySelector('#t-sport span').textContent = `${tournament.sport.toUpperCase()} - ${tournament.year}`;

            if (tournament.description_en) {
                document.getElementById('t-description-container').classList.remove('hidden');
                document.getElementById('t-description').innerHTML = sanitizeHtml(marked.parse(tournament.description_en));
            }

            const token = localStorage.getItem('fyc_token');
            const role = localStorage.getItem('fyc_role');
            const isAdmin = role === 'SUPER_ADMIN' || role === 'ADMIN' || role === 'EXECUTIVE_MEMBER';

            const submitBtn = document.getElementById('submitBtn');
            if (tournament.status !== 'UPCOMING' && !isAdmin) {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Registration Closed';
            }
            
            if (isAdmin) {
                document.getElementById('admin-tools').classList.remove('hidden');
                loadAdminTeams(tournament.id, token);
            }

            if (!token && tournament.status === 'UPCOMING') {
                document.getElementById('auth-warning').classList.remove('hidden');
                submitBtn.disabled = true;
                submitBtn.textContent = 'Login Required';
            }

            renderFixtures(fixtures, tournament.sport);

            document.getElementById('loading').classList.add('hidden');
            document.getElementById('content').classList.remove('hidden');
        } catch (e) {
            document.getElementById('loading').classList.add('hidden');
            document.getElementById('error').classList.remove('hidden');
        }
    }

    let loadedTeams = [];

    async function loadAdminTeams(tId, token) {
        try {
            const res = await fetch(`${API_BASE}/api/v1/sports/tournaments/${tId}/teams`, {
                headers: { 'X-Organization-ID': DEFAULT_ORG_ID, 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) return;
            const teams = await res.json();
            loadedTeams = teams.filter(t => t.status === 'APPROVED');
            
            const container = document.getElementById('admin-teams-list');
            if (teams.length === 0) {
                container.innerHTML = '<p class="text-sm text-amber-800">No teams registered yet.</p>';
                return;
            }
            container.innerHTML = teams.map(t => `
                <div class="bg-white p-4 rounded-lg border border-amber-100 flex justify-between items-center shadow-sm">
                    <div>
                        <div class="font-bold text-gray-900">${escapeHtml(t.name)} ${t.status === 'PENDING' ? '<span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded-full ml-2">PENDING</span>' : '<span class="text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded-full ml-2">APPROVED</span>'}</div>
                        <div class="text-xs text-gray-500 mt-1">Capt: ${escapeHtml(t.captain_name || 'N/A')} | ${escapeHtml(t.contact_number || 'N/A')}</div>
                    </div>
                    ${t.status === 'PENDING' ? `<button onclick="approveTeam('${escapeHtml(t.id)}')" class="bg-[#064e3b] text-white px-3 py-1.5 rounded text-xs font-bold hover:bg-[#0f5132]">Approve</button>` : ''}
                </div>
            `).join('');
        } catch (e) {
            console.error(e);
        }
    }

    window.approveTeam = async function(teamId) {
        const token = localStorage.getItem('fyc_token');
        try {
            const res = await fetch(`${API_BASE}/api/v1/sports/tournaments/${tourneyId}/teams/${teamId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'X-Organization-ID': DEFAULT_ORG_ID, 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ status: 'APPROVED' })
            });
            if (res.ok) {
                loadAdminTeams(tourneyId, token);
            } else {
                alert('Failed to approve team');
            }
        } catch (e) {
            alert('Error approving team');
        }
    };

    document.getElementById('generateFixturesBtn')?.addEventListener('click', async () => {
        const token = localStorage.getItem('fyc_token');
        try {
            const res = await fetch(`${API_BASE}/api/v1/sports/tournaments/${tourneyId}/generate-fixtures?double_round=false`, {
                method: 'POST',
                headers: { 'X-Organization-ID': DEFAULT_ORG_ID, 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
                alert('Fixtures generated successfully!');
                location.reload();
            } else {
                const data = await res.json();
                alert(data.detail || 'Failed to generate fixtures');
            }
        } catch (e) {
            alert('Error generating fixtures');
        }
    });

    window.openAddFixtureModal = function() {
        if (loadedTeams.length < 2) {
            alert("At least 2 approved teams are required to add a fixture.");
            return;
        }
        
        const selA = document.getElementById('fixtureTeamA');
        const selB = document.getElementById('fixtureTeamB');
        
        const optionsHtml = '<option value="">Select Team</option>' + loadedTeams.map(t => 
            `<option value="${t.id}">${escapeHtml(t.name)}</option>`
        ).join('');
        
        selA.innerHTML = optionsHtml;
        selB.innerHTML = optionsHtml;
        
        document.getElementById('fixtureDate').value = '';
        document.getElementById('fixtureVenue').value = '';
        
        document.getElementById('addFixtureModal').classList.remove('hidden');
    };

    window.closeAddFixtureModal = function() {
        document.getElementById('addFixtureModal').classList.add('hidden');
    };

    document.getElementById('addFixtureForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const teamA = document.getElementById('fixtureTeamA').value;
        const teamB = document.getElementById('fixtureTeamB').value;
        
        if (teamA === teamB) {
            alert("Please select two different teams.");
            return;
        }

        const dateVal = document.getElementById('fixtureDate').value;
        const payload = {
            team_a_id: teamA,
            team_b_id: teamB,
            scheduled_at: dateVal ? new Date(dateVal).toISOString() : undefined,
            venue: document.getElementById('fixtureVenue').value || undefined
        };

        const token = localStorage.getItem('fyc_token');
        const btn = document.getElementById('saveAddFixtureBtn');
        const oldText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Adding...';

        try {
            const res = await fetch(`${API_BASE}/api/v1/sports/tournaments/${tourneyId}/fixtures`, {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'X-Organization-ID': DEFAULT_ORG_ID, 
                    'Authorization': `Bearer ${token}` 
                },
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                alert('Fixture added successfully!');
                location.reload();
            } else {
                const data = await res.json();
                alert(data.detail || data.message || 'Failed to add fixture');
            }
        } catch (err) {
            alert('Error adding fixture');
        } finally {
            btn.disabled = false;
            btn.textContent = oldText;
            closeAddFixtureModal();
        }
    });

    function renderFixtures(fixtures, sport) {
        const container = document.getElementById('fixtures-container');
        if (!fixtures || fixtures.length === 0) {
            container.innerHTML = '<div class="bg-amber-50 border border-amber-200 text-amber-800 p-4 rounded-lg text-sm">Fixtures have not been generated yet. Register your team below to participate!</div>';
            return;
        }

        const role = localStorage.getItem('fyc_role');
        const isAdmin = role === 'SUPER_ADMIN' || role === 'ADMIN' || role === 'EXECUTIVE_MEMBER';
        const adminUrl = window.location.hostname === 'localhost' ? 'http://localhost:3000' : 'https://fyc-admin.fly.dev';

        container.innerHTML = `<div class="flex flex-col gap-4">` + fixtures.map((f) => {
            const showAdminControls = isAdmin;
            const adminControlsHtml = showAdminControls ? `
                <div class="mt-4 flex gap-2 justify-end border-t border-gray-100 pt-3">
                    <button onclick="openResultModal('${f.id}', '${escapeHtml(f.team_a_name || 'Team A')}', '${escapeHtml(f.team_b_name || 'Team B')}', '${escapeHtml(f.team_a_id)}', '${escapeHtml(f.team_b_id)}')" class="bg-white border border-[#064e3b] text-[#064e3b] px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-green-50 transition-colors shadow-sm">Enter Score</button>
                    ${(sport || '').toLowerCase() === 'cricket' ? `<a href="${adminUrl}/dashboard/sports/cricket/${f.id}" target="_blank" class="bg-[#064e3b] text-white px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-[#0f5132] transition-colors shadow-sm">Live Scoring Dashboard</a>` : ''}
                </div>
            ` : '';

            return `
                <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow">
                    <div class="text-xs font-semibold text-gray-500 mb-3 uppercase tracking-wider flex justify-between items-center">
                        <span>Match #${f.match_number}</span>
                        <span class="px-2 py-1 rounded-full ${f.status === 'COMPLETED' ? 'bg-green-100 text-green-700' : f.status === 'LIVE' ? 'bg-red-100 text-red-600 animate-pulse' : 'bg-blue-100 text-blue-700'}">${f.status}</span>
                    </div>
                    <div class="flex items-center justify-between font-bold text-lg text-gray-900 px-2 md:px-8">
                        <span class="flex-1 text-center truncate">${escapeHtml(f.team_a_name || '?')}</span>
                        <span class="text-gray-300 font-medium text-sm px-4">VS</span>
                        <span class="flex-1 text-center truncate">${escapeHtml(f.team_b_name || '?')}</span>
                    </div>
                    ${f.status === 'COMPLETED' ? `
                        <div class="mt-4 text-center">
                            <span class="inline-block bg-green-50 text-green-800 font-bold px-4 py-2 rounded-lg text-sm border border-green-100">Score: ${f.team_a_score || 0} - ${f.team_b_score || 0}</span>
                            ${f.result_notes ? `<div class="text-xs text-gray-500 mt-2">${escapeHtml(f.result_notes)}</div>` : ''}
                        </div>
                    ` : ''}
                    ${adminControlsHtml}
                </div>
            `;
        }).join('') + `</div>`;
    }

    loadData();

    const form = document.getElementById('teamForm');
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const tId = document.getElementById('tourneyId').value;
        const msgEl = document.getElementById('msg');
        const btn = document.getElementById('submitBtn');
        
        const payload = {
            name: document.getElementById('tname').value,
            captain_name: document.getElementById('cname').value,
            contact_number: document.getElementById('mobile').value
        };

        btn.disabled = true;
        btn.textContent = "Registering...";

        try {
            const token = localStorage.getItem('fyc_token') || ''; 

            const res = await fetch(`${API_BASE}/api/v1/sports/tournaments/${tId}/teams`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`,
                    'X-Organization-ID': DEFAULT_ORG_ID
                },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            
            msgEl.classList.remove('hidden', 'bg-green-100', 'text-green-800', 'bg-red-100', 'text-red-800', 'bg-amber-100', 'text-amber-800');

            if (res.ok) {
                msgEl.classList.add('block', 'bg-green-100', 'text-green-800');
                msgEl.textContent = 'Team Registered successfully!';
                form.reset();
            } else if (res.status === 401) {
                localStorage.removeItem('fyc_token');
                msgEl.classList.add('block', 'bg-amber-100', 'text-amber-800');
                msgEl.innerHTML = 'Session expired. Please <a href="/login" class="underline font-bold text-amber-900">log in again</a>.';
                btn.disabled = true;
            } else {
                msgEl.classList.add('block', 'bg-red-100', 'text-red-800');
                msgEl.textContent = data.detail || 'Failed to register. Please try again.';
            }
        } catch (err) {
            msgEl.classList.remove('hidden');
            msgEl.classList.add('block', 'bg-red-100', 'text-red-800');
            msgEl.textContent = 'Network error. Please try again.';
        } finally {
            btn.disabled = false;
            if (msgEl.innerHTML.includes('log in again')) {
                btn.disabled = true;
            }
            btn.textContent = "Submit Team Registration";
        }
    });

    window.openResultModal = function(fixtureId, nameA, nameB, idA, idB) {
        document.getElementById('modalFixtureId').value = fixtureId;
        document.getElementById('lblTeamA').textContent = `${nameA} Score`;
        document.getElementById('lblTeamB').textContent = `${nameB} Score`;
        
        const optA = document.getElementById('optTeamA');
        optA.textContent = nameA;
        optA.value = idA;
        
        const optB = document.getElementById('optTeamB');
        optB.textContent = nameB;
        optB.value = idB;

        document.getElementById('scoreA').value = '';
        document.getElementById('scoreB').value = '';
        document.getElementById('winnerSelect').value = '';
        document.getElementById('resultNotes').value = '';

        document.getElementById('resultModal').classList.remove('hidden');
    };

    window.closeResultModal = function() {
        document.getElementById('resultModal').classList.add('hidden');
    };

    document.getElementById('resultForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fId = document.getElementById('modalFixtureId').value;
        const scoreA = document.getElementById('scoreA').value;
        const scoreB = document.getElementById('scoreB').value;
        const winnerId = document.getElementById('winnerSelect').value;
        const notes = document.getElementById('resultNotes').value;
        const btn = document.getElementById('saveResultBtn');
        const token = localStorage.getItem('fyc_token') || '';

        btn.disabled = true;
        btn.textContent = 'Saving...';

        try {
            const res = await fetch(`${API_BASE}/api/v1/sports/tournaments/${tourneyId}/fixtures/${fId}/result`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`,
                    'X-Organization-ID': DEFAULT_ORG_ID
                },
                body: JSON.stringify({
                    team_a_score: scoreA,
                    team_b_score: scoreB,
                    winner_id: winnerId || null,
                    result_notes: notes || null
                })
            });

            if (res.ok) {
                alert('Result submitted successfully!');
                location.reload();
            } else {
                const data = await res.json();
                alert(typeof data.detail === 'string' ? data.detail : JSON.stringify(data.detail) || 'Failed to submit result');
            }
        } catch (e) {
            alert('Error submitting result');
        } finally {
            btn.disabled = false;
            btn.textContent = 'Save Result';
        }
    });
</script>
