# Public API base URL (no trailing slash)
# In development: http://localhost:8000
# In production: https://api.fycconnect.org
PUBLIC_API_BASE=http://localhost:8000

# Default tenant organization ID (Friends Youth Club Nagercoil)
PUBLIC_DEFAULT_ORG_ID=8f8b80b7-4b71-4770-b183-5c5f49e49a1d

# Google OAuth 2.0 Web client ID — enables "Sign in with Google" on the web app.
# Steps:
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create credential → OAuth 2.0 Client ID → type: Web application
#   3. Add Authorized JavaScript origin: https://fyc-web.fly.dev (no trailing slash)
#   4. Copy the client ID below
# Production: flyctl secrets set PUBLIC_GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com" --app fyc-web
PUBLIC_GOOGLE_CLIENT_ID=
