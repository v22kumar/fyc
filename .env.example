# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=fyc_connect
POSTGRES_USER=fyc
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Backend API ───────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_32char_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Leave empty in production to require real OTPs
# Set to a 6-digit code for development/testing only
OTP_BYPASS_CODE=

# ── Public URLs (used by web and admin builds) ────────────────────────────────
PUBLIC_API_BASE=https://api.fyc.org
PUBLIC_DEFAULT_ORG_ID=8f8b80b7-4b71-4770-b183-5c5f49e49a1d

# ── First Superadmin (used by init_db.py on first run) ───────────────────────
FIRST_SUPERADMIN_PHONE=+919876543210
FIRST_SUPERADMIN_PASSWORD=changeme_admin_password
FIRST_SUPERADMIN_NAME_EN=Super Admin
FIRST_SUPERADMIN_NAME_TA=மேல் நிர்வாகி
